---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/invoice/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.invoice.title' | t }}"
  description: "{{ 'tools.invoice.lede' | t }}"
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><a class="eyebrow__link" href="{{ locale.pathPrefix }}/tools/">tools</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">invoice</span></p>
  <h1>{{ "tools.invoice.title" | t }}</h1>
  <p>{{ "tools.invoice.lede" | t }}</p>
  {% include "tldr.njk" %}
</section>

{% set terminalTitle = "invoice.js" %}
{% include "terminal-frame-open.njk" %}
<section class="iv">
  <div class="iv__actions no-print">
    <button class="m-btn m-btn--primary" id="iv-print" title="{{ 'tool.invoice.title_print' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      {{ "tool.invoice.btn_print" | t }}
    </button>
    <button class="m-btn m-btn--ghost" id="iv-export" title="{{ 'tool.invoice.title_export' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      {{ "tool.invoice.btn_export" | t }}
    </button>
    <label class="m-btn m-btn--ghost" for="iv-file" title="{{ 'tool.invoice.title_import' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      {{ "tool.invoice.btn_import" | t }}
      <input type="file" id="iv-file" accept="application/json,.json" hidden>
    </label>
    <button class="m-btn m-btn--danger" id="iv-clear" title="{{ 'tool.invoice.title_clear' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
      {{ "tool.invoice.btn_clear" | t }}
    </button>
  </div>

  <div class="iv__doc" id="iv-doc">
    <div class="iv__header">
      <div class="iv__title">{{ "tool.invoice.hdr_invoice" | t }}</div>
    </div>

    <div class="iv__parties">
      <div class="iv__section">
        <div class="iv__section-title">{{ "tool.invoice.section_from" | t }}</div>
        <input class="iv__input iv__input--heavy m-input" type="text" id="nameInp" autocomplete="name" placeholder="{{ 'tool.invoice.ph_name' | t }}" value="John Doe">
        <label class="iv__label" for="addr1Inp">{{ "tool.invoice.lbl_address" | t }}</label>
        <input class="iv__input m-input" type="text" id="addr1Inp" autocomplete="address-line1" placeholder="{{ 'tool.invoice.ph_addr1' | t }}">
        <input class="iv__input m-input" type="text" id="addr2Inp" autocomplete="address-line2" placeholder="{{ 'tool.invoice.ph_addr2' | t }}">
        <label class="iv__label" for="phoneInp">{{ "tool.invoice.lbl_phone" | t }}</label>
        <input class="iv__input m-input" type="tel" id="phoneInp" autocomplete="tel" placeholder="{{ 'tool.invoice.ph_phone' | t }}">
        <label class="iv__label" for="emailInp">{{ "tool.invoice.lbl_email" | t }}</label>
        <input class="iv__input m-input" type="email" id="emailInp" autocomplete="email" placeholder="{{ 'tool.invoice.ph_email' | t }}">
        <input class="iv__input m-input" type="text" id="extraInp" placeholder="{{ 'tool.invoice.ph_extra' | t }}">
      </div>

      <div class="iv__section">
        <div class="iv__section-title">{{ "tool.invoice.section_bill_to" | t }}</div>
        <input class="iv__input iv__input--heavy m-input" type="text" id="companyNameInp" placeholder="{{ 'tool.invoice.ph_company' | t }}">
        <input class="iv__input m-input" type="text" id="companyStreetInp" placeholder="{{ 'tool.invoice.ph_street' | t }}">
        <input class="iv__input m-input" type="text" id="companyCityInp" placeholder="{{ 'tool.invoice.ph_city' | t }}">
        <input class="iv__input m-input" type="text" id="companyCountryInp" placeholder="{{ 'tool.invoice.ph_country' | t }}">
        <label class="iv__label" for="companyVatInp">{{ "tool.invoice.lbl_vat" | t }}</label>
        <input class="iv__input m-input" type="text" id="companyVatInp" placeholder="{{ 'tool.invoice.ph_vat' | t }}">
      </div>
    </div>

    <div class="iv__meta">
      <div class="iv__meta-left">
        <p>
          <span class="iv__meta-label">{{ "tool.invoice.meta_invoice_no" | t }}</span>
          <input class="iv__meta-input m-input" type="text" id="invnoInp" placeholder="{{ 'tool.invoice.ph_invno' | t }}">
        </p>
        <p>
          <span class="iv__meta-label">{{ "tool.invoice.meta_invoice_date" | t }}</span>
          <input class="iv__meta-input iv__meta-input--date m-input" type="date" id="invoiceDate">
        </p>
        <p class="no-print">
          <span class="iv__meta-label">{{ "tool.invoice.meta_currency" | t }}</span>
          <select class="iv__meta-input m-input" id="currencyInp">
            <option value="₹">INR ₹</option>
            <option value="€">EUR €</option>
            <option value="$">USD $</option>
          </select>
        </p>
      </div>
      <div class="iv__meta-right">
        <p class="iv__amount-label">{{ "tool.invoice.amount_due" | t }}</p>
        <p class="iv__amount-value">
          <span class="grand-total">0</span>
        </p>
      </div>
    </div>

    <div class="iv__table-wrap">
    <table class="iv__table">
      <thead>
        <tr>
          <th class="iv__col-desc">{{ "tool.invoice.tbl_description" | t }}</th>
          <th class="iv__col-sac">{{ "tool.invoice.tbl_sac" | t }}</th>
          <th class="iv__col-qty">{{ "tool.invoice.tbl_quantity" | t }}</th>
          <th class="iv__col-price">{{ "tool.invoice.tbl_unit_price" | t }}</th>
          <th class="iv__col-total">{{ "tool.invoice.tbl_total" | t }}</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td data-label="{{ 'tool.invoice.tbl_description' | t }}">
            <button type="button" class="remove-row no-print m-btn m-btn--ghost m-btn--icon" title="{{ 'tool.invoice.row_remove' | t }}" aria-label="{{ 'tool.invoice.row_remove' | t }}">−</button>
            <textarea id="desc1Inp" placeholder="{{ 'tool.invoice.ph_line_desc' | t }}" rows="1"></textarea>
          </td>
          <td data-label="{{ 'tool.invoice.tbl_sac' | t }}"><input id="sac1Inp" type="text" value="998314" placeholder="______"></td>
          <td data-label="{{ 'tool.invoice.tbl_quantity' | t }}"><input id="qty1Inp" class="input-qty-cell" type="text" value="1" placeholder="{{ 'tool.invoice.ph_qty' | t }}" pattern="^[0-9]+(\.[0-9]+)?$" inputmode="decimal"></td>
          <td data-label="{{ 'tool.invoice.tbl_unit_price' | t }}">
            <span class="iv__cell-price">
              <input id="price1Inp" class="input-price-cell" type="text" value="0" placeholder="{{ 'tool.invoice.ph_price' | t }}" pattern="^[0-9]+(\.[0-9]+)?$" inputmode="decimal"><span class="currency">₹</span>
            </span>
          </td>
          <td data-label="{{ 'tool.invoice.tbl_total' | t }}"><span class="line-total">0</span></td>
        </tr>
        <tr class="last-row">
          <td class="last-row-first-col" colspan="4">
            <button type="button" class="add-row no-print m-btn m-btn--ghost m-btn--icon" title="{{ 'tool.invoice.row_add' | t }}" aria-label="{{ 'tool.invoice.row_add' | t }}">+</button>
            <span class="last-row-label">{{ "tool.invoice.footer_total" | t }}</span>
          </td>
          <td class="total"><span class="grand-total">0</span></td>
        </tr>
      </tbody>
    </table>
    </div>

    <div class="iv__section iv__notes">
      <div class="iv__section-title">{{ "tool.invoice.section_notes" | t }}</div>
      <textarea
        id="notesInp"
        class="iv__notes-input m-input"
        rows="2"
        placeholder="{{ 'tool.invoice.ph_notes' | t }}"
      ></textarea>
    </div>

    <div class="iv__section iv__bank">
      <div class="iv__section-title">{{ "tool.invoice.section_bank" | t }}</div>
      <label class="iv__label" for="panInp">{{ "tool.invoice.lbl_pan" | t }}</label>
      <input class="iv__input m-input" type="text" id="panInp" placeholder="{{ 'tool.invoice.ph_pan' | t }}">
      <label class="iv__label" for="bankAccNoInp">{{ "tool.invoice.lbl_bank_acc" | t }}</label>
      <input class="iv__input m-input" type="text" id="bankAccNoInp" placeholder="{{ 'tool.invoice.ph_bank_acc' | t }}">
      <label class="iv__label" for="accHolderNameInp">{{ "tool.invoice.lbl_acc_holder" | t }}</label>
      <input class="iv__input m-input" type="text" id="accHolderNameInp" placeholder="{{ 'tool.invoice.ph_acc_holder' | t }}">
      <label class="iv__label" for="ifscCodeInp">{{ "tool.invoice.lbl_ifsc" | t }}</label>
      <input class="iv__input m-input" type="text" id="ifscCodeInp" placeholder="{{ 'tool.invoice.ph_ifsc' | t }}">
      <label class="iv__label" for="bankNameInp">{{ "tool.invoice.lbl_bank_name" | t }}</label>
      <input class="iv__input m-input" type="text" id="bankNameInp" placeholder="{{ 'tool.invoice.ph_bank_name' | t }}">
      <p class="iv__declaration">{{ "tool.invoice.declaration" | t }}</p>
    </div>
  </div>
</section>
{% include "terminal-frame-close.njk" %}

{% include "tool-schema.njk" %}

<script>
(() => {
  const COPY = {
    rowRemove:        {{ ("tool.invoice.row_remove"        | t) | dump | safe }},
    phLineDesc:       {{ ("tool.invoice.ph_line_desc"      | t) | dump | safe }},
    phQty:            {{ ("tool.invoice.ph_qty"            | t) | dump | safe }},
    phPrice:          {{ ("tool.invoice.ph_price"          | t) | dump | safe }},
    alertInvalidJson: {{ ("tool.invoice.alert_invalid_json" | t) | dump | safe }},
    alertUnknownFmt:  {{ ("tool.invoice.alert_unknown_format" | t) | dump | safe }},
    alertSelectJson:  {{ ("tool.invoice.alert_select_json" | t) | dump | safe }},
    confirmClear:     {{ ("tool.invoice.confirm_clear"     | t) | dump | safe }}
  };

  const LS = 'mentria-iv-';

  /* ── DOM refs ──────────────────────────────────────── */
  const table            = document.querySelector('.iv__table');
  const currencyInput    = document.getElementById('currencyInp');
  const invoiceDateInput = document.getElementById('invoiceDate');
  const fileInput        = document.getElementById('iv-file');
  const printBtn         = document.getElementById('iv-print');
  const exportBtn        = document.getElementById('iv-export');
  const clearBtn         = document.getElementById('iv-clear');

  /* ── Persistence ───────────────────────────────────── */
  const NS = 'invoice';
  (function migrateLegacy() {
    if (!window.MentriaStore) return;
    const victims = [];
    for (let i = 0; i < localStorage.length; i++) {
      const k = localStorage.key(i);
      if (k && k.indexOf(LS) === 0) victims.push(k);
    }
    victims.forEach(k => {
      const id = k.slice(LS.length);
      if (window.MentriaStore.get(NS, id) == null) {
        window.MentriaStore.set(NS, id, localStorage.getItem(k));
      }
      localStorage.removeItem(k);
    });
  })();
  const restore = (el) => {
    const v = window.MentriaStore ? window.MentriaStore.get(NS, el.id) : localStorage.getItem(LS + el.id);
    if (v != null) el.value = v;
  };
  const persist = (el) => {
    if (window.MentriaStore) window.MentriaStore.set(NS, el.id, el.value);
    else localStorage.setItem(LS + el.id, el.value);
  };
  const dropField = (id) => {
    if (window.MentriaStore) window.MentriaStore.remove(NS, id);
    else localStorage.removeItem(LS + id);
  };
  const hasField = (id) => {
    if (window.MentriaStore) return window.MentriaStore.get(NS, id) != null;
    return localStorage.getItem(LS + id) !== null;
  };

  /* ── Validation / sanitization ─────────────────────── */
  const DECIMAL_SEP = (() => {
    try { return (new Intl.NumberFormat(document.documentElement.lang || undefined).formatToParts(1.1).find(p => p.type === 'decimal') || {}).value || '.'; }
    catch (_) { return '.'; }
  })();
  const sanitizeDecimalInput = (value) => {
    let s = String(value);
    if (DECIMAL_SEP === ',') s = s.replace(/,/g, '.');
    s = s.replace(/[^0-9.]/g, '');
    const dot = s.indexOf('.');
    if (dot !== -1) {
      s = s.slice(0, dot + 1) + s.slice(dot + 1).replace(/\./g, '');
    }
    if (s.startsWith('.')) s = '0' + s;
    return s;
  };

  /* ── Layout / dates ────────────────────────────────── */
  const autoResizeTextarea = (ta) => {
    ta.style.height = 'auto';
    ta.style.height = Math.max(ta.scrollHeight, 38.4) + 'px';
  };
  const localDateStr = () => {
    const d = new Date();
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
  };
  const setCurrentDateIfEmpty = () => {
    if (!invoiceDateInput.value) {
      invoiceDateInput.value = localDateStr();
      persist(invoiceDateInput);
    }
  };

  /* ── Math ──────────────────────────────────────────── */
  const roundToTwo = (n) => (typeof n !== 'number' || isNaN(n))
    ? 0 : Math.round((n + Number.EPSILON) * 100) / 100;
  const SYMBOL_TO_CODE = { '₹': 'INR', '€': 'EUR', '$': 'USD' };
  const fmtMoney = (n) => new Intl.NumberFormat(document.documentElement.lang || undefined, {
    style: 'currency',
    currency: SYMBOL_TO_CODE[currencyInput.value] || 'USD',
    minimumFractionDigits: 2,
    maximumFractionDigits: 2
  }).format(roundToTwo(n));

  const calculateLineTotal = (row) => {
    const qty   = parseFloat(row.querySelector('.input-qty-cell')?.value);
    const price = parseFloat(row.querySelector('.input-price-cell')?.value);
    const total = (!isNaN(qty) && !isNaN(price)) ? qty * price : 0;
    row.querySelector('.line-total').textContent = fmtMoney(total);
  };
  const calculateGrandTotal = () => {
    let grand = 0;
    document.querySelectorAll('.input-qty-cell').forEach(qtyEl => {
      const row = qtyEl.closest('tr');
      const qty = parseFloat(qtyEl.value);
      const price = parseFloat(row.querySelector('.input-price-cell')?.value);
      if (!isNaN(qty) && !isNaN(price)) grand += roundToTwo(qty * price);
    });
    document.querySelectorAll('.grand-total').forEach(el => {
      el.textContent = fmtMoney(grand);
    });
  };

  /* ── Currency ──────────────────────────────────────── */
  const changeCurrency = () => {
    const c = currencyInput.value;
    document.querySelectorAll('.currency').forEach(el => el.textContent = c);
    const decl = document.querySelector('.iv__declaration');
    if (decl) decl.style.display = (c === '₹') ? '' : 'none';
    document.querySelectorAll('.input-qty-cell').forEach(qtyEl => calculateLineTotal(qtyEl.closest('tr')));
    calculateGrandTotal();
  };

  /* ── HTML escaping for templated row ───────────────── */
  const esc = (s) => String(s ?? '')
    .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
    .replace(/</g, '&lt;').replace(/>/g, '&gt;');

  /* ── Row management ────────────────────────────────── */
  const addRow = (data) => {
    const tbody        = table.querySelector('tbody');
    const existingRows = Array.from(tbody.children).slice(0, -1); // exclude total row
    const rowIndex     = existingRows.length + 1;

    const isEmpty = !data || Object.keys(data).length === 0;
    if (isEmpty) {
      data = { Description: '', 'SAC code': '998314', Quantity: '1', 'Unit Price': '0' };
    }

    const labels = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent.trim());
    const newRow = document.createElement('tr');
    newRow.innerHTML = `
      <td data-label="${esc(labels[0] || '')}">
        <button type="button" class="remove-row no-print m-btn m-btn--ghost m-btn--icon" title="${esc(COPY.rowRemove)}" aria-label="${esc(COPY.rowRemove)}">−</button>
        <textarea id="desc${rowIndex}Inp" placeholder="${esc(COPY.phLineDesc)}" rows="1">${esc(data.Description)}</textarea>
      </td>
      <td data-label="${esc(labels[1] || '')}"><input id="sac${rowIndex}Inp" type="text" value="${esc(data['SAC code'] ?? '')}" placeholder="______"></td>
      <td data-label="${esc(labels[2] || '')}"><input id="qty${rowIndex}Inp" class="input-qty-cell" type="text" value="${esc(data.Quantity ?? '1')}" placeholder="${esc(COPY.phQty)}" pattern="^[0-9]+(\\.[0-9]+)?$" inputmode="decimal"></td>
      <td data-label="${esc(labels[3] || '')}">
        <span class="iv__cell-price">
          <input id="price${rowIndex}Inp" class="input-price-cell" type="text" value="${esc(data['Unit Price'] ?? '0')}" placeholder="${esc(COPY.phPrice)}" pattern="^[0-9]+(\\.[0-9]+)?$" inputmode="decimal"><span class="currency">₹</span>
        </span>
      </td>
      <td data-label="${esc(labels[4] || '')}"><span class="line-total">0</span></td>
    `;
    tbody.insertBefore(newRow, tbody.lastElementChild);

    // Wire persistence for this row's fields
    newRow.querySelectorAll('input[id$="Inp"], textarea[id$="Inp"]').forEach(el => {
      // If we're rebuilding from LS replay, prefer LS value over the templated one
      restore(el);
      el.addEventListener('input', () => persist(el));
      el.dataset.wired = '1';
    });
    newRow.querySelectorAll('textarea').forEach(autoResizeTextarea);

    // Persist the templated values immediately so reload reconstructs the row
    if (!isEmpty || !hasField(`desc${rowIndex}Inp`)) {
      newRow.querySelectorAll('input[id$="Inp"], textarea[id$="Inp"]').forEach(persist);
    }

    changeCurrency();
    calculateLineTotal(newRow);
    calculateGrandTotal();
  };

  const renumberRows = () => {
    const rows = Array.from(table.querySelector('tbody').children).slice(0, -1);
    rows.forEach((row, i) => {
      const idx = i + 1;
      row.querySelectorAll('input[id$="Inp"], textarea[id$="Inp"]').forEach(el => {
        const newId = el.id.replace(/\d+Inp$/, idx + 'Inp');
        if (newId !== el.id) {
          dropField(el.id);
          el.id = newId;
          persist(el);
        }
      });
    });
  };

  const removeRow = (event) => {
    if (!event.target.classList.contains('remove-row')) return;
    const row = event.target.closest('tr');
    row.querySelectorAll('input[id$="Inp"], textarea[id$="Inp"]').forEach(el => {
      dropField(el.id);
    });
    row.remove();
    renumberRows();
    calculateGrandTotal();
  };

  /* ── Import / Export ───────────────────────────────── */
  const FROM_FIELDS = ['nameInp','addr1Inp','addr2Inp','phoneInp','emailInp','extraInp'];
  const BILL_FIELDS = ['companyNameInp','companyStreetInp','companyCityInp','companyCountryInp','companyVatInp'];
  const META_FIELDS = ['invnoInp','invoiceDate','currencyInp'];
  const BANK_FIELDS = ['panInp','bankAccNoInp','accHolderNameInp','ifscCodeInp','bankNameInp'];

  const collectFields = (ids) => {
    const out = {};
    ids.forEach(id => {
      const el = document.getElementById(id);
      if (el) out[id] = el.value;
    });
    return out;
  };

  const collectLines = () => {
    const tbody = table.querySelector('tbody');
    const rows  = Array.from(tbody.children).slice(0, -1);
    return rows.map(row => ({
      Description:  row.querySelector('textarea')?.value || '',
      'SAC code':   row.querySelector('input[id^="sac"]')?.value || '',
      Quantity:     row.querySelector('.input-qty-cell')?.value || '',
      'Unit Price': row.querySelector('.input-price-cell')?.value || ''
    }));
  };

  const exportJSON = () => {
    const payload = {
      version: 1,
      from:    collectFields(FROM_FIELDS),
      billTo:  collectFields(BILL_FIELDS),
      meta:    collectFields(META_FIELDS),
      lines:   collectLines(),
      notes:   document.getElementById('notesInp')?.value || '',
      bank:    collectFields(BANK_FIELDS)
    };
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    const inv  = (document.getElementById('invnoInp')?.value || 'draft').replace(/[^A-Za-z0-9_-]/g, '');
    const date = invoiceDateInput.value || localDateStr();
    a.href = url;
    a.download = `invoice-${inv || 'draft'}-${date}.json`;
    document.body.appendChild(a); a.click(); a.remove();
    URL.revokeObjectURL(url);
  };

  const applyFields = (ids, obj) => {
    if (!obj) return;
    ids.forEach(id => {
      if (obj[id] !== undefined) {
        const el = document.getElementById(id);
        if (el) {
          el.value = obj[id];
          persist(el);
        }
      }
    });
  };

  const replaceLines = (lines) => {
    if (!Array.isArray(lines)) return;
    const tbody = table.querySelector('tbody');

    // Drop dynamic rows (skip first + last total row)
    const dynamicRows = Array.from(tbody.children).slice(1, -1);
    dynamicRows.forEach(row => {
      row.querySelectorAll('input[id$="Inp"], textarea[id$="Inp"]')
         .forEach(el => dropField(el.id));
      row.remove();
    });

    if (lines.length === 0) {
      calculateGrandTotal();
      return;
    }

    // Apply first line into existing row 1
    const firstRow = tbody.children[0];
    const setIf = (sel, val) => {
      const el = firstRow.querySelector(sel);
      if (el && val !== undefined) {
        el.value = val;
        persist(el);
      }
    };
    const f = lines[0];
    setIf('textarea[id^="desc"]', f.Description);
    setIf('input[id^="sac"]',     f['SAC code']);
    setIf('.input-qty-cell',      f.Quantity);
    setIf('.input-price-cell',    f['Unit Price']);
    autoResizeTextarea(firstRow.querySelector('textarea'));
    calculateLineTotal(firstRow);

    // Append the rest as new rows
    for (let i = 1; i < lines.length; i++) addRow(lines[i]);
    calculateGrandTotal();
  };

  const importJSON = (text) => {
    let parsed;
    try { parsed = JSON.parse(text); }
    catch { mentriaAlert(COPY.alertInvalidJson); return; }

    if (Array.isArray(parsed)) {
      // Legacy: array of line items
      replaceLines(parsed);
    } else if (parsed && typeof parsed === 'object') {
      applyFields(FROM_FIELDS, parsed.from);
      applyFields(BILL_FIELDS, parsed.billTo);
      applyFields(META_FIELDS, parsed.meta);
      applyFields(BANK_FIELDS, parsed.bank);
      if (typeof parsed.notes === 'string') {
        const notesEl = document.getElementById('notesInp');
        if (notesEl) {
          notesEl.value = parsed.notes;
          persist(notesEl);
          autoResizeTextarea(notesEl);
        }
      }
      changeCurrency();
      replaceLines(parsed.lines || []);
    } else {
      mentriaAlert(COPY.alertUnknownFmt);
    }
  };

  /* ── Event wiring ──────────────────────────────────── */
  table.addEventListener('click', removeRow);

  table.addEventListener('input', (e) => {
    const t = e.target;
    if (t.tagName === 'INPUT') {
      if (t.classList.contains('input-price-cell') || t.classList.contains('input-qty-cell')) {
        const before = t.value;
        const after  = sanitizeDecimalInput(before);
        if (before !== after) {
          const pos = (t.selectionStart || 0) - (before.length - after.length);
          t.value = after;
          if (!isNaN(pos)) t.setSelectionRange(Math.max(0, pos), Math.max(0, pos));
        }
        calculateLineTotal(t.closest('tr'));
        calculateGrandTotal();
      }
    } else if (t.tagName === 'TEXTAREA') {
      autoResizeTextarea(t);
    }
  });

  table.addEventListener('focusout', (e) => {
    const t = e.target;
    if (t.tagName !== 'INPUT') return;
    if (t.classList.contains('input-price-cell') || t.classList.contains('input-qty-cell')) {
      if (t.value === '.') t.value = '0';
      else if (/^\d+\.$/.test(t.value)) t.value = t.value.slice(0, -1);
      calculateLineTotal(t.closest('tr'));
      calculateGrandTotal();
    }
  });

  fileInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;
    if (file.type !== 'application/json' && !file.name.toLowerCase().endsWith('.json')) {
      mentriaAlert(COPY.alertSelectJson);
      fileInput.value = '';
      return;
    }
    const reader = new FileReader();
    reader.onload = (ev) => {
      importJSON(ev.target.result);
      fileInput.value = '';
    };
    reader.readAsText(file);
  });

  const buildPrintMirrors = () => {
    document.querySelectorAll('.iv__table textarea, .iv__notes-input').forEach(ta => {
      const mirror = document.createElement('div');
      mirror.className = 'iv__print-mirror';
      mirror.setAttribute('aria-hidden', 'true');
      mirror.textContent = ta.value;
      ta.insertAdjacentElement('afterend', mirror);
    });
  };
  const clearPrintMirrors = () => {
    document.querySelectorAll('.iv__print-mirror').forEach(el => el.remove());
  };
  window.addEventListener('beforeprint', buildPrintMirrors);
  window.addEventListener('afterprint', clearPrintMirrors);

  document.querySelector('.add-row').addEventListener('click', () => addRow());
  currencyInput.addEventListener('change', changeCurrency);
  printBtn.addEventListener('click', () => window.print());
  exportBtn.addEventListener('click', exportJSON);
  clearBtn.addEventListener('click', async () => {
    if (!(await mentriaConfirm(COPY.confirmClear))) return;
    if (window.MentriaStore) window.MentriaStore.clear(NS);
    Object.keys(localStorage)
      .filter(k => k.startsWith(LS))
      .forEach(k => localStorage.removeItem(k));
    location.reload();
  });

  /* ── Init ──────────────────────────────────────────── */
  // 1. Recreate dynamic rows from LS (rows beyond row 1)
  let rowIndex = 2;
  while (
    hasField(`desc${rowIndex}Inp`) ||
    hasField(`qty${rowIndex}Inp`) ||
    hasField(`price${rowIndex}Inp`)
  ) {
    addRow();
    rowIndex++;
  }

  // 2. Restore + wire all fields not already wired by addRow
  document.querySelectorAll('input[id$="Inp"], textarea[id$="Inp"], select[id$="Inp"], #invoiceDate')
    .forEach(el => {
      if (el.dataset.wired) return;
      restore(el);
      const handler = () => persist(el);
      el.addEventListener('input', handler);
      el.addEventListener('change', handler);
      el.dataset.wired = '1';
    });

  // 3. Apply currency, recompute totals, resize textareas
  changeCurrency();
  Array.from(table.querySelector('tbody').children).slice(0, -1).forEach(calculateLineTotal);
  calculateGrandTotal();
  document.querySelectorAll('textarea[id$="Inp"]').forEach(autoResizeTextarea);

  // Auto-resize for textareas outside the table (notes etc.) on input —
  // the table's delegated handler doesn't reach them.
  document.querySelectorAll('.iv__doc textarea[id$="Inp"]').forEach(ta => {
    if (!ta.closest('.iv__table')) {
      ta.addEventListener('input', () => autoResizeTextarea(ta));
    }
  });

  // 4. Auto-set today's date (only if no stored value)
  setCurrentDateIfEmpty();
})();
</script>

