{%- set groups = [
  ["Everyday", "home.launcher.everyday"], ["AI", "home.launcher.ai"],
  ["Games", "home.launcher.games"], ["Create", "home.launcher.create"],
  ["Dev", "home.launcher.dev"]
] -%}
{%- macro tile(tool, lang) -%}
  <a class="launch-tile" data-slug="{{ tool.slug }}" data-group="{{ tool.group }}"
     data-search="{{ tool.summary }} {{ tool.category }} {{ tool.group }} {{ tool.slug }}"
     style="view-transition-name: tool-{{ tool.slug }}"
     href="{{ ('/tools/' + tool.slug + '/') | localeUrl(lang) }}">
    <span class="launch-tile__icon" aria-hidden="true">
      <svg viewBox="0 0 48 48"><use href="#tool-{{ tool.slug }}"></use></svg>
    </span>
    <span class="launch-tile__label">{{ ("tools." + tool.slug + ".title") | t }}</span>
  </a>
{%- endmacro -%}
{{ toolIconsSvg | safe }}
<section class="launcher reveal" id="tools-preview" aria-label="{{ 'home.tools_heading' | t }}">
  <div class="launcher__widgets" id="launcher-widgets" hidden
       data-label-steps="{{ 'widgets.steps_label' | t }}"
       data-label-steps-goal="{{ 'widgets.steps_of_goal' | t }}"
       data-label-notes="{{ 'widgets.notes_label' | t }}"
       data-label-notes-count="{{ 'widgets.notes_count' | t }}"
       data-label-untitled="{{ 'widgets.untitled' | t }}"
       data-label-storage="{{ 'widgets.storage_label' | t }}"
       data-label-storage-used="{{ 'widgets.storage_used' | t }}"></div>
  <div class="launcher__recents" id="launcher-recents" hidden>
    <h2 class="launcher__label">{{ "home.launcher.recents" | t }}</h2>
    <div class="launcher__grid" id="launcher-recents-row"></div>
  </div>
  <div class="launcher__pages">
    {%- for g in groups %}
    <section class="launcher__cat launcher__cat--{{ g[0] | lower }}" data-group="{{ g[0] }}">
      <h2 class="launcher__label">{{ g[1] | t }}</h2>
      <div class="launcher__grid">
        {%- for tool in tools %}{% if tool.group == g[0] %}{{ tile(tool, lang) }}{% endif %}{%- endfor %}
      </div>
    </section>
    {%- endfor %}
  </div>
  <p class="launcher__nomatch" id="launcher-nomatch" hidden>{{ "home.launcher.noMatch" | t }}</p>
</section>

<script>
(function () {
  'use strict';
  function visibleTiles() {
    var nodes = document.querySelectorAll('.launcher .launch-tile');
    var out = [];
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      if (n.offsetParent !== null) out.push(n);
    }
    return out;
  }
  function rectCenter(el) {
    var r = el.getBoundingClientRect();
    return { x: r.left + r.width / 2, y: r.top + r.height / 2, el: el, rect: r };
  }
  function pickNearest(dir, fromEl) {
    var tiles = visibleTiles();
    if (!tiles.length) return null;
    var from = fromEl ? rectCenter(fromEl) : null;
    if (!from) return tiles[0];
    var candidates = [];
    for (var i = 0; i < tiles.length; i++) {
      if (tiles[i] === fromEl) continue;
      var c = rectCenter(tiles[i]);
      var dx = c.x - from.x, dy = c.y - from.y;
      var primary, lateral;
      if (dir === 'right')      { primary = dx;  lateral = dy; }
      else if (dir === 'left')  { primary = -dx; lateral = dy; }
      else if (dir === 'down')  { primary = dy;  lateral = dx; }
      else if (dir === 'up')    { primary = -dy; lateral = dx; }
      else continue;
      if (primary <= 0.5) continue;
      var score = primary * primary + lateral * lateral * 3;
      candidates.push({ score: score, el: tiles[i] });
    }
    if (!candidates.length) return null;
    candidates.sort(function (a, b) { return a.score - b.score; });
    return candidates[0].el;
  }
  function focusTile(el) {
    if (!el) return;
    el.focus({ preventScroll: false });
    var r = el.getBoundingClientRect();
    if (r.top < 80 || r.bottom > window.innerHeight - 60) {
      el.scrollIntoView({ block: 'center', behavior: 'smooth' });
    }
  }
  function currentTile() {
    var a = document.activeElement;
    if (a && a.classList && a.classList.contains('launch-tile')) return a;
    return null;
  }
  function handleDirection(dir) {
    var from = currentTile();
    if (!from) {
      var first = visibleTiles()[0];
      if (first) focusTile(first);
      return;
    }
    var next = pickNearest(dir, from);
    if (next) focusTile(next);
  }
  function handleButton(name, pressed) {
    if (!pressed) return;
    if (name === 'a') {
      var el = currentTile();
      if (el) { el.click(); }
    } else if (name === 'b') {
      if (history.length > 1) history.back();
    } else if (name === 'start') {
      var cli = document.getElementById('mentria-cli-input') || document.querySelector('.cli__input') || document.querySelector('input[type="text"]');
      if (cli && typeof cli.focus === 'function') cli.focus();
    }
  }
  window.addEventListener('mentria:gamepad:direction', function (e) { handleDirection(e.detail.direction); });
  window.addEventListener('mentria:gamepad:button', function (e) { handleButton(e.detail.name, e.detail.pressed); });
  window.addEventListener('mentria:gamepad:connect', function () {
    var el = visibleTiles()[0];
    if (el) focusTile(el);
  });
  if (window.MentriaGamepad && window.MentriaGamepad.isConnected()) {
    var el = visibleTiles()[0];
    if (el) focusTile(el);
  }
})();
</script>

<script>
(function () {
  'use strict';
  var input = document.querySelector('.cli__input');
  var launcher = document.getElementById('tools-preview');
  if (!input || !launcher) return;
  var noMatch = document.getElementById('launcher-nomatch');
  function normalize(s) {
    return (s || '').toString().toLowerCase().normalize('NFD').replace(/\p{Diacritic}/gu, '');
  }
  function haystack(tile) {
    var label = tile.querySelector('.launch-tile__label');
    return normalize((label ? label.textContent : '') + ' ' + (tile.getAttribute('data-search') || ''));
  }
  function applyFilter() {
    var qNorm = normalize(input.value.trim());
    var tokens = qNorm.split(/[^a-z0-9]+/).filter(Boolean);
    var tiles = launcher.querySelectorAll('.launch-tile');
    var anyVisible = false;
    for (var i = 0; i < tiles.length; i++) {
      var hay = haystack(tiles[i]);
      var match = !qNorm || hay.indexOf(qNorm) !== -1 ||
        (tokens.length > 0 && tokens.every(function (t) { return hay.indexOf(t) !== -1; }));
      tiles[i].hidden = !match;
      if (match && qNorm) anyVisible = true;
    }
    var sections = launcher.querySelectorAll('.launcher__cat, .launcher__recents');
    for (var j = 0; j < sections.length; j++) {
      sections[j].hidden = !sections[j].querySelector('.launch-tile:not([hidden])');
    }
    if (noMatch) noMatch.hidden = !(qNorm && !anyVisible);
  }
  input.addEventListener('input', applyFilter);
  input.addEventListener('keydown', function (e) { if (e.key === 'Enter') setTimeout(applyFilter, 0); });
})();
</script>
<script src="/assets/js/mentria-widgets.js?v={{ buildHash }}"></script>
