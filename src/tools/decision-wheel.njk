<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow">Decision Maker</p>
  <h1>Spin the Minimal Wheel</h1>
  <p>
    When a call could go either way, tap the button, watch the wheel rotate, and get a clear answer. This tool runs
    entirely offline once cached, so it keeps working even when the site is installed as a PWA.
  </p>
</section>

<section class="tool-shell decision-tool">
  <div class="decision-tool__wheel-wrapper" aria-live="polite">
    <div class="decision-tool__pointer" aria-hidden="true"></div>
    <div class="decision-tool__wheel" id="decision-wheel" role="img" aria-label="Decision wheel">
      <div class="decision-tool__center"></div>
      <span class="decision-tool__slice-label decision-tool__slice-label--0">Yes</span>
      <span class="decision-tool__slice-label decision-tool__slice-label--1">No</span>
      <span class="decision-tool__slice-label decision-tool__slice-label--2">Up to you</span>
      <span class="decision-tool__slice-label decision-tool__slice-label--3">Wait &amp;<br>try again</span>
    </div>
  </div>

  <p class="decision-tool__result" id="decision-result">Ready when you are.</p>

  <div class="decision-tool__controls">
    <button class="decision-tool__button" id="decision-spin">Spin the wheel</button>
  </div>

  <div class="decision-tool__legend">
    <p>Legend</p>
    <ul>
      <li><span class="swatch swatch--yes"></span> Yes</li>
      <li><span class="swatch swatch--no"></span> No</li>
      <li><span class="swatch swatch--upto"></span> Up to you</li>
      <li><span class="swatch swatch--wait"></span> Wait &amp; try again</li>
    </ul>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Mentria Decision Wheel",
  "operatingSystem": "Web",
  "applicationCategory": "ProductivityApplication",
  "description": "A minimal offline-ready decision wheel that helps you commit to an answer.",
  "offers": {
    "@type": "Offer",
    "price": "0"
  }
}
</script>

<script>
(() => {
  const outcomes = [
    { label: "Yes", colorClass: "yes" },
    { label: "No", colorClass: "no" },
    { label: "Up to you", colorClass: "upto" },
    { label: "Wait & try again", colorClass: "wait" }
  ];

  const wheel = document.getElementById("decision-wheel");
  const resultEl = document.getElementById("decision-result");
  const spinBtn = document.getElementById("decision-spin");
  const segmentAngle = 360 / outcomes.length;

  let currentRotation = 0;

  function updateResultFromRotation() {
    const normalized = (360 - (currentRotation % 360)) % 360;
    const index = Math.floor(normalized / segmentAngle) % outcomes.length;
    const outcome = outcomes[index];
    resultEl.textContent = outcome.label;
    resultEl.dataset.outcome = outcome.colorClass;
  }

  function spin() {
    const extraSpins = Math.floor(Math.random() * 4) + 4;
    const extraDegrees = Math.floor(Math.random() * 360);
    currentRotation += extraSpins * 360 + extraDegrees;
    wheel.style.transition = "transform 2.2s cubic-bezier(.19,1,.22,1)";
    wheel.style.transform = `rotate(${currentRotation}deg)`;

    wheel.ontransitionend = () => {
      wheel.style.transition = "none";
      updateResultFromRotation();
    };
  }

  if (spinBtn) spinBtn.addEventListener("click", spin);
})();
</script>

