<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow">Timer</p>
  <h1>Countdown Timer</h1>
  <p>
    Set hours, minutes, and seconds for your countdown. When time's up, an alarm will ring.
    This tool works entirely offline once cached.
  </p>
</section>

<section class="tool-shell countdown-tool">
  <div class="countdown-tool__display-wrapper">
    <div class="countdown-tool__title" id="timer-title">Ready</div>
    <div class="countdown-tool__display" id="timer-display">
      <span class="countdown-tool__segment" id="display-hours">00</span>
      <span class="countdown-tool__colon">:</span>
      <span class="countdown-tool__segment" id="display-mins">00</span>
      <span class="countdown-tool__colon">:</span>
      <span class="countdown-tool__segment" id="display-secs">00</span>
    </div>
  </div>

  <div class="countdown-tool__inputs" id="input-section">
    <div class="countdown-tool__input-group">
      <label for="input-hours">Hours</label>
      <input type="number" id="input-hours" min="0" max="99" value="0" />
    </div>
    <div class="countdown-tool__input-group">
      <label for="input-mins">Minutes</label>
      <input type="number" id="input-mins" min="0" max="59" value="0" />
    </div>
    <div class="countdown-tool__input-group">
      <label for="input-secs">Seconds</label>
      <input type="number" id="input-secs" min="0" max="59" value="0" />
    </div>
  </div>

  <div class="countdown-tool__controls">
    <button class="countdown-tool__button countdown-tool__button--primary" id="btn-start">Start</button>
    <button class="countdown-tool__button countdown-tool__button--secondary" id="btn-pause" disabled>Pause</button>
    <button class="countdown-tool__button countdown-tool__button--ghost" id="btn-reset" disabled>Reset</button>
  </div>

  <div class="countdown-tool__presets">
    <p>Quick presets:</p>
    <div class="countdown-tool__preset-buttons">
      <button class="countdown-tool__preset" data-seconds="60">1 min</button>
      <button class="countdown-tool__preset" data-seconds="300">5 min</button>
      <button class="countdown-tool__preset" data-seconds="600">10 min</button>
      <button class="countdown-tool__preset" data-seconds="1500">25 min</button>
      <button class="countdown-tool__preset" data-seconds="3600">1 hour</button>
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Mentria Countdown Timer",
  "operatingSystem": "Web",
  "applicationCategory": "ProductivityApplication",
  "description": "A customizable countdown timer with alarm sound that works offline.",
  "offers": {
    "@type": "Offer",
    "price": "0"
  }
}
</script>

<script>
(() => {
  // Elements
  const displayHours = document.getElementById('display-hours');
  const displayMins = document.getElementById('display-mins');
  const displaySecs = document.getElementById('display-secs');
  const timerTitle = document.getElementById('timer-title');
  const timerDisplay = document.querySelector('.countdown-tool__display');
  const inputSection = document.getElementById('input-section');
  const inputHours = document.getElementById('input-hours');
  const inputMins = document.getElementById('input-mins');
  const inputSecs = document.getElementById('input-secs');
  const btnStart = document.getElementById('btn-start');
  const btnPause = document.getElementById('btn-pause');
  const btnReset = document.getElementById('btn-reset');
  const presetButtons = document.querySelectorAll('.countdown-tool__preset');

  let countdown = null;
  let totalSeconds = 0;
  let isPaused = false;
  let originalTitle = document.title;

  // Audio context for alarm
  let audioContext = null;
  let alarmInterval = null;
  let isAlarming = false;

  function initAudio() {
    if (!audioContext) {
      audioContext = new (window.AudioContext || window.webkitAudioContext)();
    }
    return audioContext;
  }

  function playBellOnce() {
    const ctx = initAudio();
    const duration = 0.15;
    const gap = 0.08;
    const bellCount = 4;
    
    for (let i = 0; i < bellCount; i++) {
      const startTime = ctx.currentTime + i * (duration + gap);
      
      // Create oscillator for bell sound
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      
      osc.type = 'sine';
      osc.frequency.setValueAtTime(880, startTime); // A5
      osc.frequency.exponentialRampToValueAtTime(440, startTime + duration);
      
      gain.gain.setValueAtTime(0.4, startTime);
      gain.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
      
      osc.connect(gain);
      gain.connect(ctx.destination);
      
      osc.start(startTime);
      osc.stop(startTime + duration);

      // Add harmonic for richer bell sound
      const osc2 = ctx.createOscillator();
      const gain2 = ctx.createGain();
      
      osc2.type = 'sine';
      osc2.frequency.setValueAtTime(1760, startTime);
      osc2.frequency.exponentialRampToValueAtTime(880, startTime + duration);
      
      gain2.gain.setValueAtTime(0.2, startTime);
      gain2.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
      
      osc2.connect(gain2);
      gain2.connect(ctx.destination);
      
      osc2.start(startTime);
      osc2.stop(startTime + duration);
    }
  }

  function startAlarm() {
    if (isAlarming) return;
    isAlarming = true;
    playBellOnce();
    // Repeat the bell sound every 1.2 seconds
    alarmInterval = setInterval(() => {
      if (isAlarming) {
        playBellOnce();
      }
    }, 1200);
  }

  function stopAlarm() {
    isAlarming = false;
    if (alarmInterval) {
      clearInterval(alarmInterval);
      alarmInterval = null;
    }
  }

  function formatNumber(num) {
    return String(num).padStart(2, '0');
  }

  function updateDisplay() {
    const hours = Math.floor(totalSeconds / 3600);
    const mins = Math.floor((totalSeconds % 3600) / 60);
    const secs = totalSeconds % 60;

    displayHours.textContent = formatNumber(hours);
    displayMins.textContent = formatNumber(mins);
    displaySecs.textContent = formatNumber(secs);

    // Update page title with remaining time
    if (totalSeconds > 0) {
      document.title = `${formatNumber(hours)}:${formatNumber(mins)}:${formatNumber(secs)} - Timer`;
    } else {
      document.title = originalTitle;
    }
  }

  function tick() {
    if (totalSeconds > 0) {
      totalSeconds--;
      updateDisplay();
    } else {
      clearInterval(countdown);
      countdown = null;
      timerTitle.textContent = "Time's Up!";
      timerDisplay.classList.add('countdown-tool__display--finished');
      startAlarm();
      btnPause.disabled = true;
      btnStart.textContent = 'Start';
      btnStart.disabled = true;
      btnReset.disabled = false;
      document.title = "⏰ Time's Up!";
    }
  }

  function startTimer() {
    // Initialize audio on user gesture
    initAudio();
    
    if (countdown) {
      // Timer is running, pause it
      clearInterval(countdown);
      countdown = null;
      isPaused = true;
      btnStart.textContent = 'Resume';
      btnPause.disabled = true;
      timerTitle.textContent = 'Paused';
      return;
    }

    if (isPaused && totalSeconds > 0) {
      // Resume from pause
      isPaused = false;
      countdown = setInterval(tick, 1000);
      btnStart.textContent = 'Pause';
      btnPause.disabled = false;
      timerTitle.textContent = 'Running';
      return;
    }

    // Start new timer
    const h = parseInt(inputHours.value) || 0;
    const m = parseInt(inputMins.value) || 0;
    const s = parseInt(inputSecs.value) || 0;
    totalSeconds = h * 3600 + m * 60 + s;

    if (totalSeconds <= 0) {
      timerTitle.textContent = 'Set a time first!';
      setTimeout(() => timerTitle.textContent = 'Ready', 2000);
      return;
    }

    timerDisplay.classList.remove('countdown-tool__display--finished');
    timerTitle.textContent = 'Running';
    updateDisplay();
    
    countdown = setInterval(tick, 1000);
    btnStart.textContent = 'Pause';
    btnPause.disabled = false;
    btnReset.disabled = false;
    inputSection.classList.add('countdown-tool__inputs--hidden');
  }

  function resetTimer() {
    // Stop the alarm if it's playing
    stopAlarm();
    if (countdown) {
      clearInterval(countdown);
      countdown = null;
    }
    isPaused = false;
    totalSeconds = 0;
    updateDisplay();
    timerTitle.textContent = 'Ready';
    timerDisplay.classList.remove('countdown-tool__display--finished');
    btnStart.textContent = 'Start';
    btnStart.disabled = false;
    btnPause.disabled = true;
    btnReset.disabled = true;
    inputSection.classList.remove('countdown-tool__inputs--hidden');
    document.title = originalTitle;
  }

  function setPreset(seconds) {
    resetTimer();
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = seconds % 60;
    inputHours.value = h;
    inputMins.value = m;
    inputSecs.value = s;
    totalSeconds = seconds;
    updateDisplay();
  }

  // Event listeners
  btnStart.addEventListener('click', startTimer);
  btnPause.addEventListener('click', () => {
    if (countdown) {
      clearInterval(countdown);
      countdown = null;
      isPaused = true;
      btnStart.textContent = 'Resume';
      timerTitle.textContent = 'Paused';
    }
  });
  btnReset.addEventListener('click', resetTimer);

  presetButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const seconds = parseInt(btn.dataset.seconds);
      setPreset(seconds);
    });
  });

  // Update display when inputs change
  [inputHours, inputMins, inputSecs].forEach(input => {
    input.addEventListener('input', () => {
      if (!countdown && !isPaused) {
        const h = parseInt(inputHours.value) || 0;
        const m = parseInt(inputMins.value) || 0;
        const s = parseInt(inputSecs.value) || 0;
        totalSeconds = h * 3600 + m * 60 + s;
        updateDisplay();
      }
    });
  });
})();
</script>

<style>
