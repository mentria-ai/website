<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow">~/tools/color-picker</p>
  <h1>Color Picker</h1>
  <p>
    Pick any color, view its HEX / RGB / HSL values, and generate harmonious palettes. Works offline.
  </p>
</section>

{% set terminalTitle = "color-picker.js" %}
{% include "terminal-frame-open.njk" %}
