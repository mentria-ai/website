---
layout: feed-layout.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/feed/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'feed_page.title' | t }}"
  description: "{{ 'feed_page.lede' | t }}"
---
{% set entries = (feed | default([])) | interleaveFeed %}
{% if entries.length %}
<div class="feed-scroll" id="feed-scroll">
    {% for item in entries %}
    <section class="feed-card{% if item.link %} feed-card--linked{% endif %}"{% if not item.link %} tabindex="0"{% endif %} data-index="{{ loop.index0 }}"{% if item.src %} style="--feed-card-bg: url('{{ item.src }}')"{% endif %}>
        {% if item.link %}<a class="feed-card__link" href="{{ item.link }}" aria-label="{{ (item.caption | tloc(locale.code)) if item.caption else item.title }}"></a>{% endif %}
        {% if item.type == "video" and item.src %}
        <video class="feed-card__media" src="{{ item.src }}" {% if item.poster %}poster="{{ item.poster }}"{% endif %} muted loop playsinline preload="metadata"></video>
        {% elif (item.type == "image" or item.type == "chapter") and item.src %}
        <img class="feed-card__media" src="{{ item.src }}" alt="{{ (item.caption | tloc(locale.code)) if item.caption else item.title }}" loading="lazy">
        {% elif item.color %}
        <div class="feed-card__color-bg" style="background: {{ item.color }};"></div>
        {% endif %}

        {% if item.badge %}
        <div class="feed-card__chapter-badge">{{ item.badge }}</div>
        {% elif item.type == "chapter" %}
        <div class="feed-card__chapter-badge">{{ "feed_page.chapter_badge" | t }}</div>
        {% endif %}

        <div class="feed-card__gradient"></div>

        {% if item.tags %}
        <div class="feed-card__tags">
            {% for tag in item.tags %}
            <span class="feed-card__tag">{{ tag }}</span>
            {% endfor %}
        </div>
        {% endif %}

        <div class="feed-card__info">
            {% if item.caption %}
            <p class="feed-card__caption">{{ item.caption | tloc(locale.code) }}</p>
            {% endif %}
            <h2 class="feed-card__title">{{ item.title }}</h2>
            {% if item.date %}
            <time class="feed-card__date" datetime="{{ item.date }}">{{ item.date | date }}</time>
            {% endif %}
        </div>

        {% if item.type == "video" and item.src %}
        <button class="feed-card__mute-btn" aria-label="Toggle mute">🔇</button>
        <div class="feed-card__progress" role="progressbar" aria-valuenow="0" aria-valuemax="100" style="width: 0%;"></div>
        {% endif %}

        {% if loop.first %}
        <div class="feed-card__scroll-hint" aria-hidden="true">↓</div>
        {% endif %}
    </section>
    {% endfor %}
</div>
{% else %}
<div class="feed-empty">
    <p class="feed-empty__command">{{ "feed_page.empty_cmd" | t }}</p>
    <p class="feed-empty__message">{{ "feed_page.empty_msg" | t }}<span class="cursor-blink"></span></p>
</div>
{% endif %}

<script>
(function () {
  'use strict';

  var feedScroll = document.getElementById('feed-scroll');
  if (!feedScroll) return;

  var cards = feedScroll.querySelectorAll('.feed-card');
  if (!cards.length) return;

  var currentObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      entry.target.classList.toggle('is-current', entry.isIntersecting && entry.intersectionRatio > 0.55);
    });
  }, { threshold: [0.55] });
  for (var ci = 0; ci < cards.length; ci++) currentObserver.observe(cards[ci]);

  // Video autoplay/pause with Intersection Observer
  var videos = feedScroll.querySelectorAll('video');
  if (videos.length) {
    var observer = new IntersectionObserver(function (entries) {
      for (var i = 0; i < entries.length; i++) {
        var video = entries[i].target;
        if (entries[i].isIntersecting) {
          video.play().catch(function () {});
        } else {
          video.pause();
        }
      }
    }, { threshold: 0.5 });

    for (var i = 0; i < videos.length; i++) {
      observer.observe(videos[i]);
    }
  }

  // Mute toggle
  feedScroll.addEventListener('click', function (e) {
    var muteBtn = e.target.closest('.feed-card__mute-btn');
    if (muteBtn) {
      var card = muteBtn.closest('.feed-card');
      var video = card ? card.querySelector('video') : null;
      if (video) {
        video.muted = !video.muted;
        muteBtn.textContent = video.muted ? '🔇' : '🔊';
        muteBtn.setAttribute('aria-label', video.muted ? 'Unmute' : 'Mute');
      }
      return;
    }

    // Tap card to play/pause video
    var card = e.target.closest('.feed-card');
    if (card) {
      var video = card.querySelector('video');
      if (video) {
        if (video.paused) {
          video.play().catch(function () {});
        } else {
          video.pause();
        }
      }
    }
  });

  // Keyboard play/pause
  feedScroll.addEventListener('keydown', function (e) {
    if (e.key !== ' ' && e.key !== 'Enter') return;
    if (e.target.closest('.feed-card__link')) return;
    var card = e.target.closest('.feed-card');
    if (!card) return;
    var video = card.querySelector('video');
    if (video) {
      e.preventDefault();
      if (video.paused) {
        video.play().catch(function () {});
      } else {
        video.pause();
      }
    }
  });

  // Video progress bar
  for (var i = 0; i < videos.length; i++) {
    (function (video) {
      var card = video.closest('.feed-card');
      var progressBar = card ? card.querySelector('.feed-card__progress') : null;
      if (!progressBar) return;

      video.addEventListener('timeupdate', function () {
        if (video.duration) {
          var pct = (video.currentTime / video.duration) * 100;
          progressBar.style.width = pct + '%';
          progressBar.setAttribute('aria-valuenow', Math.round(pct));
        }
      });
    })(videos[i]);
  }

  // Hide scroll hint after first scroll
  var scrollHint = feedScroll.querySelector('.feed-card__scroll-hint');
  if (scrollHint) {
    feedScroll.addEventListener('scroll', function () {
      if (feedScroll.scrollTop > 50) {
        scrollHint.style.opacity = '0';
        scrollHint.style.transition = 'opacity 0.3s';
      }
    }, { once: true });
  }
})();
</script>
