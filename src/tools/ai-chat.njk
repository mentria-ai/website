{% include "terminal-frame-close.njk" %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Mentria AI Chat",
  "operatingSystem": "Web",
  "applicationCategory": "UtilitiesApplication",
  "description": "Chat with a local AI model (Qwen3.5-0.8B) running entirely in your browser via WebGPU. Supports image input.",
  "offers": { "@type": "Offer", "price": "0" }
}
</script>

<script type="module">
const LIB_URLS = [
  'https://cdn.jsdelivr.net/npm/@huggingface/transformers@4',
  'https://cdn.jsdelivr.net/npm/@huggingface/transformers@latest'
];

const statusDot     = document.getElementById('ac-status-dot');
const statusText    = document.getElementById('ac-status-text');

function setStatus(state, text) {
  statusDot.className = 'ac__status-dot ac__status-dot--' + state;
  statusText.textContent = text;
}

// Dynamic import with fallback
let lib = null;
for (const url of LIB_URLS) {
  try {
    lib = await import(url);
    break;
  } catch (e) {
    console.warn('Failed to load', url, e);
  }
}

if (!lib) {
  setStatus('error', 'Failed to load Transformers.js library. Check network/ad-blocker.');
} else {
  runApp(lib);
}

function runApp({ AutoProcessor, AutoModelForImageTextToText, RawImage, TextStreamer }) {
  /* ── Config ──────────────────────────────────────── */
  const MODEL_ID = 'onnx-community/Qwen3.5-0.8B-ONNX';
  const MAX_TOKENS = 512;

  function getBestDevice() {
    if (!navigator.gpu) return 'wasm';
    const ua = navigator.userAgent;
    if (ua.includes('Safari') && !ua.includes('Chrome') && !ua.includes('Android')) return 'wasm';
    return 'webgpu';
  }

  const DEVICE = getBestDevice();
  const DTYPE = DEVICE === 'webgpu'
    ? { embed_tokens: 'q4', vision_encoder: 'fp16', decoder_model_merged: 'q4' }
    : { embed_tokens: 'q4', vision_encoder: 'q4', decoder_model_merged: 'q4' };

  /* ── DOM refs ────────────────────────────────────── */
  const deleteBtn     = document.getElementById('ac-delete-model');
  const progressWrap  = document.getElementById('ac-progress-wrap');
  const progressLabel = document.getElementById('ac-progress-label');
  const progressPct   = document.getElementById('ac-progress-pct');
  const progressFill  = document.getElementById('ac-progress-fill');
  const progressDetail= document.getElementById('ac-progress-detail');
  const messagesEl    = document.getElementById('ac-messages');
  const emptyEl       = document.getElementById('ac-empty');
  const imgPreview    = document.getElementById('ac-img-preview');
  const imgThumb      = document.getElementById('ac-img-thumb');
  const imgRemoveBtn  = document.getElementById('ac-img-remove');
  const fileInput     = document.getElementById('ac-file-input');
  const inputEl       = document.getElementById('ac-input');
  const sendBtn       = document.getElementById('ac-send');

  /* ── State ───────────────────────────────────────── */
  let processor = null;
  let model = null;
  let generating = false;
  let attachedImage = null;
  let attachedDataUrl = null;
  let messages = [];

  function scrollToBottom() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function autoResize() {
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 120) + 'px';
  }

  function formatBytes(b) {
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(1) + ' MB';
  }

  function addMessage(role, content, imageUrl) {
    if (emptyEl) emptyEl.style.display = 'none';
    const bubble = document.createElement('div');
    bubble.className = 'ac__msg ac__msg--' + role;

    const label = document.createElement('div');
    label.className = 'ac__msg-label';
    label.textContent = role === 'user' ? 'you' : 'qwen-0.8B';
    bubble.appendChild(label);

    if (imageUrl) {
      const img = document.createElement('img');
      img.className = 'ac__msg-img';
      img.src = imageUrl;
      img.alt = 'Attached';
      bubble.appendChild(img);
    }

    const body = document.createElement('div');
    body.className = 'ac__msg-body';
    if (content) body.textContent = content;
    bubble.appendChild(body);

    messagesEl.appendChild(bubble);
    scrollToBottom();
    return body;
  }

  /* ── Progress tracking ───────────────────────────── */
  const fileProgress = {};
  function onProgress(event) {
    if (event.status === 'progress' && event.total) {
      fileProgress[event.file] = { loaded: event.loaded, total: event.total };
      const totals = Object.values(fileProgress);
      const loaded = totals.reduce((s, f) => s + f.loaded, 0);
      const total = totals.reduce((s, f) => s + f.total, 0);
      const pct = Math.round((loaded / total) * 100);
      progressFill.style.width = pct + '%';
      progressPct.textContent = pct + '%';
      progressDetail.textContent = formatBytes(loaded) + ' / ' + formatBytes(total);
    } else if (event.status === 'ready') {
      progressLabel.textContent = 'Loading model…';
    }
  }

  /* ── Load model ──────────────────────────────────── */
  async function loadModel() {
    setStatus('loading', 'Loading model…');
    progressWrap.style.display = '';

    try {
      processor = await AutoProcessor.from_pretrained(MODEL_ID, {
        progress_callback: onProgress
      });

      model = await AutoModelForImageTextToText.from_pretrained(MODEL_ID, {
        dtype: DTYPE,
        device: DEVICE,
        progress_callback: onProgress
      });

      progressWrap.style.display = 'none';
      setStatus('ready', DEVICE === 'webgpu' ? 'Ready' : 'Ready (WASM — slower)');
      deleteBtn.style.display = '';
      inputEl.disabled = false;
      sendBtn.disabled = false;
      inputEl.focus();
    } catch (err) {
      progressWrap.style.display = 'none';
      console.error('Model load error:', err);
      setStatus('error', 'Failed to load: ' + (err.message || err));
    }
  }

  /* ── Generate ────────────────────────────────────── */
  async function generate() {
    if (generating || !model) return;
    const text = inputEl.value.trim();
    if (!text && !attachedImage) return;

    generating = true;
    inputEl.value = '';
    autoResize();
    sendBtn.disabled = true;
    setStatus('generating', 'Generating…');

    // Build user content
    const userContent = [];
    if (attachedImage) {
      userContent.push({ type: 'image' });
    }
    userContent.push({ type: 'text', text: text || 'Describe this image.' });

    // Show user message
    addMessage('user', text, attachedDataUrl);

    // Build messages array
    messages.push({ role: 'user', content: userContent });

    const bodyEl = addMessage('assistant', '');

    try {
      const textContent = processor.apply_chat_template(messages, {
        tokenize: false,
        add_generation_prompt: true
      });

      const inputs = await processor(
        attachedImage ? [textContent, attachedImage] : textContent
      );

      // Clear attached image after use
      attachedImage = null;
      attachedDataUrl = null;
      imgPreview.style.display = 'none';
      fileInput.value = '';

      let fullText = '';
      let firstToken = true;
      let pendingPaint = false;

      function paintToken() {
        const display = fullText.replace(/<think>[\s\S]*?<\/think>/g, '').trim();
        bodyEl.textContent = display || '…';
        scrollToBottom();
        pendingPaint = false;
      }

      const streamer = new TextStreamer(processor.tokenizer, {
        skip_prompt: true,
        skip_special_tokens: true,
        callback_function(token) {
          if (firstToken) {
            token = token.trimStart();
            firstToken = false;
          }
          fullText += token;
          if (!pendingPaint) {
            pendingPaint = true;
            requestAnimationFrame(paintToken);
          }
        }
      });

      await model.generate({
        ...inputs,
        max_new_tokens: MAX_TOKENS,
        do_sample: false,
        streamer
      });

      const display = fullText.replace(/<think>[\s\S]*?<\/think>/g, '').trim();
      bodyEl.textContent = display || '(empty response)';
      messages.push({ role: 'assistant', content: display });

    } catch (err) {
      bodyEl.textContent = 'Error: ' + err.message;
      console.error('Generation error:', err);
    }

    generating = false;
    sendBtn.disabled = false;
    setStatus('ready', 'Ready');
    inputEl.focus();
  }

  /* ── Delete cached model ─────────────────────────── */
  async function deleteModel() {
    if (!confirm('Delete the cached model (~850 MB)? You will need to re-download it next time.')) return;
    try {
      const keys = await caches.keys();
      for (const key of keys) {
        if (key.includes('transformers')) {
          await caches.delete(key);
        }
      }
      const dbs = await indexedDB.databases();
      for (const db of dbs) {
        if (db.name && (db.name.includes('transformers') || db.name.includes('onnxruntime'))) {
          indexedDB.deleteDatabase(db.name);
        }
      }
      model = null;
      processor = null;
      messages = [];
      messagesEl.innerHTML = '';
      if (emptyEl) {
        messagesEl.appendChild(emptyEl);
        emptyEl.style.display = '';
      }
      deleteBtn.style.display = 'none';
      inputEl.disabled = true;
      sendBtn.disabled = true;
      setStatus('idle', 'Model deleted. Reload to re-download.');
    } catch (err) {
      console.error('Delete error:', err);
      alert('Failed to delete cache: ' + err.message);
    }
  }

  /* ── Image handling ──────────────────────────────── */
  async function attachFile(file) {
    if (!file || !file.type.startsWith('image/')) return;
    const url = URL.createObjectURL(file);
    imgThumb.src = url;
    imgPreview.style.display = '';
    attachedDataUrl = url;
    attachedImage = await RawImage.fromURL(url);
  }

  function removeImage() {
    attachedImage = null;
    attachedDataUrl = null;
    imgPreview.style.display = 'none';
    imgThumb.src = '';
    fileInput.value = '';
  }

  /* ── Events ──────────────────────────────────────── */
  sendBtn.addEventListener('click', generate);

  inputEl.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      generate();
    }
  });

  inputEl.addEventListener('input', autoResize);

  fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) attachFile(fileInput.files[0]);
  });

  imgRemoveBtn.addEventListener('click', removeImage);

  deleteBtn.addEventListener('click', deleteModel);

  // Paste image from clipboard
  document.addEventListener('paste', e => {
    const items = e.clipboardData?.items;
    if (!items) return;
    for (const item of items) {
      if (item.type.startsWith('image/')) {
        e.preventDefault();
        attachFile(item.getAsFile());
        break;
      }
    }
  });

  /* ── Init ────────────────────────────────────────── */
  async function init() {
    setStatus('idle', DEVICE === 'webgpu' ? 'WebGPU available. Loading model…' : 'Using WASM backend. Loading model…');
    await loadModel();
  }

  init();
}
</script>

<style>
/* ── AI Chat — Terminal HUD ─────────────────────── */
.ac {
  display: flex;
  flex-direction: column;
  font-family: var(--font-mono);
  height: min(600px, 70vh);
}

/* ── Status bar ─────────────────────────────────── */
.ac__status {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.75rem;
  border-bottom: 1px solid var(--term-border);
  font-size: 0.75rem;
  color: var(--term-muted);
  flex-shrink: 0;
}

.ac__status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--term-muted);
  flex-shrink: 0;
}
.ac__status-dot--idle     { background: var(--term-muted); }
.ac__status-dot--loading  { background: var(--syn-amber); box-shadow: 0 0 6px var(--syn-amber); animation: ac-pulse 1.5s ease-in-out infinite; }
.ac__status-dot--ready    { background: var(--syn-green); box-shadow: 0 0 6px var(--syn-green); }
.ac__status-dot--generating { background: var(--syn-cyan); box-shadow: 0 0 6px var(--syn-cyan); animation: ac-pulse 1s ease-in-out infinite; }
.ac__status-dot--error    { background: var(--syn-pink); box-shadow: 0 0 6px var(--syn-pink); }

@keyframes ac-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.ac__delete-btn {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  background: none;
  border: 1px solid rgba(244, 114, 182, 0.2);
  color: var(--syn-pink);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.2s ease;
}
.ac__delete-btn:hover {
  background: rgba(244, 114, 182, 0.1);
  border-color: rgba(244, 114, 182, 0.4);
}

/* ── Progress bar ───────────────────────────────── */
.ac__progress-wrap {
  padding: 0.75rem;
  border-bottom: 1px solid var(--term-border);
  flex-shrink: 0;
}
.ac__progress-info {
  display: flex;
  justify-content: space-between;
  font-size: 0.7rem;
  color: var(--term-muted);
  margin-bottom: 0.4rem;
}
.ac__progress-bar {
  height: 4px;
  background: rgba(255,255,255,0.06);
  border-radius: 2px;
  overflow: hidden;
}
.ac__progress-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--syn-cyan), var(--syn-purple));
  border-radius: 2px;
  transition: width 0.3s ease;
}
.ac__progress-detail {
  font-size: 0.65rem;
  color: var(--term-muted);
  margin-top: 0.3rem;
  text-align: right;
}

/* ── Messages ───────────────────────────────────── */
.ac__messages {
  flex: 1;
  overflow-y: auto;
  padding: 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.08) transparent;
}

.ac__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  color: var(--term-muted);
  text-align: center;
  gap: 0.25rem;
  font-size: 0.8rem;
}
.ac__empty-icon {
  font-size: 1.8rem;
  color: var(--syn-cyan);
  opacity: 0.4;
  margin-bottom: 0.5rem;
}
.ac__empty-sub {
  font-size: 0.65rem;
  opacity: 0.6;
}

/* ── Message bubble ─────────────────────────────── */
.ac__msg {
  max-width: 85%;
  padding: 0.6rem 0.75rem;
  border-radius: 8px;
  font-size: 0.8rem;
  line-height: 1.55;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.ac__msg--user {
  align-self: flex-end;
  background: rgba(34, 211, 238, 0.08);
  border: 1px solid rgba(34, 211, 238, 0.15);
}

.ac__msg--assistant {
  align-self: flex-start;
  background: rgba(167, 139, 250, 0.06);
  border: 1px solid rgba(167, 139, 250, 0.12);
}

.ac__msg-label {
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.3rem;
  opacity: 0.5;
}

.ac__msg-img {
  max-width: 200px;
  max-height: 150px;
  border-radius: 6px;
  margin-bottom: 0.4rem;
  display: block;
  border: 1px solid var(--term-border);
}

.ac__msg-body {
  white-space: pre-wrap;
  color: var(--term-fg);
}

/* ── Image preview ──────────────────────────────── */
.ac__img-preview {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 0.75rem;
  border-top: 1px solid var(--term-border);
  flex-shrink: 0;
}
.ac__img-preview img {
  width: 48px;
  height: 48px;
  object-fit: cover;
  border-radius: 6px;
  border: 1px solid var(--term-border);
}
.ac__img-remove {
  background: none;
  border: none;
  color: var(--term-muted);
  font-size: 1.2rem;
  cursor: pointer;
  padding: 0 0.3rem;
  line-height: 1;
}
.ac__img-remove:hover {
  color: var(--syn-pink);
}

/* ── Input area ─────────────────────────────────── */
.ac__input-wrap {
  display: flex;
  align-items: flex-end;
  gap: 0.4rem;
  padding: 0.6rem 0.75rem;
  border-top: 1px solid var(--term-border);
  flex-shrink: 0;
}

.ac__attach-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 6px;
  cursor: pointer;
  color: var(--term-muted);
  transition: all 0.2s ease;
  flex-shrink: 0;
}
.ac__attach-btn:hover {
  color: var(--syn-cyan);
  background: rgba(34, 211, 238, 0.08);
}

.ac__input {
  flex: 1;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--term-border);
  border-radius: 8px;
  padding: 0.5rem 0.7rem;
  color: var(--term-fg);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  line-height: 1.4;
  resize: none;
  overflow-y: auto;
  max-height: 120px;
  transition: border-color 0.2s ease;
}
.ac__input:focus {
  outline: none;
  border-color: rgba(34, 211, 238, 0.3);
}
.ac__input::placeholder {
  color: var(--term-muted);
  opacity: 0.6;
}
.ac__input:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.ac__send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: none;
  border-radius: 6px;
  background: var(--syn-cyan);
  color: #000;
  cursor: pointer;
  transition: all 0.2s ease;
  flex-shrink: 0;
}
.ac__send-btn:hover:not(:disabled) {
  background: #67e8f9;
  box-shadow: 0 0 12px rgba(34, 211, 238, 0.3);
}
.ac__send-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

/* ── Responsive ─────────────────────────────────── */
@media (max-width: 480px) {
  .ac {
    height: min(500px, 65vh);
  }
  .ac__msg {
    max-width: 92%;
    font-size: 0.75rem;
  }
  .ac__delete-btn span {
    display: none;
  }
}
</style>
