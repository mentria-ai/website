---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/markdown-pdf/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.markdown-pdf.title' | t }}"
  description: "{{ 'tools.markdown-pdf.lede' | t }}"
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><a class="eyebrow__link" href="{{ locale.pathPrefix }}/tools/">tools</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">markdown-pdf</span></p>
  <h1>{{ "tools.markdown-pdf.title" | t }}</h1>
  <p>{{ "tools.markdown-pdf.lede" | t }}</p>
  {% include "tldr.njk" %}
</section>

{% set terminalTitle = "markdown-pdf.js" %}
{% include "terminal-frame-open.njk" %}
<section class="mp">
  <div class="mp__actions no-print">
    <button class="mp__btn mp__btn--primary" id="mp-download" title="{{ 'tool.markdown-pdf.title_download' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      {{ "tool.markdown-pdf.btn_download" | t }}
    </button>
    <button class="mp__btn" id="mp-export" title="{{ 'tool.markdown-pdf.title_export' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      {{ "tool.markdown-pdf.btn_export" | t }}
    </button>
    <button class="mp__btn" id="mp-share" title="{{ 'common.share' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      {{ "common.share" | t }}
    </button>
    <label class="mp__btn mp__btn--label" for="mp-file" title="{{ 'tool.markdown-pdf.title_import' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      {{ "tool.markdown-pdf.btn_import" | t }}
      <input type="file" id="mp-file" accept=".md,.markdown,text/markdown,text/plain" hidden>
    </label>
    <button class="mp__btn mp__btn--danger" id="mp-clear" title="{{ 'tool.markdown-pdf.title_clear' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
      {{ "tool.markdown-pdf.btn_clear" | t }}
    </button>

    <div class="mp__tabs" role="tablist" aria-label="{{ 'tool.markdown-pdf.tab_aria' | t }}">
      <button class="mp__tab is-active" id="mp-tab-edit" role="tab" aria-selected="true" aria-controls="mp-input">{{ "tool.markdown-pdf.tab_edit" | t }}</button>
      <button class="mp__tab" id="mp-tab-preview" role="tab" aria-selected="false" aria-controls="mp-preview">{{ "tool.markdown-pdf.tab_preview" | t }}</button>
    </div>
  </div>

  <div class="mp__filename no-print">
    <label class="mp__filename-label" for="mp-filename">{{ "tool.markdown-pdf.filename_label" | t }}</label>
    <input class="mp__filename-input" id="mp-filename" type="text" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="{{ 'tool.markdown-pdf.filename_placeholder' | t }}">
    <button class="mp__filename-btn" id="mp-ai-name" type="button" title="{{ 'tool.markdown-pdf.btn_ai_generate' | t }}">
      <svg class="mp__filename-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v3m0 12v3M5.6 5.6l2.1 2.1m8.6 8.6 2.1 2.1M3 12h3m12 0h3M5.6 18.4l2.1-2.1m8.6-8.6 2.1-2.1"/></svg>
      <span class="mp__filename-btn-label">{{ "tool.markdown-pdf.btn_ai_generate" | t }}</span>
    </button>
  </div>

  <div class="mp__panes">
    <section class="mp__pane mp__pane--editor" data-tab="edit">
      <header class="mp__pane-header no-print">
        <span class="mp__pane-label">{{ "tool.markdown-pdf.pane_markdown" | t }}</span>
      </header>
      <textarea
        class="mp__input"
        id="mp-input"
        spellcheck="false"
        autocomplete="off"
        autocapitalize="off"
        placeholder="{{ 'tool.markdown-pdf.ph_input' | t }}"
      ></textarea>
      <footer class="mp__pane-status no-print">
        <span id="mp-counts"></span>
        <span id="mp-saved" class="mp__saved" aria-live="polite"></span>
      </footer>
    </section>

    <section class="mp__pane mp__pane--preview" data-tab="preview" hidden>
      <header class="mp__pane-header no-print">
        <span class="mp__pane-label">{{ "tool.markdown-pdf.pane_preview" | t }}</span>
      </header>
      <article class="mp__preview" id="mp-preview" aria-live="polite"></article>
    </section>
  </div>
</section>
{% include "terminal-frame-close.njk" %}

{% include "tool-schema.njk" %}

<script src="/assets/js/markdown.js?v={{ buildHash }}"></script>
<script type="module">
const COPY = {
  saved:              {{ ("tool.markdown-pdf.saved"              | t) | dump | safe }},
  countsFmt:          {{ ("tool.markdown-pdf.counts_format"      | t) | dump | safe }},
  errLoadLib:         {{ ("tool.markdown-pdf.err_load_lib"       | t) | dump | safe }},
  confirmClear:       {{ ("tool.markdown-pdf.confirm_clear"      | t) | dump | safe }},
  aiGenerating:       {{ ("tool.markdown-pdf.btn_ai_generating"  | t) | dump | safe }},
  aiUnavailableHint:  {{ ("tool.markdown-pdf.ai_unavailable_hint" | t) | dump | safe }},
  aiConfirmDownload:  {{ ("tool.markdown-pdf.ai_confirm_download" | t) | dump | safe }},
  aiLoadingFmt:       {{ ("tool.markdown-pdf.btn_ai_loading"      | t) | dump | safe }}
};

const inputEl     = document.getElementById('mp-input');
const previewEl   = document.getElementById('mp-preview');
const countsEl    = document.getElementById('mp-counts');
const savedEl     = document.getElementById('mp-saved');
const downloadBtn = document.getElementById('mp-download');
const exportBtn   = document.getElementById('mp-export');
const shareBtn    = document.getElementById('mp-share');
const clearBtn    = document.getElementById('mp-clear');
const fileInput   = document.getElementById('mp-file');
const tabEdit     = document.getElementById('mp-tab-edit');
const tabPreview  = document.getElementById('mp-tab-preview');
const editorPane  = document.querySelector('.mp__pane--editor');
const previewPane = document.querySelector('.mp__pane--preview');

const LS_KEY = 'mentria-mdpdf-content';

const SAMPLE = `# Welcome to Markdown → PDF

This is a quick demo so you can see how your document will print.
**Edit on the left**, see the preview on the right, and click **Download PDF** when you're happy.

## Features

- GitHub-Flavored Markdown — tables, task lists, strikethrough
- Clean code blocks
- Fast live preview, debounced
- Auto-saved to your browser

### Code

\`\`\`js
function greet(name) {
  return \`Hello, \${name}!\`;
}
\`\`\`

### Table

| Feature      | Status |
| ------------ | :----: |
| Tables       | ✓      |
| Lists        | ✓      |
| Code blocks  | ✓      |
| Math (KaTeX) | later  |

### Task list

- [x] Type some markdown
- [x] Watch the preview update
- [ ] Hit **Download PDF**

> Tip: in the print dialog, choose **Save as PDF** as the destination, set margins to *Default*, and turn off headers/footers for the cleanest result.

---

Made with [Mentria](https://mentria.ai).
`;

if (window.renderMarkdownReady) { try { await window.renderMarkdownReady; } catch (_) {} }
if (typeof window.renderMarkdown !== 'function') {
  previewEl.innerHTML = `<p style="color:var(--syn-pink);padding:1rem;">${COPY.errLoadLib.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>`;
  inputEl.disabled = true;
  downloadBtn.disabled = true;
}

let renderTimer = null;
function scheduleRender() {
  clearTimeout(renderTimer);
  renderTimer = setTimeout(render, 100);
}

function render() {
  const scroll = previewEl.scrollTop;
  previewEl.innerHTML = window.renderMarkdown ? window.renderMarkdown(inputEl.value || '') : '';
  previewEl.scrollTop = scroll;
  updateCounts();
}

function updateCounts() {
  const text = inputEl.value || '';
  const chars = text.length;
  const words = text.trim() ? text.trim().split(/\s+/).length : 0;
  countsEl.textContent = COPY.countsFmt
    .replace('{words}', words.toLocaleString())
    .replace('{chars}', chars.toLocaleString());
}

/* ── Persistence ────────────────────────────────────────────────── */
let saveTimer = null;
function scheduleSave() {
  clearTimeout(saveTimer);
  saveTimer = setTimeout(() => {
    try {
      if (window.MentriaStore) window.MentriaStore.set('tools', 'mdpdf_content', inputEl.value);
      else localStorage.setItem(LS_KEY, inputEl.value);
      flashSaved();
    } catch (_) { /* quota etc. — ignore */ }
  }, 500);
}

let flashTimer = null;
function flashSaved() {
  savedEl.textContent = COPY.saved;
  savedEl.classList.add('is-visible');
  clearTimeout(flashTimer);
  flashTimer = setTimeout(() => savedEl.classList.remove('is-visible'), 1200);
}

function loadInitial() {
  let stored = null;
  if (window.MentriaStore) {
    stored = window.MentriaStore.get('tools', 'mdpdf_content');
    if (stored == null) {
      try {
        const legacy = localStorage.getItem(LS_KEY);
        if (legacy != null && legacy !== '') {
          stored = legacy;
          window.MentriaStore.set('tools', 'mdpdf_content', stored);
          localStorage.removeItem(LS_KEY);
        }
      } catch (_) {}
    }
  } else {
    try { stored = localStorage.getItem(LS_KEY); } catch (_) {}
  }
  inputEl.value = (stored != null && stored !== '') ? stored : SAMPLE;
}

/* ── PDF (via browser print) ────────────────────────────────────── */
function slugify(s) {
  return String(s || '')
    .normalize('NFKD').replace(/[̀-ͯ]/g, '')   // strip diacritics
    .replace(/[^A-Za-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .toLowerCase()
    .slice(0, 64) || 'document';
}

function deriveTitle() {
  const h1 = previewEl.querySelector('h1');
  if (h1?.textContent?.trim()) return h1.textContent.trim();
  // No H1 — use the first meaningful words from the source so the fallback
  // is at least content-shaped instead of a generic 'document'.
  const cleaned = (inputEl.value || '')
    .replace(/```[\s\S]*?```/g, ' ')   // drop fenced code blocks
    .replace(/[#>*_`~\[\]()!]/g, ' ')  // strip markdown punctuation
    .replace(/\s+/g, ' ')
    .trim();
  return cleaned.slice(0, 60) || 'document';
}

// ── AI naming ────────────────────────────────────────────────────
// Visible button hook. Lazy-instantiates the WebGPU engine only if a
// previous visit has cached the Qwen weights. Names are cached by a
// session-only content hash so re-pasting the same doc restores the
// last AI-generated name without another inference run.
const filenameInput = document.getElementById('mp-filename');
const aiBtn         = document.getElementById('mp-ai-name');
const aiBtnLabel    = aiBtn?.querySelector('.mp__filename-btn-label');
const AI_LABEL_DEFAULT = aiBtnLabel?.textContent || '';

let aiEngine = null;
const aiNameByHash = new Map();
let lastHash = '';

// Tiny, fast non-cryptographic hash (cyrb53). Fine for a session-only key.
function contentHash(s) {
  let h1 = 0xdeadbeef ^ 0, h2 = 0x41c6ce57 ^ 0;
  s = (s || '').trim();
  for (let i = 0, ch; i < s.length; i++) {
    ch = s.charCodeAt(i);
    h1 = Math.imul(h1 ^ ch, 2654435761);
    h2 = Math.imul(h2 ^ ch, 1597334677);
  }
  h1 = Math.imul(h1 ^ (h1 >>> 16), 2246822507) ^ Math.imul(h2 ^ (h2 >>> 13), 3266489909);
  h2 = Math.imul(h2 ^ (h2 >>> 16), 2246822507) ^ Math.imul(h1 ^ (h1 >>> 13), 3266489909);
  return (4294967296 * (2097151 & h2) + (h1 >>> 0)).toString(36);
}

// Mirror the cache probe used by /tools/search/. A positive hit on any
// mentria/huggingface cache key is a weak signal that the user has
// touched an AI tool before — actual model load happens on click and
// will download on demand if the weights aren't truly cached yet.
const MENTRIA_DIST_BASE  = '/assets/mentria/dist/';

async function detectCachedSignal() {
  if (!('caches' in window) || !navigator.gpu) return false;
  try {
    const keys = await caches.keys();
    return keys.some(k => k.includes('mentria') || k.includes('huggingface'));
  } catch (_) {
    return false;
  }
}

async function reflectAvailability() {
  if (!aiBtn) return;
  if (!('caches' in window) || !navigator.gpu) {
    aiBtn.disabled = true;
    aiBtn.title = COPY.aiUnavailableHint || '';
    return;
  }
  const cached = await detectCachedSignal();
  aiBtn.disabled = !cached;
  aiBtn.title = cached ? '' : (COPY.aiUnavailableHint || '');
}

async function ensureEngine(onProgress) {
  if (aiEngine && aiEngine.generate) return aiEngine;
  const { MentriaEngine } = await import(MENTRIA_DIST_BASE + 'mentria.mjs');
  const { ensureModel } = await import('/assets/js/mentria-model.js');
  const createEngine = () => {
    const e = new MentriaEngine(MENTRIA_DIST_BASE + 'worker.mjs');
    window.mentriaWrapEngine && window.mentriaWrapEngine(e);
    return e;
  };
  const res = await ensureModel(createEngine, { vision: false, cachedOnly: true, onProgress });
  aiEngine = res.engine;
  return aiEngine;
}

async function aiSuggestFilename(onLoadProgress) {
  const engine = await ensureEngine(onLoadProgress);
  if (!engine) return null;
  const text = (inputEl.value || '').trim().slice(0, 1500);
  if (text.length < 8) return null;
  const messages = [
    { role: 'system', content:
      'You name documents. Read the document the user gives you and reply with a ' +
      'short, descriptive title of 3 to 6 plain words that say what the document is ' +
      'about. Reply with the title only: no quotes, no file extension, no explanation.' },
    { role: 'user', content: 'Document:\n\n# Project Phoenix Kickoff\n\nAgenda for the Q3 launch covering timeline, budget owners, and the marketing plan for the new mobile app.' },
    { role: 'assistant', content: 'Project Phoenix Q3 Kickoff' },
    { role: 'user', content: 'Document:\n\nA quick banana bread recipe: cream the butter and sugar, mix in three ripe bananas, fold in flour and baking soda, then bake at 350 degrees for one hour.' },
    { role: 'assistant', content: 'Banana Bread Recipe' },
    { role: 'user', content: 'Document:\n\n' + text }
  ];
  let buf = '';
  await engine.generate({
    messages, maxTokens: 24,
    temperature: 0.3, topP: 0.9, topK: 30,
    repetitionPenalty: 1.1, enableThinking: false
  }, (event) => {
    if (typeof event.token === 'string' && event.token.length > 0) {
      if (/^<\|[^|]*\|>$/.test(event.token)) return;
      buf += event.token;
    }
  });
  const slug0 = buf
    .replace(/<think>[\s\S]*?<\/think>/g, '')
    .replace(/<\|[^|]*\|>/g, '')
    .trim()
    .toLowerCase()
    .split(/[\n\r]/)[0]
    .replace(/^[`'"\s]+|[`'"\s.]+$/g, '')
    .replace(/[^a-z0-9\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
  const GARBAGE_NAMES = new Set(['untitled', 'document', 'filename', 'title', 'slug', 'name']);
  const parts = slug0.split('-').filter(Boolean);
  const ALPHA = 'abcdefghijklmnopqrstuvwxyz';
  const looksGarbage =
    parts.length === 0 ||
    parts.every((p) => p.length <= 1) ||
    (parts.length === 1 && ALPHA.indexOf(parts[0]) !== -1) ||
    GARBAGE_NAMES.has(slug0);
  const clean = parts.slice(0, 6).join('-').slice(0, 64).replace(/-+$/, '');
  return (clean.length >= 3 && !looksGarbage) ? clean : null;
}

async function runAINameGeneration() {
  if (!aiBtn || aiBtn.disabled) return;

  aiBtn.disabled = true;
  if (aiBtnLabel) aiBtnLabel.textContent = (COPY.aiGenerating || 'Generating…');

  function onProgress(p) {
    if (!p || p.total == null || p.loaded == null || p.total <= 0) return;
    const pct = Math.max(0, Math.min(100, Math.round((p.loaded / p.total) * 100)));
    if (aiBtnLabel) aiBtnLabel.textContent = (COPY.aiLoadingFmt || 'Loading {pct}%').replace('{pct}', pct);
  }

  try {
    const name = await aiSuggestFilename(onProgress);
    if (name) {
      aiNameByHash.set(lastHash, name);
      filenameInput.value = name;
    }
  } catch (err) {
    console.warn('AI naming failed:', err);
  } finally {
    if (aiBtnLabel) aiBtnLabel.textContent = AI_LABEL_DEFAULT;
    reflectAvailability();
  }
}

// Track content hash and respond to content changes:
// - if input was showing the previous hash's AI name, clear it
// - if input is empty AND new hash has a cached AI name, restore it
// - any user-typed value that diverges from the cache persists across edits
function syncFilenameForContent() {
  const newHash = contentHash(inputEl.value);
  if (newHash === lastHash) return;
  const prevAIName = aiNameByHash.get(lastHash);
  const showingPrevAI = prevAIName && filenameInput.value === prevAIName;
  lastHash = newHash;
  if (showingPrevAI) {
    filenameInput.value = aiNameByHash.get(newHash) || '';
  } else if (filenameInput.value === '' && aiNameByHash.has(newHash)) {
    filenameInput.value = aiNameByHash.get(newHash);
  }
}

function downloadPDF() {
  const original = document.title;
  const fromInput = (filenameInput.value || '').trim();
  const name = fromInput ? slugify(fromInput) : slugify(deriveTitle());
  document.title = name;
  if (renderTimer) { clearTimeout(renderTimer); render(); }
  window.print();
  setTimeout(() => { document.title = original; }, 1000);
}

/* ── Export / Import .md ────────────────────────────────────────── */
function exportMD() {
  const fromInput = (filenameInput.value || '').trim();
  const filename = (fromInput ? slugify(fromInput) : slugify(deriveTitle())) + '.md';
  const blob = new Blob([inputEl.value || ''], { type: 'text/markdown;charset=utf-8' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a); a.click(); a.remove();
  URL.revokeObjectURL(url);
}

async function shareMD() {
  const fromInput = (filenameInput.value || '').trim();
  const filename = (fromInput ? slugify(fromInput) : slugify(deriveTitle())) + '.md';
  const file = new File([inputEl.value || ''], filename, { type: 'text/markdown' });
  const withFile = { files: [file], title: filename };
  try {
    if (navigator.canShare && navigator.canShare(withFile)) {
      await navigator.share(withFile);
    } else {
      await navigator.share({ title: filename, text: inputEl.value || '', url: location.href });
    }
  } catch (_) { /* dismissed */ }
}

function importMD(file) {
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    inputEl.value = e.target.result || '';
    render();
    scheduleSave();
  };
  reader.readAsText(file);
}

/* ── Tabs (mobile) ──────────────────────────────────────────────── */
function setTab(tab) {
  const editing = tab === 'edit';
  tabEdit.classList.toggle('is-active', editing);
  tabPreview.classList.toggle('is-active', !editing);
  tabEdit.setAttribute('aria-selected', String(editing));
  tabPreview.setAttribute('aria-selected', String(!editing));
  // hidden attribute drives mobile-only display via CSS
  editorPane.hidden  = !editing;
  previewPane.hidden =  editing;
}

/* ── Events ─────────────────────────────────────────────────────── */
inputEl.addEventListener('input', () => {
  scheduleRender();
  scheduleSave();
  syncFilenameForContent();
});

// Tab key inserts 2 spaces (instead of leaving the textarea)
inputEl.addEventListener('keydown', (e) => {
  if (e.key === 'Tab' && !e.shiftKey) {
    e.preventDefault();
    const start = inputEl.selectionStart;
    const end   = inputEl.selectionEnd;
    const v = inputEl.value;
    inputEl.value = v.slice(0, start) + '  ' + v.slice(end);
    inputEl.selectionStart = inputEl.selectionEnd = start + 2;
    scheduleRender();
    scheduleSave();
  }
});

downloadBtn.addEventListener('click', downloadPDF);
exportBtn.addEventListener('click', exportMD);
if (navigator.share) shareBtn.addEventListener('click', shareMD);
else shareBtn.style.display = 'none';
aiBtn?.addEventListener('click', runAINameGeneration);
clearBtn.addEventListener('click', async () => {
  if (!(await mentriaConfirm(COPY.confirmClear))) return;
  inputEl.value = '';
  filenameInput.value = '';
  if (window.MentriaStore) window.MentriaStore.remove('tools', 'mdpdf_content');
  try { localStorage.removeItem(LS_KEY); } catch (_) {}
  syncFilenameForContent();
  render();
});
fileInput.addEventListener('change', (e) => {
  const file = e.target.files?.[0];
  if (file) importMD(file);
  fileInput.value = '';
});

tabEdit.addEventListener('click', () => setTab('edit'));
tabPreview.addEventListener('click', () => setTab('preview'));

/* ── Init ───────────────────────────────────────────────────────── */
loadInitial();
render();
// Both panes visible on desktop; tabs are no-ops there. On mobile (≤720px)
// the CSS hides the inactive pane via `hidden`. Force a default tab state.
setTab('edit');
lastHash = contentHash(inputEl.value);
reflectAvailability();
const idle = window.requestIdleCallback || (cb => setTimeout(cb, 1500));
idle(() => reflectAvailability());

if ('launchQueue' in window) {
  window.launchQueue.setConsumer(async (params) => {
    if (!params || !params.files || !params.files.length) return;
    try {
      importMD(await params.files[0].getFile());
    } catch (_) {}
  });
}
</script>

<style>
/* ── Tool shell ───────────────────────────────────────────────── */
.mp {
  display: flex;
  flex-direction: column;
  font-family: var(--font-mono);
  height: min(680px, 76vh);
}

/* ── Action bar ───────────────────────────────────────────────── */
.mp__actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  padding: 0.55rem 0.65rem;
  border-bottom: 1px solid var(--term-border);
  flex-shrink: 0;
}
.mp__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  padding: 0.45rem 0.75rem;
