<!DOCTYPE html>
<html lang="{{ lang | default('en') }}"{% if feedLayout %} class="feed-layout"{% endif %}>
<head>
    <meta charset="UTF-8">
    {# Disable user pinch-to-zoom + iOS focus auto-zoom. The site has
       multi-tap interactions (CLI input, game touch controls, install
       sheet, language switcher) that iOS otherwise hijacks for zoom
       gestures. maximum-scale=1.0 + user-scalable=no together cover the
       older iOS versions that occasionally ignore one or the other.
       The CSS also forces 16px on inputs to prevent the focus-zoom
       that fires even when scaling is locked. #}
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <script>
      // Anti-FOUC: detect standalone (installed) mode before first paint so
      // the install prompt CSS can hide everything via .is-standalone.
      if (window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone) {
        document.documentElement.classList.add('is-standalone');
      }
    </script>
    <script>
      // Soft-redirect: on a visitor's first hit at the default-locale root,
      // if their browser language matches a supported non-default locale,
      // bounce them to that locale's path once. Sticky-dismissable.
      (function () {
        try {
          var FLAG = 'mentria_lang_redirected_at';
          if (localStorage.getItem(FLAG)) return;
          // Map: each entry is [lang code, path prefix used in URLs].
          var supported = [
            ['es', '/es'],
            ['pt-BR', '/pt-br'],
            ['fr', '/fr'],
            ['ja', '/ja']
          ];
          var path = location.pathname || '/';
          // Already in a non-default locale path? Nothing to do.
          for (var i = 0; i < supported.length; i++) {
            if (path === supported[i][1] || path.indexOf(supported[i][1] + '/') === 0) return;
          }
          var pref = (navigator.language || 'en').toLowerCase();
          var match = null;
          for (var j = 0; j < supported.length; j++) {
            var code = supported[j][0].toLowerCase();
            var base = code.split('-')[0];
            if (pref === code || pref === base || pref.indexOf(base + '-') === 0) {
              match = supported[j];
              break;
            }
          }
          if (!match) return;
          localStorage.setItem(FLAG, String(Date.now()));
          var dest = match[1] + (path === '/' ? '/' : path) + (location.search || '') + (location.hash || '');
          location.replace(dest);
        } catch (_) { /* ignore */ }
      })();
    </script>
    {% set baseUrl = site.siteUrl | default('/') %}
    {% set pageUrl = baseUrl ~ page.url %}
    {% set metaTitle = (title and (title ~ " | " ~ site.title)) or ("site.metaTitle" | t) %}
    {% set metaDescription = description | default(("site.metaDescription" | t)) %}
    {% set socialImage = site.siteUrl ~ (site.socialImage | default('/assets/img/icon-512x512.png')) %}
    <title>{{ metaTitle }}</title>
    <meta name="description" content="{{ metaDescription }}">
    <meta name="keywords" content="{{ site.keywords }}">
    <meta name="robots" content="{{ site.robots | default('index, follow') }}">
    <meta name="author" content="{{ site.author }}">
    <meta name="theme-color" content="#0a0a0a">

    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ pageUrl }}">
    <meta property="og:title" content="{{ metaTitle }}">
    <meta property="og:description" content="{{ metaDescription }}">
    <meta property="og:image" content="{{ socialImage }}">
    <meta property="og:locale" content="{{ lang | default('en') | replace('-', '_') }}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="{{ pageUrl }}">
    <meta name="twitter:title" content="{{ metaTitle }}">
    <meta name="twitter:description" content="{{ metaDescription }}">
    <meta name="twitter:image" content="{{ socialImage }}">

    <link rel="canonical" href="{{ pageUrl }}">
    <link rel="icon" href="/assets/img/favicon-96x96.png" type="image/png">
    <link rel="apple-touch-icon" href="/assets/img/icon-192x192.png">

    {#- Reciprocal hreflang matrix — one alternate per supported locale -#}
    {%- for loc in locales %}
    <link rel="alternate" hreflang="{{ loc.code }}" href="{{ site.siteUrl }}{{ page.url | switchLocale(loc.code) }}">
    {%- endfor %}
    <link rel="alternate" hreflang="x-default" href="{{ site.siteUrl }}{{ page.url | switchLocale('en') }}">

    <link rel="preload" href="/assets/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/assets/fonts/jbm-latin.woff2"   as="font" type="font/woff2" crossorigin>

    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="/assets/css/terminal.css">
    <link rel="manifest" href="/manifest.json">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "{{ site.siteUrl }}/#organization",
          "name": "{{ site.title }}",
          "url": "{{ site.siteUrl }}",
          "logo": {
            "@type": "ImageObject",
            "url": "{{ site.siteUrl }}/assets/img/icon-512x512.png",
            "width": 512,
            "height": 512
          },
          "sameAs": [
            "https://github.com/mentria-ai",
            "https://huggingface.co/mentriaai",
            "https://x.com/mentria_ai"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "{{ site.siteUrl }}/#website",
          "url": "{{ site.siteUrl }}",
          "name": "{{ site.title }}",
          "description": "{{ ('site.metaDescription' | t) | default(site.metaDescription) }}",
          "publisher": { "@id": "{{ site.siteUrl }}/#organization" },
          "inLanguage": "{{ lang | default('en') }}"
        }
      ]
    }
    </script>

    {%- set localePrefix = (locale.pathPrefix | default("")) -%}
    {%- set isHomePage = (page.url == "/" or page.url == localePrefix + "/") -%}
    {%- set inTools = page.url | startsWith(localePrefix + "/tools/") -%}
    {%- set isToolIndex = (page.url == localePrefix + "/tools/") -%}
    {%- set inFeed = page.url | startsWith(localePrefix + "/feed/") -%}
    {%- set isFeedIndex = (page.url == localePrefix + "/feed/") -%}
    {%- set isPost = tags and ("post" in tags) -%}
    {%- if not isHomePage %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": {{ ("nav.home" | t) | dump | safe }}, "item": "{{ site.siteUrl }}{{ localePrefix }}/" }
        {%- if inTools %},
        { "@type": "ListItem", "position": 2, "name": {{ ("nav.tools" | t) | dump | safe }}, "item": "{{ site.siteUrl }}{{ localePrefix }}/tools/" }
        {%- if not isToolIndex %},
        { "@type": "ListItem", "position": 3, "name": {{ title | dump | safe }}, "item": "{{ pageUrl }}" }
        {%- endif %}
        {%- elif inFeed %},
        { "@type": "ListItem", "position": 2, "name": {{ ("nav.feed" | t) | dump | safe }}, "item": "{{ site.siteUrl }}{{ localePrefix }}/feed/" }
        {%- if not isFeedIndex %},
        { "@type": "ListItem", "position": 3, "name": {{ title | dump | safe }}, "item": "{{ pageUrl }}" }
        {%- endif %}
        {%- endif %}
      ]
    }
    </script>
    {%- endif %}

    {%- if isPost %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ pageUrl }}" },
      "headline": {{ title | dump | safe }},
      "description": {{ (description or "") | dump | safe }},
      {%- if cover %}
      "image": "{{ site.siteUrl }}{{ cover }}",
      {%- else %}
      "image": "{{ socialImage }}",
      {%- endif %}
      "datePublished": "{{ page.date.toISOString() }}",
      "dateModified": "{{ page.date.toISOString() }}",
      "author": { "@type": "Organization", "@id": "{{ site.siteUrl }}/#organization" },
      "publisher": { "@id": "{{ site.siteUrl }}/#organization" },
      "inLanguage": "{{ lang | default('en') }}"
    }
    </script>
    {%- endif %}
</head>
<body class="scanlines">
    {% include "header.njk" %}

    <main id="main-content">
        {{ content | safe }}
    </main>

    {% if not feedLayout %}
    {% include "footer.njk" %}
    {% endif %}

    {% include "pwa-install.njk" %}

    <div id="m-dialog" popover="manual" class="m-dialog" role="alertdialog" aria-modal="true" aria-labelledby="m-dialog-msg">
      <p class="m-dialog__msg" id="m-dialog-msg"></p>
      <div class="m-dialog__actions">
        <button type="button" class="m-dialog__btn m-dialog__btn--ghost" id="m-dialog-cancel">{{ "common.dialog.cancel" | t }}</button>
        <button type="button" class="m-dialog__btn m-dialog__btn--primary" id="m-dialog-ok">{{ "common.dialog.ok" | t }}</button>
      </div>
    </div>
    <script>
      (function () {
        var dlg = document.getElementById('m-dialog');
        if (!dlg || typeof dlg.showPopover !== 'function') {
          window.mentriaConfirm = function (m) { return Promise.resolve(window.confirm(m)); };
          window.mentriaAlert = function (m) { window.alert(m); return Promise.resolve(); };
          return;
        }
        var msgEl = document.getElementById('m-dialog-msg');
        var okBtn = document.getElementById('m-dialog-ok');
        var cancelBtn = document.getElementById('m-dialog-cancel');
        var okLabel = {{ ("common.dialog.ok" | t) | dump | safe }};
        var confirmLabel = {{ ("common.dialog.confirm" | t) | dump | safe }};
        var resolver = null;
        function settle(result) {
          var r = resolver; resolver = null;
          if (dlg.matches(':popover-open')) dlg.hidePopover();
          if (r) r(result);
        }
        okBtn.addEventListener('click', function () { settle(true); });
        cancelBtn.addEventListener('click', function () { settle(false); });
        dlg.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') { e.preventDefault(); settle(false); }
        });
        function open(message, mode) {
          if (resolver) settle(false);
          msgEl.textContent = message;
          cancelBtn.hidden = (mode === 'alert');
          okBtn.textContent = (mode === 'alert') ? okLabel : confirmLabel;
          dlg.showPopover();
          okBtn.focus();
          return new Promise(function (res) { resolver = res; });
        }
        window.mentriaConfirm = function (m) { return open(m, 'confirm'); };
        window.mentriaAlert = function (m) { return open(m, 'alert'); };
      })();
    </script>
    <script>
      window.mentriaConfirmHeavyDownload = async function () {
        try {
          if ('caches' in window) {
            var hit = await caches.match('https://huggingface.co/mentriaai/Qwen3.5-0.8B-mentria/resolve/main/qwen3.5-0.8b-q4.safetensors');
            if (hit) return true;
          }
        } catch (_) {}
        var c = navigator.connection;
        if (!c) return true;
        var slow = c.saveData === true || ['slow-2g', '2g', '3g'].indexOf(c.effectiveType) !== -1;
        if (!slow) return true;
        if (typeof window.mentriaConfirm === 'function') {
          return window.mentriaConfirm({{ ("common.heavy_download" | t) | dump | safe }});
        }
        return true;
      };
    </script>
    <script>
      (function () {
        if (!navigator.share) return;
        if (!/^(\/(es|fr|ja|pt-br))?\/tools\/[^/]+\/?$/.test(location.pathname)) return;
        var h1 = document.querySelector('.hero h1');
        if (!h1) return;
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'tool-share';
        btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg><span></span>';
        btn.querySelector('span').textContent = {{ ("common.share" | t) | dump | safe }};
        btn.addEventListener('click', function () {
          var desc = document.querySelector('meta[name="description"]');
          navigator.share({
            title: document.title,
            text: desc ? desc.content : document.title,
            url: location.href
          }).catch(function () {});
        });
        h1.insertAdjacentElement('afterend', btn);
      })();
    </script>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
    <script>
      (function () {
        var FS = 'terminal-frame--fullscreen';
        var BODY_FS = 'is-fullscreen-tool';
        function activeFrame() { return document.querySelector('.' + FS); }
        function exit() {
          var frame = activeFrame();
          if (!frame) return;
          frame.classList.remove(FS);
          document.body.classList.remove(BODY_FS);
          window.dispatchEvent(new Event('resize'));
        }
        function enter(frame) {
          var current = activeFrame();
          if (current && current !== frame) current.classList.remove(FS);
          frame.classList.add(FS);
          document.body.classList.add(BODY_FS);
          window.dispatchEvent(new Event('resize'));
        }
        document.addEventListener('click', function (e) {
          var btn = e.target.closest && e.target.closest('[data-action="toggle-fullscreen"]');
          if (!btn) return;
          var frame = btn.closest('.terminal-frame');
          if (!frame) return;
          e.preventDefault();
          if (frame.classList.contains(FS)) exit(); else enter(frame);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && activeFrame()) exit();
        });
      })();
    </script>
</body>
</html>
