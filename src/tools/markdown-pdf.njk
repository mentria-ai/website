      {{ "tool.markdown-pdf.btn_download" | t }}
    </button>
    <button class="mp__btn" id="mp-export" title="{{ 'tool.markdown-pdf.title_export' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      {{ "tool.markdown-pdf.btn_export" | t }}
    </button>
    <label class="mp__btn mp__btn--label" for="mp-file" title="{{ 'tool.markdown-pdf.title_import' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
