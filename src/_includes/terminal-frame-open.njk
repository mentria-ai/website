<div class="terminal-frame">
    <div class="terminal-frame__titlebar">
        <div class="terminal-frame__dots">
            <span class="terminal-frame__dot terminal-frame__dot--red"></span>
            <span class="terminal-frame__dot terminal-frame__dot--yellow"></span>
            <button type="button" class="terminal-frame__dot terminal-frame__dot--green" data-action="toggle-fullscreen" aria-label="Toggle fullscreen" title="Toggle fullscreen"></button>
        </div>
        {% if terminalTitle %}
        <span class="terminal-frame__filename">{{ terminalTitle }}</span>
        {% endif %}
        {% if terminalHelpId %}
        <button type="button" class="terminal-frame__help" popovertarget="{{ terminalHelpId }}" aria-label="{{ 'tool.common.controls' | t }}" title="{{ 'tool.common.controls' | t }}">?</button>
        {% endif %}
    </div>
    <div class="terminal-frame__body">

