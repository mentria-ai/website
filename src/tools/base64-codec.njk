---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/base64-codec/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.base64-codec.title' | t }}"
  description: "{{ 'tools.base64-codec.lede' | t }}"
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><a class="eyebrow__link" href="{{ locale.pathPrefix }}/tools/">tools</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">base64-codec</span></p>
  <h1>{{ "tools.base64-codec.title" | t }}</h1>
  <p>{{ "tools.base64-codec.lede" | t }}</p>
  {% include "tldr.njk" %}
</section>

{% set terminalTitle = "base64-codec.js" %}
{% include "terminal-frame-open.njk" %}
<section class="b64">
  <div class="m-seg b64-mode-tabs">
    <button data-mode="text" data-value="text">{{ "tool.base64-codec.tab_text" | t }}</button>
    <button data-mode="file" data-value="file">{{ "tool.base64-codec.tab_file" | t }}</button>
  </div>

  <div class="b64-panel" id="b64-text-panel">
    <div class="b64-text-grid">
      <div class="b64-text-col">
        <label class="b64-label" for="b64-input">{{ "tool.base64-codec.input_label" | t }}</label>
        <textarea class="b64-textarea" id="b64-input" placeholder="{{ 'tool.base64-codec.input_placeholder' | t }}" spellcheck="false"></textarea>
      </div>
      <div class="b64-text-col">
        <label class="b64-label" for="b64-output">{{ "tool.base64-codec.output_label" | t }}</label>
        <textarea class="b64-textarea" id="b64-output" placeholder="{{ 'tool.base64-codec.output_placeholder' | t }}" spellcheck="false" readonly></textarea>
      </div>
    </div>
    <div class="b64-text-actions">
      <button class="m-btn m-btn--primary" id="b64-encode-btn">{{ "tool.base64-codec.btn_encode" | t }}</button>
      <button class="m-btn m-btn--primary" id="b64-decode-btn">{{ "tool.base64-codec.btn_decode" | t }}</button>
      <button class="m-btn m-btn--ghost" id="b64-copy-btn">{{ "tool.base64-codec.btn_copy_output" | t }}</button>
      <button class="m-btn m-btn--ghost" id="b64-clear-btn">{{ "tool.base64-codec.btn_clear" | t }}</button>
    </div>
    <div class="b64-status m-status" id="b64-text-status"></div>
  </div>

  <div class="b64-panel b64-panel--hidden" id="b64-file-panel">
    <div class="b64-file-section">
      <h3 class="b64-section-title">{{ "tool.base64-codec.section_file_to_b64" | t }}</h3>
      <div class="b64-dropzone" id="b64-dropzone">
        <div class="b64-dropzone__content">
          <div class="b64-dropzone__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <path d="M24 32V16m0 0l-8 8m8-8l8 8" stroke="var(--syn-cyan)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <rect x="4" y="4" width="40" height="40" rx="8" stroke="var(--term-muted)" stroke-width="2" stroke-dasharray="4 4"/>
            </svg>
          </div>
          <p class="b64-dropzone__text">{{ "tool.base64-codec.dropzone_text_prefix" | t }} <button class="b64-dropzone__browse" id="b64-browse-btn" type="button">{{ "tool.base64-codec.dropzone_browse" | t }}</button></p>
          <p class="b64-dropzone__hint">{{ "tool.base64-codec.dropzone_hint" | t }}</p>
        </div>
        <input type="file" id="b64-file-input" class="b64-sr-only" accept="*/*" />
      </div>

      <div class="b64-file-info b64-file-info--hidden" id="b64-file-info">
        <div class="b64-file-meta">
          <div class="b64-file-meta__row"><span class="b64-file-meta__label">{{ "tool.base64-codec.meta_name" | t }}</span> <span id="b64-file-name">-</span></div>
          <div class="b64-file-meta__row"><span class="b64-file-meta__label">{{ "tool.base64-codec.meta_type" | t }}</span> <span id="b64-file-type">-</span></div>
          <div class="b64-file-meta__row"><span class="b64-file-meta__label">{{ "tool.base64-codec.meta_size" | t }}</span> <span id="b64-file-size">-</span></div>
          <div class="b64-file-meta__row"><span class="b64-file-meta__label">{{ "tool.base64-codec.meta_b64_size" | t }}</span> <span id="b64-file-b64size">-</span></div>
        </div>
        <div class="b64-file-preview" id="b64-file-preview"></div>
        <div class="b64-file-output">
          <label class="b64-label">{{ "tool.base64-codec.data_uri_label" | t }}</label>
          <textarea class="b64-textarea b64-textarea--sm" id="b64-file-datauri" readonly spellcheck="false"></textarea>
          <div class="b64-file-actions">
            <button class="m-btn m-btn--ghost" id="b64-copy-datauri">{{ "tool.base64-codec.btn_copy_datauri" | t }}</button>
            <button class="m-btn m-btn--ghost" id="b64-copy-raw">{{ "tool.base64-codec.btn_copy_raw" | t }}</button>
            <button class="m-btn m-btn--ghost" id="b64-file-clear">{{ "tool.base64-codec.btn_clear" | t }}</button>
          </div>
        </div>
      </div>
    </div>

    <div class="b64-file-section">
      <h3 class="b64-section-title">{{ "tool.base64-codec.section_b64_to_file" | t }}</h3>
      <label class="b64-label" for="b64-decode-input">{{ "tool.base64-codec.decode_input_label" | t }}</label>
      <textarea class="b64-textarea b64-textarea--sm" id="b64-decode-input" placeholder="{{ 'tool.base64-codec.decode_input_placeholder' | t }}" spellcheck="false"></textarea>
      <div class="b64-file-actions" style="margin-top:0.75rem;">
        <button class="m-btn m-btn--primary" id="b64-decode-file-btn">{{ "tool.base64-codec.btn_decode_preview" | t }}</button>
        <button class="m-btn m-btn--ghost" id="b64-download-btn" disabled>{{ "tool.base64-codec.btn_download" | t }}</button>
      </div>
      <div class="b64-decode-preview" id="b64-decode-preview"></div>
      <div class="b64-status m-status" id="b64-file-status"></div>
    </div>
  </div>
</section>
{% include "terminal-frame-close.njk" %}

{% include "tool-schema.njk" %}

<script>
(() => {
  const COPY = {
    unknown:                 {{ ("tool.base64-codec.meta_unknown"                | t) | dump | safe }},
    noPreview:               {{ ("tool.base64-codec.preview_no_preview"          | t) | dump | safe }},
    decodedPreview:          {{ ("tool.base64-codec.preview_decoded_template"    | t) | dump | safe }},
    statusCopied:            {{ ("tool.base64-codec.status_copied"               | t) | dump | safe }},
    statusCopyFailed:        {{ ("tool.base64-codec.status_copy_failed"          | t) | dump | safe }},
    statusNothingEncode:     {{ ("tool.base64-codec.status_nothing_encode"       | t) | dump | safe }},
    statusEncoded:           {{ ("tool.base64-codec.status_encoded_template"     | t) | dump | safe }},
    statusEncodeFailed:      {{ ("tool.base64-codec.status_encode_failed"        | t) | dump | safe }},
    statusNothingDecode:     {{ ("tool.base64-codec.status_nothing_decode"       | t) | dump | safe }},
    statusDecoded:           {{ ("tool.base64-codec.status_decoded_template"     | t) | dump | safe }},
    statusDecodeFailedInv:   {{ ("tool.base64-codec.status_decode_failed_invalid"| t) | dump | safe }},
    statusDecodeBinary:      {{ ("tool.base64-codec.status_decode_binary"        | t) | dump | safe }},
    statusNothingCopy:       {{ ("tool.base64-codec.status_nothing_copy"         | t) | dump | safe }},
    statusFileLoaded:        {{ ("tool.base64-codec.status_file_loaded"          | t) | dump | safe }},
    statusFileReadFailed:    {{ ("tool.base64-codec.status_file_read_failed"     | t) | dump | safe }},
    statusPasteFirst:        {{ ("tool.base64-codec.status_paste_first"          | t) | dump | safe }},
    statusInvalidB64:        {{ ("tool.base64-codec.status_invalid_b64"          | t) | dump | safe }},
    statusFileDecoded:       {{ ("tool.base64-codec.status_file_decoded_template"| t) | dump | safe }},
    statusDecodeFailedB64:   {{ ("tool.base64-codec.status_decode_failed_b64"    | t) | dump | safe }}
  };

  document.addEventListener('DOMContentLoaded', () => {
    const textPanel     = document.getElementById('b64-text-panel');
    const filePanel     = document.getElementById('b64-file-panel');

    const inputEl       = document.getElementById('b64-input');
    const outputEl      = document.getElementById('b64-output');
    const encodeBtn     = document.getElementById('b64-encode-btn');
    const decodeBtn     = document.getElementById('b64-decode-btn');
    const copyBtn       = document.getElementById('b64-copy-btn');
    const clearBtn      = document.getElementById('b64-clear-btn');
    const textStatus    = MentriaUI.status(document.getElementById('b64-text-status'));

    const dropzone      = document.getElementById('b64-dropzone');
    const browseBtn     = document.getElementById('b64-browse-btn');
    const fileInput     = document.getElementById('b64-file-input');
    const fileInfoWrap  = document.getElementById('b64-file-info');
    const fileNameEl    = document.getElementById('b64-file-name');
    const fileTypeEl    = document.getElementById('b64-file-type');
    const fileSizeEl    = document.getElementById('b64-file-size');
    const fileB64SizeEl = document.getElementById('b64-file-b64size');
    const filePreview   = document.getElementById('b64-file-preview');
    const fileDataUri   = document.getElementById('b64-file-datauri');
    const copyDataUri   = document.getElementById('b64-copy-datauri');
    const copyRaw       = document.getElementById('b64-copy-raw');
    const fileClearBtn  = document.getElementById('b64-file-clear');

    const decodeInput   = document.getElementById('b64-decode-input');
    const decodeFileBtn = document.getElementById('b64-decode-file-btn');
    const downloadBtn   = document.getElementById('b64-download-btn');
    const decodePreview = document.getElementById('b64-decode-preview');
    const fileStatus    = MentriaUI.status(document.getElementById('b64-file-status'));

    let currentDataUri  = '';
    let currentRawB64   = '';
    let decodedBlob     = null;
    let decodedFilename = 'decoded-file';

    function formatBytes(bytes) {
      if (bytes === 0) return '0 B';
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    }

    function showStatus(status, msg, tone) {
      status.set(msg, tone);
      if (tone !== 'err') setTimeout(() => status.clear(), 3000);
    }

    async function copyText(text, status) {
      try {
        await navigator.clipboard.writeText(text);
        showStatus(status, COPY.statusCopied, 'ok');
      } catch {
        showStatus(status, COPY.statusCopyFailed, 'err');
      }
    }

    function isBase64(str) {
      const s = str.trim();
      if (s.startsWith('data:')) return true;
      if (s.length < 4) return false;
      return /^[A-Za-z0-9+/\n\r]+=*$/.test(s);
    }

    function isImageMime(mime) {
      return /^image\//i.test(mime);
    }

    function mimeToExt(mime) {
      const map = {
        'image/png': 'png', 'image/jpeg': 'jpg', 'image/gif': 'gif',
        'image/webp': 'webp', 'image/svg+xml': 'svg', 'image/bmp': 'bmp',
        'image/tiff': 'tiff', 'image/x-icon': 'ico', 'image/avif': 'avif',
        'application/pdf': 'pdf', 'application/json': 'json',
        'text/plain': 'txt', 'text/html': 'html', 'text/css': 'css',
        'application/javascript': 'js',
      };
      return map[mime] || 'bin';
    }

    MentriaUI.segmented(document.querySelector('.b64-mode-tabs'), (mode) => {
      textPanel.classList.toggle('b64-panel--hidden', mode !== 'text');
      filePanel.classList.toggle('b64-panel--hidden', mode !== 'file');
    }).set('text');

    encodeBtn.addEventListener('click', () => {
      const raw = inputEl.value;
      if (!raw) { showStatus(textStatus, COPY.statusNothingEncode, 'err'); return; }
      try {
        const encoded = btoa(unescape(encodeURIComponent(raw)));
        outputEl.value = encoded;
        showStatus(textStatus, COPY.statusEncoded.replace('{size}', formatBytes(encoded.length)), 'ok');
      } catch (e) {
        showStatus(textStatus, COPY.statusEncodeFailed.replace('{reason}', e.message), 'err');
      }
    });

    decodeBtn.addEventListener('click', () => {
      let raw = inputEl.value.trim();
      if (!raw) { showStatus(textStatus, COPY.statusNothingDecode, 'err'); return; }
      const dataUriMatch = raw.match(/^data:[^;]*;base64,(.*)$/s);
      if (dataUriMatch) raw = dataUriMatch[1];
      let bytes;
      try {
        bytes = Uint8Array.from(atob(raw), c => c.charCodeAt(0));
      } catch (e) {
        showStatus(textStatus, COPY.statusDecodeFailedInv, 'err');
        return;
      }
      try {
        outputEl.value = new TextDecoder('utf-8', { fatal: true }).decode(bytes);
        showStatus(textStatus, COPY.statusDecoded.replace('{size}', formatBytes(bytes.length)), 'ok');
      } catch (e) {
        outputEl.value = '';
        showStatus(textStatus, COPY.statusDecodeBinary, 'err');
      }
    });

    copyBtn.addEventListener('click', () => {
      if (!outputEl.value) { showStatus(textStatus, COPY.statusNothingCopy, 'err'); return; }
      copyText(outputEl.value, textStatus);
    });

    clearBtn.addEventListener('click', () => {
      inputEl.value = '';
      outputEl.value = '';
      textStatus.clear();
    });

    browseBtn.addEventListener('click', () => fileInput.click());

    ['dragenter', 'dragover'].forEach(evt => {
      dropzone.addEventListener(evt, e => {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.add('b64-dropzone--active');
      });
    });
    ['dragleave', 'drop'].forEach(evt => {
      dropzone.addEventListener(evt, e => {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.remove('b64-dropzone--active');
      });
    });

    dropzone.addEventListener('drop', e => {
      const files = e.dataTransfer.files;
      if (files.length) handleFile(files[0]);
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files.length) handleFile(fileInput.files[0]);
    });

    function handleFile(file) {
      const reader = new FileReader();
      reader.onload = () => {
        currentDataUri = reader.result;
        const commaIdx = currentDataUri.indexOf(',');
        currentRawB64 = commaIdx !== -1 ? currentDataUri.slice(commaIdx + 1) : currentDataUri;

        fileNameEl.textContent = file.name;
        fileTypeEl.textContent = file.type || COPY.unknown;
        fileSizeEl.textContent = formatBytes(file.size);
        fileB64SizeEl.textContent = formatBytes(currentRawB64.length);
        fileDataUri.value = currentDataUri;

        filePreview.innerHTML = '';
        if (isImageMime(file.type)) {
          const img = document.createElement('img');
          img.src = currentDataUri;
          img.alt = 'Preview of ' + file.name;
          img.className = 'b64-preview-img';
          filePreview.appendChild(img);
        } else {
          filePreview.innerHTML = '<p class="b64-preview-placeholder">' + COPY.noPreview + '</p>';
        }

        fileInfoWrap.classList.remove('b64-file-info--hidden');
        showStatus(fileStatus, COPY.statusFileLoaded.replace('{name}', file.name), 'ok');
      };
      reader.onerror = () => {
        showStatus(fileStatus, COPY.statusFileReadFailed, 'err');
      };
      reader.readAsDataURL(file);
    }

    copyDataUri.addEventListener('click', () => {
      if (!currentDataUri) return;
      copyText(currentDataUri, fileStatus);
    });

    copyRaw.addEventListener('click', () => {
      if (!currentRawB64) return;
      copyText(currentRawB64, fileStatus);
    });

    fileClearBtn.addEventListener('click', () => {
      currentDataUri = '';
      currentRawB64 = '';
      fileInfoWrap.classList.add('b64-file-info--hidden');
      filePreview.innerHTML = '';
      fileDataUri.value = '';
      fileInput.value = '';
      fileStatus.clear();
    });

    decodeFileBtn.addEventListener('click', () => {
      const val = decodeInput.value.trim();
      if (!val) { showStatus(fileStatus, COPY.statusPasteFirst, 'err'); return; }

      let mime = 'application/octet-stream';
      let b64 = val;

      const dataUriMatch = val.match(/^data:([^;]+);base64,(.*)$/s);
      if (dataUriMatch) {
        mime = dataUriMatch[1];
        b64 = dataUriMatch[2];
      } else if (!isBase64(val)) {
        showStatus(fileStatus, COPY.statusInvalidB64, 'err');
        return;
      }

      try {
        const binary = atob(b64);
        const bytes = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
        decodedBlob = new Blob([bytes], { type: mime });
        decodedFilename = 'decoded-file.' + mimeToExt(mime);

        decodePreview.innerHTML = '';
        if (isImageMime(mime)) {
          const img = document.createElement('img');
          img.src = val.startsWith('data:') ? val : 'data:' + mime + ';base64,' + b64;
          img.alt = 'Decoded image preview';
          img.className = 'b64-preview-img';
          decodePreview.appendChild(img);
        } else {
          decodePreview.innerHTML = '<p class="b64-preview-placeholder">' + COPY.decodedPreview.replace('{mime}', mime).replace('{size}', formatBytes(decodedBlob.size)) + '</p>';
        }

        downloadBtn.disabled = false;
        showStatus(fileStatus, COPY.statusFileDecoded.replace('{size}', formatBytes(decodedBlob.size)), 'ok');
      } catch (e) {
        showStatus(fileStatus, COPY.statusDecodeFailedB64, 'err');
        decodedBlob = null;
        downloadBtn.disabled = true;
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (!decodedBlob) return;
      MentriaUI.downloadFile(decodedFilename, decodedBlob);
    });
  });
})();
</script>

<style>
.b64 {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  max-width: 960px;
  margin: 0 auto;
}

.b64-mode-tabs {
  align-self: center;
}

.b64-panel--hidden {
  display: none !important;
}

.b64-label {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--syn-cyan);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  margin-bottom: 0.35rem;
  display: block;
}

.b64-section-title {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--syn-purple);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  margin: 0 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--term-border);
}

.b64-text-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.b64-text-col {
  display: flex;
  flex-direction: column;
}

.b64-textarea {
  width: 100%;
  min-height: 180px;
  padding: 0.85rem 1rem;
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 0.85rem;
  line-height: 1.6;
  color: var(--term-fg);
  background: var(--term-bg);
  border: 1px solid var(--term-border);
  border-radius: 8px;
  resize: vertical;
  transition: border-color 0.25s ease, box-shadow 0.25s ease;
  box-sizing: border-box;
}
.b64-textarea:focus {
  outline: none;
  border-color: var(--syn-cyan);
  box-shadow: 0 0 12px rgba(34, 211, 238, 0.15);
}
.b64-textarea--sm {
  min-height: 100px;
}

.b64-text-actions {
  display: flex;
  gap: 0.6rem;
  flex-wrap: wrap;
  justify-content: center;
}

.b64-status {
  text-align: center;
  min-height: 1.4em;
}

.b64-dropzone {
  position: relative;
  border: 2px dashed rgba(34, 211, 238, 0.25);
  border-radius: 12px;
  padding: 2.5rem 1.5rem;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s ease;
  background: rgba(34, 211, 238, 0.02);
}
.b64-dropzone:hover {
  border-color: rgba(34, 211, 238, 0.4);
  background: rgba(34, 211, 238, 0.04);
}
.b64-dropzone--active {
  border-color: var(--syn-cyan, #22d3ee);
  background: rgba(34, 211, 238, 0.08);
  box-shadow: 0 0 24px rgba(34, 211, 238, 0.15), inset 0 0 24px rgba(34, 211, 238, 0.05);
}
.b64-dropzone__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  pointer-events: none;
}
.b64-dropzone__icon {
  margin-bottom: 0.25rem;
}
.b64-dropzone__text {
  font-size: 0.9rem;
  color: var(--term-fg, #e2e8f0);
  margin: 0;
  pointer-events: auto;
}
.b64-dropzone__browse {
  background: none;
  border: none;
  color: var(--syn-cyan, #22d3ee);
  text-decoration: underline;
  cursor: pointer;
  font-size: inherit;
  font-family: inherit;
  padding: 0;
  pointer-events: auto;
}
.b64-dropzone__browse:hover {
  color: #67e8f9;
}
.b64-dropzone__hint {
  font-size: 0.78rem;
  color: var(--term-muted, #64748b);
  margin: 0;
}

.b64-sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.b64-file-info--hidden {
  display: none !important;
}
.b64-file-info {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-top: 1rem;
}
.b64-file-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem 1.5rem;
  font-size: 0.82rem;
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  color: var(--term-fg);
}
.b64-file-meta__row {
  display: flex;
  gap: 0.4rem;
}
.b64-file-meta__label {
  color: var(--term-muted);
  font-weight: 600;
}

.b64-file-preview {
  display: flex;
  justify-content: center;
}
.b64-preview-img {
  max-width: 100%;
  max-height: 320px;
  border-radius: 8px;
  border: 1px solid var(--term-border);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  object-fit: contain;
}
.b64-preview-placeholder {
  font-size: 0.82rem;
  color: var(--term-muted);
  font-style: italic;
  margin: 0;
}

.b64-file-output {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.b64-file-actions {
  display: flex;
  gap: 0.6rem;
  flex-wrap: wrap;
}

.b64-decode-preview {
  display: flex;
  justify-content: center;
  margin-top: 0.75rem;
}

