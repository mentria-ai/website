---
layout: base.njk
permalink: /comms/index.html
eleventyExcludeFromCollections: true
title: comms (experimental)
description: Peer-to-peer chat and file drop — experimental, hidden by default.
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="/">~</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">comms</span></p>
  <h1>comms</h1>
  <p>Peer-to-peer chat and file drop. No accounts, no server in the middle. Share the URL to invite someone into the same room.</p>
</section>

{% set terminalTitle = "comms.js" %}
{% include "terminal-frame-open.njk" %}

<section class="comms">
  <div class="comms__bar">
    <div class="comms__room">
      <label class="comms__lbl" for="comms-room">room</label>
      <input class="comms__input" id="comms-room" type="text" autocomplete="off" spellcheck="false" inputmode="latin" lang="en" dir="ltr" autocapitalize="off" placeholder="!ephemeral">
      <button class="comms__btn" id="comms-join" type="button">join</button>
    </div>
    <div class="comms__meta">
      <span class="comms__badge" id="comms-status">disconnected</span>
      <span class="comms__badge comms__badge--peers" id="comms-peers" hidden>peers: 0</span>
      <span class="comms__badge comms__badge--eph" id="comms-eph" title="messages aren't saved (room starts with !)" hidden>ephemeral</span>
      <span class="comms__badge comms__badge--enc" id="comms-enc" title="end-to-end encrypted; the key is in the URL after the colon" hidden>encrypted</span>
      <button class="comms__btn comms__btn--ghost comms__btn--mute" id="comms-mute" type="button" aria-pressed="false">sound: on</button>
    </div>
  </div>

  <div class="comms__share" id="comms-share" hidden>
    <span class="comms__lbl">share</span>
    <code class="comms__url" id="comms-url"></code>
    <button class="comms__btn comms__btn--ghost" id="comms-copy" type="button">copy</button>
    <button class="comms__btn comms__btn--ghost" id="comms-genkey" type="button" title="generate a fresh encryption key and append it to the URL">+ key</button>
  </div>

  <div class="comms__peerlist" id="comms-peerlist" hidden></div>

  <div class="comms__log" id="comms-log" aria-live="polite" aria-relevant="additions"></div>

  <label class="comms__drop" id="comms-drop">
    <input type="file" id="comms-file" multiple hidden>
    drop files here, or click to choose — sent to everyone in the room
  </label>

  <button class="comms__btn comms__btn--ghost" id="comms-attach-ext" type="button">attach extension</button>

  <form class="comms__send" id="comms-send" autocomplete="off">
    <input class="comms__input comms__input--msg" id="comms-msg" type="text" placeholder="message…" disabled>
    <button class="comms__btn" id="comms-go" type="submit" disabled>send</button>
  </form>
</section>

{% include "terminal-frame-close.njk" %}

<style>
