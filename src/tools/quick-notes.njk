---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/quick-notes/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.quick-notes.title' | t }}"
  description: "{{ 'tools.quick-notes.lede' | t }}"
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><a class="eyebrow__link" href="{{ locale.pathPrefix }}/tools/">tools</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">quick-notes</span></p>
  <h1>{{ "tools.quick-notes.title" | t }}</h1>
  <p>{{ "tools.quick-notes.lede" | t }}</p>
  {% include "tldr.njk" %}
</section>

<!-- ── Quick Notes Tool ─────────────────────────────── -->
{% set terminalTitle = "quick-notes.js" %}
{% include "terminal-frame-open.njk" %}
<section class="qn-tool" id="qn-tool">
  <!-- Sidebar -->
  <aside class="qn-sidebar" id="qn-sidebar">
    <div class="qn-sidebar__header">
      <span class="qn-sidebar__label">{{ "tool.quick-notes.notes_label" | t }}</span>
      <button class="qn-sidebar__toggle" id="qn-sidebar-toggle" title="{{ 'tool.quick-notes.toggle_sidebar' | t }}" aria-label="{{ 'tool.quick-notes.toggle_sidebar' | t }}">
        <span class="qn-sidebar__toggle-icon"></span>
      </button>
    </div>
    <div class="qn-sidebar__list" id="qn-note-list">
      <!-- note tabs injected here -->
    </div>
    <button class="qn-sidebar__new" id="qn-new-btn" title="{{ 'tool.quick-notes.new_note_title' | t }}">
      <span>+</span> {{ "tool.quick-notes.new_note_btn" | t }}
    </button>
  </aside>

  <!-- Editor -->
  <div class="qn-editor" id="qn-editor">
    <div class="qn-editor__titlebar">
      <input
        type="text"
        class="qn-editor__title"
        id="qn-title-input"
        placeholder="{{ 'tool.quick-notes.untitled' | t }}"
        spellcheck="false"
        autocomplete="off"
      />
      <div class="qn-editor__actions">
        <button class="qn-action-btn" id="qn-export-btn" title="{{ 'tool.quick-notes.export_title' | t }}">{{ "tool.quick-notes.export_btn" | t }}</button>
        <button class="qn-action-btn" id="qn-share-btn" title="{{ 'common.share' | t }}">{{ "common.share" | t }}</button>
        <button class="qn-action-btn" id="qn-lock-btn" title="{{ 'tool.quick-notes.lock_title' | t }}">{{ "tool.quick-notes.lock_btn" | t }}</button>
        <button class="qn-action-btn qn-action-btn--danger" id="qn-delete-btn" title="{{ 'tool.quick-notes.delete_title' | t }}">{{ "tool.quick-notes.delete_btn" | t }}</button>
      </div>
    </div>
    <textarea
      class="qn-editor__textarea"
      id="qn-textarea"
      placeholder="{{ 'tool.quick-notes.start_typing' | t }}"
      spellcheck="false"
    ></textarea>
    <div class="qn-locked" id="qn-locked" hidden>
      <svg class="qn-locked__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="4" y="11" width="16" height="10" rx="2"/>
        <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
      </svg>
      <h2 class="qn-locked__heading">{{ "tool.quick-notes.locked_heading" | t }}</h2>
      <p class="qn-locked__body">{{ "tool.quick-notes.locked_body" | t }}</p>
      <button class="qn-unlock-btn" id="qn-unlock-btn">{{ "tool.quick-notes.unlock_btn" | t }}</button>
    </div>
    <div class="qn-editor__statusbar">
      <span class="qn-status__counts" id="qn-counts">{{ ('tool.quick-notes.count_summary' | t) | replace('{words}', '0') | replace('{chars}', '0') }}</span>
      <span class="qn-status__saved" id="qn-saved"></span>
    </div>
  </div>
</section>
{% include "terminal-frame-close.njk" %}

{% include "tool-schema.njk" %}

<script>
(() => {
  const COPY = {
    untitled:          {{ ("tool.quick-notes.untitled"           | t) | dump | safe }},
    savedPrefix:       {{ ("tool.quick-notes.saved_prefix"       | t) | dump | safe }},
    confirmDelete:     {{ ("tool.quick-notes.confirm_delete"     | t) | dump | safe }},
    lockBtn:           {{ ("tool.quick-notes.lock_btn"           | t) | dump | safe }},
    removeLockBtn:     {{ ("tool.quick-notes.remove_lock_btn"    | t) | dump | safe }},
    lockedTag:         {{ ("tool.quick-notes.locked_tag"         | t) | dump | safe }},
    confirmLock:       {{ ("tool.quick-notes.confirm_lock"       | t) | dump | safe }},
    confirmRemoveLock: {{ ("tool.quick-notes.confirm_remove_lock" | t) | dump | safe }},
    lockFailed:        {{ ("tool.quick-notes.lock_failed"        | t) | dump | safe }},
    unlockFailed:      {{ ("tool.quick-notes.unlock_failed"      | t) | dump | safe }},
    prfUnsupported:    {{ ("tool.quick-notes.prf_unsupported"    | t) | dump | safe }},
    countSummary:      {{ ("tool.quick-notes.count_summary"      | t) | dump | safe }}
  };

  const STORAGE_KEY = 'mentria-quick-notes';
  const DEBOUNCE_MS = 500;

  /* ── DOM refs ──────────────────────────────────────── */
  const noteList    = document.getElementById('qn-note-list');
  const newBtn      = document.getElementById('qn-new-btn');
  const titleInput  = document.getElementById('qn-title-input');
  const textarea    = document.getElementById('qn-textarea');
  const countsEl    = document.getElementById('qn-counts');
  const savedEl     = document.getElementById('qn-saved');
  const exportBtn   = document.getElementById('qn-export-btn');
  const shareBtn    = document.getElementById('qn-share-btn');
  const lockBtn     = document.getElementById('qn-lock-btn');
  const deleteBtn   = document.getElementById('qn-delete-btn');
  const lockedPanel = document.getElementById('qn-locked');
  const unlockBtn   = document.getElementById('qn-unlock-btn');
  const sidebar     = document.getElementById('qn-sidebar');
  const sidebarToggle = document.getElementById('qn-sidebar-toggle');

  /* ── State ─────────────────────────────────────────── */
  let notes = [];        // [{id, title, body, createdAt, updatedAt}]
  let activeId = null;
  let saveTimer = null;

  const CRED_KEY = 'mentria-qn-cred';
  const SALT_KEY = 'mentria-qn-salt';
  let sessionKey = null;
  const cryptoOK = !!(window.PublicKeyCredential && window.isSecureContext && window.crypto && crypto.subtle);

  /* ── Persistence ───────────────────────────────────── */
  function load() {
    if (window.MentriaStore) {
      const v = window.MentriaStore.get('quick_notes', 'blob');
      if (Array.isArray(v)) notes = v;
      else {
        try {
          const legacy = localStorage.getItem(STORAGE_KEY);
          if (legacy) {
            notes = JSON.parse(legacy);
            if (Array.isArray(notes)) {
              window.MentriaStore.set('quick_notes', 'blob', notes);
              localStorage.removeItem(STORAGE_KEY);
            }
          }
        } catch (_) {}
      }
    } else {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) notes = JSON.parse(raw);
      } catch (_) {}
    }
    if (!Array.isArray(notes) || notes.length === 0) {
      notes = [];
      createNote();
    }
  }

  function persist() {
    if (window.MentriaStore) return window.MentriaStore.set('quick_notes', 'blob', notes);
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(notes)); return true; } catch (_) { return false; }
  }

  function b64enc(buf) {
    const bytes = new Uint8Array(buf);
    let s = '';
    for (let i = 0; i < bytes.length; i++) s += String.fromCharCode(bytes[i]);
    return btoa(s);
  }
  function b64dec(str) {
    const bin = atob(str);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return bytes;
  }

  function prfSalt() {
    let s = window.MentriaStore ? window.MentriaStore.get('quick_notes', 'salt') : null;
    if (!s) {
      const legacy = localStorage.getItem(SALT_KEY);
      if (legacy) {
        s = legacy;
        if (window.MentriaStore) { window.MentriaStore.set('quick_notes', 'salt', s); localStorage.removeItem(SALT_KEY); }
      } else {
        s = b64enc(crypto.getRandomValues(new Uint8Array(32)));
        if (window.MentriaStore) window.MentriaStore.set('quick_notes', 'salt', s);
        else localStorage.setItem(SALT_KEY, s);
      }
    }
    return b64dec(s);
  }

  async function ensureKey() {
    if (sessionKey) return sessionKey;
    if (!cryptoOK) throw new Error('prf-unsupported');
    const salt = prfSalt();
    let credId = window.MentriaStore ? window.MentriaStore.get('quick_notes', 'cred_id') : null;
    if (!credId) {
      const legacy = localStorage.getItem(CRED_KEY);
      if (legacy) {
        credId = legacy;
        if (window.MentriaStore) { window.MentriaStore.set('quick_notes', 'cred_id', credId); localStorage.removeItem(CRED_KEY); }
      }
    }
    let prfResult = null;
    if (!credId) {
      const cred = await navigator.credentials.create({
        publicKey: {
          challenge: crypto.getRandomValues(new Uint8Array(32)),
          rp: { name: 'Mentria Quick Notes' },
          user: {
            id: crypto.getRandomValues(new Uint8Array(16)),
            name: 'quick-notes',
            displayName: 'Quick Notes'
          },
          pubKeyCredParams: [{ type: 'public-key', alg: -7 }, { type: 'public-key', alg: -257 }],
          authenticatorSelection: { residentKey: 'required', userVerification: 'required' },
          extensions: { prf: { eval: { first: salt } } }
        }
      });
      if (!cred) throw new Error('cancelled');
      const prf = cred.getClientExtensionResults().prf;
      if (!prf || prf.enabled === false) throw new Error('prf-unsupported');
      credId = b64enc(cred.rawId);
      if (window.MentriaStore) window.MentriaStore.set('quick_notes', 'cred_id', credId);
      else localStorage.setItem(CRED_KEY, credId);
      if (prf.results && prf.results.first) prfResult = prf.results.first;
    }
    if (!prfResult) {
      const assertion = await navigator.credentials.get({
        publicKey: {
          challenge: crypto.getRandomValues(new Uint8Array(32)),
          allowCredentials: [{ type: 'public-key', id: b64dec(credId) }],
          userVerification: 'required',
          extensions: { prf: { eval: { first: salt } } }
        }
      });
      if (!assertion) throw new Error('cancelled');
      const prf = assertion.getClientExtensionResults().prf;
      if (!prf || !prf.results || !prf.results.first) throw new Error('prf-unsupported');
      prfResult = prf.results.first;
    }
    sessionKey = await crypto.subtle.importKey(
      'raw', new Uint8Array(prfResult), { name: 'AES-GCM' }, false, ['encrypt', 'decrypt']
    );
    return sessionKey;
  }

  async function encryptText(text) {
    const key = await ensureKey();
    const iv = crypto.getRandomValues(new Uint8Array(12));
    const ct = await crypto.subtle.encrypt(
      { name: 'AES-GCM', iv: iv }, key, new TextEncoder().encode(text)
    );
    return { body: b64enc(ct), iv: b64enc(iv) };
  }

  async function decryptNote(note) {
    const key = await ensureKey();
    const pt = await crypto.subtle.decrypt(
      { name: 'AES-GCM', iv: b64dec(note.iv) }, key, b64dec(note.body)
    );
    return new TextDecoder().decode(pt);
  }

  function handleCryptoError(err, fallbackMsg) {
    if (err && err.name === 'NotAllowedError') return;
    if (err && err.message === 'prf-unsupported') { mentriaAlert(COPY.prfUnsupported); return; }
    if (err && err.message === 'cancelled') return;
    mentriaAlert(fallbackMsg);
  }

  /* ── Note CRUD ─────────────────────────────────────── */
  function genId() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 7);
  }

  function createNote() {
    const note = {
      id: genId(),
      title: '',
      body: '',
      createdAt: Date.now(),
      updatedAt: Date.now()
    };
    notes.unshift(note);
    persist();
    selectNote(note.id);
    renderList();
    titleInput.focus();
  }

  function deleteNote(id) {
    const idx = notes.findIndex(n => n.id === id);
    if (idx === -1) return;
    notes.splice(idx, 1);
    if (notes.length === 0) {
      createNote();
      return;
    }
    if (activeId === id) {
      selectNote(notes[0].id);
    }
    persist();
    renderList();
  }

  function getNote(id) {
    return notes.find(n => n.id === id) || null;
  }

  /* ── Selection ─────────────────────────────────────── */
  function selectNote(id) {
    if (id !== activeId) flushSave();
    activeId = id;
    const note = getNote(id);
    if (!note) return;
    renderEditor();
    renderList();
    // Collapse sidebar on mobile after selection
    if (window.innerWidth <= 640) {
      sidebar.classList.remove('qn-sidebar--open');
    }
  }

  async function renderEditor() {
    const note = getNote(activeId);
    if (!note) return;
    titleInput.value = note.title || '';
    let mode;
    if (!note.enc) {
      mode = 'plain';
      textarea.value = note.body || '';
    } else if (sessionKey) {
      mode = 'unlocked';
      try {
        const text = await decryptNote(note);
        if (activeId !== note.id) return;
        textarea.value = text;
      } catch (_) {
        mode = 'locked';
      }
    } else {
      mode = 'locked';
    }
    if (mode === 'locked') textarea.value = '';
    applyEditorMode(mode);
    updateCounts();
    updateSavedLabel(note.updatedAt);
  }

  function applyEditorMode(mode) {
    const locked = mode === 'locked';
    textarea.hidden = locked;
    lockedPanel.hidden = !locked;
    exportBtn.hidden = locked;
    shareBtn.hidden = locked || !navigator.share;
    if (!cryptoOK) {
      lockBtn.hidden = true;
    } else {
      lockBtn.hidden = locked;
      lockBtn.textContent = mode === 'unlocked' ? COPY.removeLockBtn : COPY.lockBtn;
    }
  }

  /* ── Sidebar Rendering ─────────────────────────────── */
  function renderList() {
    noteList.innerHTML = '';
    notes.forEach(note => {
      const btn = document.createElement('button');
      btn.className = 'qn-note-tab' + (note.id === activeId ? ' qn-note-tab--active' : '');
      btn.dataset.id = note.id;
      const title = note.title || COPY.untitled;
      let preview;
      if (note.enc) preview = '🔒 ' + COPY.lockedTag;
      else preview = note.body ? note.body.slice(0, 50).replace(/\n/g, ' ') : 'Empty';
      btn.innerHTML =
        '<span class="qn-note-tab__title">' + escHtml(title) + '</span>' +
        '<span class="qn-note-tab__preview">' + escHtml(preview) + '</span>';
      btn.addEventListener('click', () => selectNote(note.id));
      noteList.appendChild(btn);
    });
  }

  function escHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  /* ── Auto-save (debounced) ─────────────────────────── */
  function scheduleSave() {
    if (saveTimer) clearTimeout(saveTimer);
    saveTimer = setTimeout(() => { saveTimer = null; saveActive(); }, DEBOUNCE_MS);
  }

  function flushSave() {
    if (saveTimer) { clearTimeout(saveTimer); saveTimer = null; }
    return saveActive();
  }

  async function saveActive() {
    const note = getNote(activeId);
    if (!note) return;
    note.title = titleInput.value;
    if (note.enc) {
      if (!sessionKey) return;
      try {
        const enc = await encryptText(textarea.value);
        note.body = enc.body;
        note.iv = enc.iv;
      } catch (_) { return; }
    } else {
      note.body = textarea.value;
    }
    note.updatedAt = Date.now();
    const ok = persist();
    if (ok && note.id === activeId) updateSavedLabel(note.updatedAt);
    renderList();
  }

  /* ── Counts ────────────────────────────────────────── */
  const wordSegmenter = (() => {
    try { return new Intl.Segmenter(document.documentElement.lang || undefined, { granularity: 'word' }); }
    catch (_) { return null; }
  })();

  function countWords(text) {
    const t = text.trim();
    if (t === '') return 0;
    if (wordSegmenter) {
      let n = 0;
      for (const seg of wordSegmenter.segment(t)) if (seg.isWordLike) n++;
      return n;
    }
    return t.split(/\s+/).length;
  }

  function updateCounts() {
    const text = textarea.value;
    const chars = text.length;
    const words = countWords(text);
    countsEl.textContent = COPY.countSummary.replace('{words}', words).replace('{chars}', chars);
  }

  /* ── Saved label ───────────────────────────────────── */
  function updateSavedLabel(ts) {
    if (!ts) { savedEl.textContent = ''; return; }
    const d = new Date(ts);
    const hh = String(d.getHours()).padStart(2, '0');
    const mm = String(d.getMinutes()).padStart(2, '0');
    const ss = String(d.getSeconds()).padStart(2, '0');
    savedEl.textContent = COPY.savedPrefix + ' ' + hh + ':' + mm + ':' + ss;
  }

  /* ── Export ────────────────────────────────────────── */
  function exportNote() {
    const note = getNote(activeId);
    if (!note) return;
    const title = titleInput.value.trim() || COPY.untitled;
    const filename = title.replace(/[\/\\:*?"<>|\s]/g, '_') + '.txt';
    const blob = new Blob([textarea.value], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    setTimeout(() => { document.body.removeChild(a); URL.revokeObjectURL(url); }, 100);
  }

  /* ── Share active note ─────────────────────────────── */
  async function shareNote() {
    const note = getNote(activeId);
    if (!note || !textarea.value) return;
    try {
      await navigator.share({ title: titleInput.value.trim() || COPY.untitled, text: textarea.value });
    } catch (_) { /* dismissed */ }
  }

  function handleLockClick() {
    const note = getNote(activeId);
    if (!note) return;
    if (note.enc) removeLock();
    else lockNote();
  }

  async function lockNote() {
    const note = getNote(activeId);
    if (!note || note.enc) return;
    if (!cryptoOK) { mentriaAlert(COPY.prfUnsupported); return; }
    if (!(await mentriaConfirm(COPY.confirmLock))) return;
    let enc;
    try {
      enc = await encryptText(textarea.value);
    } catch (err) {
      handleCryptoError(err, COPY.lockFailed);
      return;
    }
    note.title = titleInput.value;
    note.enc = true;
    note.body = enc.body;
    note.iv = enc.iv;
    note.updatedAt = Date.now();
    persist();
    renderEditor();
    renderList();
  }

  async function unlockNote() {
    const note = getNote(activeId);
    if (!note || !note.enc) return;
    try {
      await ensureKey();
    } catch (err) {
      handleCryptoError(err, COPY.unlockFailed);
      return;
    }
    renderEditor();
  }

  async function removeLock() {
    const note = getNote(activeId);
    if (!note || !note.enc) return;
    if (!(await mentriaConfirm(COPY.confirmRemoveLock))) return;
    note.enc = false;
    note.body = textarea.value;
    delete note.iv;
    note.updatedAt = Date.now();
    persist();
    renderEditor();
    renderList();
  }

  /* ── Delete with confirmation ──────────────────────── */
  async function confirmDelete() {
    const note = getNote(activeId);
    if (!note) return;
    const name = note.title || COPY.untitled;
    if (await mentriaConfirm(COPY.confirmDelete.replace('{name}', name))) {
      deleteNote(activeId);
    }
  }

  /* ── Sidebar toggle (mobile) ───────────────────────── */
  function toggleSidebar() {
    sidebar.classList.toggle('qn-sidebar--open');
  }

  /* ── Events ────────────────────────────────────────── */
  textarea.addEventListener('input', () => {
    updateCounts();
    scheduleSave();
  });

  titleInput.addEventListener('input', () => {
    scheduleSave();
  });

  newBtn.addEventListener('click', createNote);
  exportBtn.addEventListener('click', exportNote);
  if (navigator.share) shareBtn.addEventListener('click', shareNote);
  else shareBtn.hidden = true;
  lockBtn.addEventListener('click', handleLockClick);
  unlockBtn.addEventListener('click', unlockNote);
  deleteBtn.addEventListener('click', confirmDelete);
  sidebarToggle.addEventListener('click', toggleSidebar);

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') flushSave();
  });
  window.addEventListener('pagehide', () => { flushSave(); });

  function ingestSharedContent() {
    let p;
    try { p = new URLSearchParams(location.search); } catch (_) { return false; }
    const title = (p.get('title') || '').trim();
    const text  = (p.get('text')  || '').trim();
    const url   = (p.get('url')   || '').trim();
    if (!title && !text && !url) return false;
    const note = {
      id: genId(),
      title: title,
      body: [text, url].filter(Boolean).join('\n\n'),
      createdAt: Date.now(),
      updatedAt: Date.now()
    };
    notes.unshift(note);
    persist();
    history.replaceState(null, '', location.pathname);
    activeId = note.id;
    return true;
  }

  /* ── Boot ───────────────────────────────────────────── */
  load();
  if (ingestSharedContent()) {
    selectNote(activeId);
  } else if (activeId === null && notes.length > 0) {
    selectNote(notes[0].id);
  }
  renderList();
})();
</script>

<style>
/* ── Tool Container ───────────────────────────────── */
.qn-tool {
  display: flex;
  min-height: 520px;
  max-height: 80vh;
  background: var(--term-bg, #0a0a0a);
  border-radius: 8px;
  overflow: hidden;
}

/* ── Sidebar ──────────────────────────────────────── */
.qn-sidebar {
  width: 220px;
  min-width: 220px;
  background: var(--term-bg-raised, #111111);
  border-right: 1px solid var(--term-border, rgba(255,255,255,0.06));
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.qn-sidebar__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 0.85rem;
  border-bottom: 1px solid var(--term-border, rgba(255,255,255,0.06));
}

.qn-sidebar__label {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--syn-cyan, #22d3ee);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.qn-sidebar__toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.25rem;
}

.qn-sidebar__toggle-icon {
  display: block;
  width: 18px;
  height: 2px;
  background: var(--term-muted, #64748b);
  position: relative;
  transition: background 0.2s;
}
.qn-sidebar__toggle-icon::before,
.qn-sidebar__toggle-icon::after {
  content: '';
  position: absolute;
  left: 0;
  width: 100%;
  height: 2px;
  background: var(--term-muted, #64748b);
  transition: transform 0.2s;
}
.qn-sidebar__toggle-icon::before { top: -6px; }
.qn-sidebar__toggle-icon::after  { top: 6px; }

.qn-sidebar__list {
  flex: 1;
  overflow-y: auto;
  padding: 0.5rem 0;
}

/* ── Note Tabs ────────────────────────────────────── */
.qn-note-tab {
