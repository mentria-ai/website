      if (scanScanner.detector) {
        try { var codes = await scanScanner.detector.detect(scanVideo); if (codes && codes.length) rawValue = codes[0].rawValue; } catch (_) {}
      } else if (scanScanner.useJsQR) {
        rawValue = scanJsqrDecode(scanVideo);
      }
      if (!rawValue) return;
      var extracted = extractCode(rawValue);
      var norm = String(extracted).toUpperCase().replace(/[^A-Z2-7]/g, '');
      if (norm.length < 16) { showScanNote(COPY.codeInvalid); return; }
      if (navigator.vibrate) try { navigator.vibrate(40); } catch (_) {}
      codeInput.value = formatSyncCode(rawValue);
      stopScan();
      joinBtn.click();
    }
    scanBtn.addEventListener('click', async function () {
      showScanNote('');
      scanPanel.hidden = false;
      if (!window.isSecureContext) { showScanNote(COPY.scanSecureRequired); return; }
      if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) { showScanNote(COPY.scanNoCamera); return; }
      var ok = await initScanDetector();
      if (!ok) { showScanNote(COPY.scanUnsupported); return; }
      try {
        scanScanner.stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
      } catch (err) {
        var name = err && err.name;
        if (name === 'NotAllowedError' || name === 'SecurityError') showScanNote(COPY.scanDenied);
        else if (name === 'NotFoundError' || name === 'OverconstrainedError') showScanNote(COPY.scanNoCamera);
        else showScanNote(String(err && err.message || err));
        return;
      }
      scanVideo.srcObject = scanScanner.stream;
      try { await scanVideo.play(); } catch (_) {}
      scanScanner.scanning = true;
      scanScanner.lastDetect = 0;
      scanScanner.rafId = requestAnimationFrame(scanLoop);
    });
    scanCancel.addEventListener('click', function () { stopScan(); });
  })();

  (function () {
    var COPY = {
      statusNone:     {{ ('about.identity_status_none'    | t) | dump | safe }},
      statusLocked:   {{ ('about.identity_status_locked'  | t) | dump | safe }},
      statusUnlocked: {{ ('about.identity_status_unlocked'| t) | dump | safe }},
      ledeNone:       {{ ('about.identity_lede_none'      | t) | dump | safe }},
      ledeLocked:     {{ ('about.identity_lede_locked'    | t) | dump | safe }},
      ledeUnlocked:   {{ ('about.identity_lede_unlocked'  | t) | dump | safe }},
      mismatch:       {{ ('about.identity_mismatch'       | t) | dump | safe }},
      tooShort:       {{ ('about.identity_too_short'      | t) | dump | safe }},
      unlockFailed:   {{ ('about.identity_unlock_failed'  | t) | dump | safe }},
      setupReminder:  {{ ('about.identity_setup_reminder' | t) | dump | safe }}
    };
    var statusEl = document.getElementById('about-identity-status');
    var ledeEl   = document.getElementById('about-identity-lede');
    var setupBox  = document.getElementById('about-identity-setup');
    var unlockBox = document.getElementById('about-identity-unlock');
    var unlockedBox = document.getElementById('about-identity-unlocked');
    var setupBtn = document.getElementById('about-identity-setup-btn');
    var setupPass = document.getElementById('about-identity-setup-pass');
    var setupPass2 = document.getElementById('about-identity-setup-pass2');
    var unlockBtn = document.getElementById('about-identity-unlock-btn');
    var unlockPass = document.getElementById('about-identity-unlock-pass');
    var lockBtn = document.getElementById('about-identity-lock-btn');
    var syncBtn = document.getElementById('about-identity-sync-btn');
    if (!setupBtn) return;

    function waitFor(name, cb) {
      if (window[name]) return cb();
      var t = 0;
      var iv = setInterval(function () {
        if (window[name]) { clearInterval(iv); cb(); }
        else if (++t > 60) clearInterval(iv);
      }, 100);
    }

    function refresh() {
      var setUp = window.MentriaIdentity && window.MentriaIdentity.isSetUp();
      var unlocked = window.MentriaIdentity && window.MentriaIdentity.isUnlocked();
      setupBox.hidden = setUp;
      unlockBox.hidden = !setUp || unlocked;
      unlockedBox.hidden = !unlocked;
      if (!setUp) {
        statusEl.textContent = COPY.statusNone;
        delete statusEl.dataset.tone;
        ledeEl.textContent = COPY.ledeNone;
      } else if (unlocked) {
        statusEl.textContent = COPY.statusUnlocked;
        statusEl.dataset.tone = 'ok';
        ledeEl.textContent = COPY.ledeUnlocked;
      } else {
        statusEl.textContent = COPY.statusLocked;
        statusEl.dataset.tone = 'locked';
        ledeEl.textContent = COPY.ledeLocked;
      }
    }
    waitFor('MentriaIdentity', refresh);

    setupBtn.addEventListener('click', async function () {
      var p1 = setupPass.value, p2 = setupPass2.value;
      if (p1.length < 8) { alert(COPY.tooShort); return; }
      if (p1 !== p2) { alert(COPY.mismatch); return; }
      setupBtn.disabled = true;
      try {
        await window.MentriaIdentity.setup(p1);
        setupPass.value = ''; setupPass2.value = '';
        refresh();
        alert(COPY.setupReminder);
      } catch (err) {
        alert(String(err && err.message || err));
      } finally { setupBtn.disabled = false; }
    });

    unlockBtn.addEventListener('click', async function () {
      var p = unlockPass.value;
      if (!p) return;
      unlockBtn.disabled = true;
      try {
        await window.MentriaIdentity.unlock(p);
        unlockPass.value = '';
        refresh();
      } catch (err) {
        alert(COPY.unlockFailed);
      } finally { unlockBtn.disabled = false; }
    });

    lockBtn.addEventListener('click', function () {
      window.MentriaIdentity.lock();
      refresh();
    });

    syncBtn.addEventListener('click', async function () {
      if (!window.MentriaSync) return;
      syncBtn.disabled = true;
      try {
        var secret = window.MentriaIdentity.getSecret();
        await window.MentriaSync.joinWithIdentity(secret);
      } catch (err) {
        alert(String(err && err.message || err));
      } finally { syncBtn.disabled = false; }
    });
  })();
</script>
