---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/countdown-timer/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.countdown-timer.title' | t }}"
  description: "{{ 'tools.countdown-timer.lede' | t }}"
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><a class="eyebrow__link" href="{{ locale.pathPrefix }}/tools/">tools</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">countdown-timer</span></p>
  <h1>{{ "tools.countdown-timer.title" | t }}</h1>
  <p>{{ "tools.countdown-timer.lede" | t }}</p>
  {% include "tldr.njk" %}
</section>

<!-- ── Widget Grid ────────────────────────────────────── -->
{% set terminalTitle = "countdown-timer.js" %}
{% include "terminal-frame-open.njk" %}
<section class="countdown-tool">
  <div class="ct-notif-bar" id="ct-notif-bar" role="status" aria-live="polite">
    <span class="ct-notif-dot" id="ct-notif-dot" aria-hidden="true"></span>
    <span class="ct-notif-text" id="ct-notif-text">{{ "tool.countdown-timer.notif_check" | t }}</span>
    <span class="ct-notif-actions">
      <button class="ct-notif-btn" id="ct-notif-enable" hidden>{{ "tool.countdown-timer.notif_enable_btn" | t }}</button>
      <button class="ct-notif-btn ct-notif-btn--ghost" id="ct-notif-test" hidden>{{ "tool.countdown-timer.notif_test_btn" | t }}</button>
    </span>
  </div>

  <div class="ct-grid" id="ct-grid">
    <!-- widgets injected here -->
  </div>
  <button class="ct-add-btn" id="ct-add-btn" title="{{ 'tool.countdown-timer.btn_add_timer' | t }}">
    <span class="ct-add-btn__icon">+</span>
    <span>{{ "tool.countdown-timer.btn_add_timer" | t }}</span>
  </button>
</section>
{% include "terminal-frame-close.njk" %}

<!-- ── Widget Template ───────────────────────────────── -->
<template id="ct-widget-tpl">
  <div class="ct-widget" data-widget-id="">
    <button class="ct-widget__close" title="{{ 'tool.countdown-timer.btn_remove_timer' | t }}">&times;</button>

    <div class="ct-widget__title" contenteditable="true" spellcheck="false" data-placeholder="Timer"></div>

    <!-- Display -->
    <div class="ct-widget__display-wrap">
      <div class="ct-widget__display">
        <span class="ct-widget__seg" data-role="hours">00</span>
        <span class="ct-widget__colon">:</span>
        <span class="ct-widget__seg" data-role="mins">00</span>
        <span class="ct-widget__colon">:</span>
        <span class="ct-widget__seg" data-role="secs">00</span>
      </div>
      <div class="ct-widget__status">{{ "tool.countdown-timer.status_ready" | t }}</div>
    </div>

    <div class="ct-widget__mode-toggle">
      <button class="ct-mode-btn ct-mode-btn--active" data-mode="duration">{{ "tool.countdown-timer.mode_duration" | t }}</button>
      <button class="ct-mode-btn" data-mode="datetime">{{ "tool.countdown-timer.mode_datetime" | t }}</button>
    </div>

    <div class="ct-widget__inputs" data-panel="duration">
      <div class="ct-input-grp">
        <label>{{ "tool.countdown-timer.input_hours" | t }}</label>
        <input type="number" data-input="hours" min="0" max="99" value="0" />
      </div>
      <div class="ct-input-grp">
        <label>{{ "tool.countdown-timer.input_minutes" | t }}</label>
        <input type="number" data-input="mins" min="0" max="59" value="0" />
      </div>
      <div class="ct-input-grp">
        <label>{{ "tool.countdown-timer.input_seconds" | t }}</label>
        <input type="number" data-input="secs" min="0" max="59" value="0" />
      </div>
    </div>

    <div class="ct-widget__inputs ct-widget__inputs--hidden" data-panel="datetime">
      <div class="ct-input-grp ct-input-grp--wide">
        <label>{{ "tool.countdown-timer.input_until_label" | t }}</label>
        <input type="datetime-local" data-input="datetime" />
      </div>
      <div class="ct-widget__dt-error" data-role="dt-error"></div>
    </div>

    <div class="ct-widget__presets">
      <span>{{ "tool.countdown-timer.presets_label" | t }}</span>
      <button class="ct-preset" data-seconds="60">{{ "tool.countdown-timer.preset_1min" | t }}</button>
      <button class="ct-preset" data-seconds="300">{{ "tool.countdown-timer.preset_5min" | t }}</button>
      <button class="ct-preset" data-seconds="600">{{ "tool.countdown-timer.preset_10min" | t }}</button>
      <button class="ct-preset" data-seconds="1500">{{ "tool.countdown-timer.preset_25min" | t }}</button>
      <button class="ct-preset" data-seconds="3600">{{ "tool.countdown-timer.preset_1hr" | t }}</button>
    </div>

    <div class="ct-widget__controls">
      <button class="ct-btn ct-btn--primary" data-action="start">{{ "tool.countdown-timer.btn_start" | t }}</button>
      <button class="ct-btn ct-btn--secondary" data-action="pause" disabled>{{ "tool.countdown-timer.btn_pause" | t }}</button>
      <button class="ct-btn ct-btn--ghost" data-action="reset" disabled>{{ "tool.countdown-timer.btn_reset" | t }}</button>
    </div>
  </div>
</template>

{% include "tool-schema.njk" %}

<script>
(() => {
  const COPY = {
    statusReady:    {{ ("tool.countdown-timer.status_ready"     | t) | dump | safe }},
    statusRunning:  {{ ("tool.countdown-timer.status_running"   | t) | dump | safe }},
    statusPaused:   {{ ("tool.countdown-timer.status_paused"    | t) | dump | safe }},
    statusTimesUp:  {{ ("tool.countdown-timer.status_times_up"  | t) | dump | safe }},
    btnStart:       {{ ("tool.countdown-timer.btn_start"        | t) | dump | safe }},
    btnPause:       {{ ("tool.countdown-timer.btn_pause"        | t) | dump | safe }},
    btnResume:      {{ ("tool.countdown-timer.btn_resume"       | t) | dump | safe }},
    errPickDt:      {{ ("tool.countdown-timer.err_pick_dt"      | t) | dump | safe }},
    errPassed:      {{ ("tool.countdown-timer.err_passed"       | t) | dump | safe }},
    errMax99:       {{ ("tool.countdown-timer.err_max_99"       | t) | dump | safe }},
    errSetTime:     {{ ("tool.countdown-timer.err_set_time"     | t) | dump | safe }},
    errMax99Brief:  {{ ("tool.countdown-timer.err_max_99_brief" | t) | dump | safe }},
    timerDefault:   {{ ("tool.countdown-timer.timer_default"    | t) | dump | safe }},
    titleAlarm:     {{ ("tool.countdown-timer.title_alarm"      | t) | dump | safe }},
    titleRunFmt:    {{ ("tool.countdown-timer.title_running_format" | t) | dump | safe }},
    notifUnsup:     {{ ("tool.countdown-timer.notif_unsupported" | t) | dump | safe }},
    notifDefault:   {{ ("tool.countdown-timer.notif_default"    | t) | dump | safe }},
    notifGranted:   {{ ("tool.countdown-timer.notif_granted"    | t) | dump | safe }},
    notifDenied:    {{ ("tool.countdown-timer.notif_denied"     | t) | dump | safe }},
    notifOnTitle:   {{ ("tool.countdown-timer.notif_on_title"   | t) | dump | safe }},
    notifOnBody:    {{ ("tool.countdown-timer.notif_on_body"    | t) | dump | safe }},
    notifTestTitle: {{ ("tool.countdown-timer.notif_test_title" | t) | dump | safe }},
    notifTestBody:  {{ ("tool.countdown-timer.notif_test_body"  | t) | dump | safe }},
    notifFinishFmt: {{ ("tool.countdown-timer.notif_finished_format" | t) | dump | safe }},
    notifBodyOpen:  {{ ("tool.countdown-timer.notif_body_open"  | t) | dump | safe }},
    notifStopAlarm: {{ ("tool.countdown-timer.notif_stop_alarm" | t) | dump | safe }}
  };
  const fmtTimer = n => COPY.timerDefault.replace('{n}', n);

  const MAX_WIDGETS = 4;
  const MAX_SECONDS = 99 * 3600; // 99 hours
  const grid = document.getElementById('ct-grid');
  const addBtn = document.getElementById('ct-add-btn');
  const tpl = document.getElementById('ct-widget-tpl');
  const originalTitle = document.title;

  let nextId = 1;
  const widgets = new Map(); // id → state

  /* ── Notifications ─────────────────────────────────── */
  // Wires the system notification tray to timer expiry. When the tab is
  // hidden and a timer hits 0, we show a system notification via the
  // service worker registration so it survives the page being backgrounded.
  // Notification clicks/actions post a message back to focus + stop alarm.
  const NOTIF_ICON  = '/assets/img/icon-192x192.png';
  const NOTIF_BADGE = '/assets/img/badge.svg';
  const NOTIF_TAG_PREFIX = 'mentria-timer-';

  const notifBar    = document.getElementById('ct-notif-bar');
  const notifText   = document.getElementById('ct-notif-text');
  const notifEnable = document.getElementById('ct-notif-enable');
  const notifTest   = document.getElementById('ct-notif-test');

  function notifSupported() {
    return 'Notification' in window && 'serviceWorker' in navigator;
  }
  function notifState() {
    if (!notifSupported()) return 'unsupported';
    return Notification.permission; // 'granted' | 'denied' | 'default'
  }

  function refreshNotifBar() {
    const s = notifState();
    notifBar.classList.toggle('is-unsupported', s === 'unsupported');
    notifBar.classList.toggle('is-granted',     s === 'granted');
    notifBar.classList.toggle('is-denied',      s === 'denied');
    notifEnable.hidden = (s !== 'default');
    notifTest.hidden   = (s !== 'granted');
    if (s === 'unsupported')  notifText.textContent = COPY.notifUnsup;
    else if (s === 'default') notifText.textContent = COPY.notifDefault;
    else if (s === 'granted') notifText.textContent = COPY.notifGranted;
    else if (s === 'denied')  notifText.textContent = COPY.notifDenied;
  }

  async function requestNotifPermission() {
    if (!notifSupported()) return;
    try {
      const result = await Notification.requestPermission();
      refreshNotifBar();
      if (result === 'granted') {
        if (window.MentriaPush) await MentriaPush.requestPermission();
        await showRawNotification(COPY.notifOnTitle, {
          body: COPY.notifOnBody,
          tag: 'mentria-timer-welcome',
          silent: true,
        });
      }
    } catch (e) { console.error('Notification permission request failed:', e); }
  }

  async function showRawNotification(title, options = {}) {
    if (notifState() !== 'granted') return;
    if (!('serviceWorker' in navigator)) return;
    try {
      const reg = await navigator.serviceWorker.ready;
      const payload = Object.assign({
        icon:  NOTIF_ICON,
        badge: NOTIF_BADGE,
        vibrate: [200, 100, 200],
      }, options);
      return reg.showNotification(title, payload);
    } catch (e) { console.error('showNotification failed:', e); }
  }

  async function notifyTimerFinished(state, label) {
    if (notifState() !== 'granted') return;
    // Only notify when the tab is hidden — visible tabs already have the
    // in-page alarm + flash + page-title flag. Notifying both ways is noisy.
    if (!document.hidden) return;
    await showRawNotification(COPY.notifFinishFmt.replace('{label}', label), {
      body: COPY.notifBodyOpen,
      tag:  NOTIF_TAG_PREFIX + state.id,
      renotify: true,
      requireInteraction: true,
      data: { url: location.pathname, timerId: state.id },
      actions: [
        { action: 'stop-alarm', title: COPY.notifStopAlarm }
      ],
    });
  }

  async function testNotification() {
    if (notifState() !== 'granted') return;
    await showRawNotification(COPY.notifTestTitle, {
      body: COPY.notifTestBody,
      tag: 'mentria-timer-test',
      data: { url: location.pathname },
    });
  }

  // Listen for messages from the service worker (notification action clicks)
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.addEventListener('message', (event) => {
      if (!event.data) return;
      if (event.data.type === 'STOP_ALARM') {
        const id = event.data.timerId;
        if (id != null) {
          const state = widgets.get(id);
          if (state) stopAlarmFor(state);
        } else {
          for (const [, s] of widgets) stopAlarmFor(s);
        }
        updatePageTitle();
      }
    });
  }

  notifEnable.addEventListener('click', requestNotifPermission);
  notifTest.addEventListener('click', testNotification);
  // Refresh on visibility change — picks up permission changes made elsewhere.
  document.addEventListener('visibilitychange', refreshNotifBar);
  refreshNotifBar();

  /* ── Audio ─────────────────────────────────────────── */
  let audioCtx = null;

  function initAudio() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    return audioCtx;
  }

  function playBellOnce() {
    const ctx = initAudio();
    const dur = 0.15, gap = 0.08;
    for (let i = 0; i < 4; i++) {
      const t = ctx.currentTime + i * (dur + gap);
      const osc = ctx.createOscillator();
      const g = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.setValueAtTime(880, t);
      osc.frequency.exponentialRampToValueAtTime(440, t + dur);
      g.gain.setValueAtTime(0.4, t);
      g.gain.exponentialRampToValueAtTime(0.01, t + dur);
      osc.connect(g); g.connect(ctx.destination);
      osc.start(t); osc.stop(t + dur);

      const osc2 = ctx.createOscillator();
      const g2 = ctx.createGain();
      osc2.type = 'sine';
      osc2.frequency.setValueAtTime(1760, t);
      osc2.frequency.exponentialRampToValueAtTime(880, t + dur);
      g2.gain.setValueAtTime(0.2, t);
      g2.gain.exponentialRampToValueAtTime(0.01, t + dur);
      osc2.connect(g2); g2.connect(ctx.destination);
      osc2.start(t); osc2.stop(t + dur);
    }
  }

  function startAlarmFor(state) {
    if (state.isAlarming) return;
    state.isAlarming = true;
    playBellOnce();
    state.alarmInterval = setInterval(() => { if (state.isAlarming) playBellOnce(); }, 1200);
  }

  function stopAlarmFor(state) {
    state.isAlarming = false;
    if (state.alarmInterval) { clearInterval(state.alarmInterval); state.alarmInterval = null; }
  }

  /* ── Helpers ───────────────────────────────────────── */
  const pad = n => String(n).padStart(2, '0');

  function updatePageTitle() {
    for (const [, s] of widgets) {
      if (s.countdown && s.totalSeconds > 0) {
        const h = Math.floor(s.totalSeconds / 3600);
        const m = Math.floor((s.totalSeconds % 3600) / 60);
        const sc = s.totalSeconds % 60;
        document.title = COPY.titleRunFmt.replace('{time}', `${pad(h)}:${pad(m)}:${pad(sc)}`);
        return;
      }
    }
    for (const [, s] of widgets) {
      if (s.isAlarming) { document.title = COPY.titleAlarm; return; }
    }
    document.title = originalTitle;
  }

  function refreshAddBtn() {
    addBtn.style.display = widgets.size >= MAX_WIDGETS ? 'none' : '';
  }

  /* ── Widget Lifecycle ──────────────────────────────── */

  function addWidget() {
    if (widgets.size >= MAX_WIDGETS) return;
    const id = nextId++;
    const el = tpl.content.firstElementChild.cloneNode(true);
    el.dataset.widgetId = id;

    const titleEl = el.querySelector('.ct-widget__title');
    titleEl.textContent = fmtTimer(widgets.size + 1);
    titleEl.dataset.isDefault = '1';

    // Scoped refs
    const $ = sel => el.querySelector(sel);
    const $$ = sel => el.querySelectorAll(sel);

    const displayH = $('[data-role="hours"]');
    const displayM = $('[data-role="mins"]');
    const displayS = $('[data-role="secs"]');
    const statusEl = $('.ct-widget__status');
    const displayWrap = $('.ct-widget__display');
    const panelDuration = $('[data-panel="duration"]');
    const panelDatetime = $('[data-panel="datetime"]');
    const inputH = $('[data-input="hours"]');
    const inputM = $('[data-input="mins"]');
    const inputS = $('[data-input="secs"]');
    const inputDT = $('[data-input="datetime"]');
    const dtError = $('[data-role="dt-error"]');
    const btnStart = $('[data-action="start"]');
    const btnPause = $('[data-action="pause"]');
    const btnReset = $('[data-action="reset"]');
    const btnClose = $('.ct-widget__close');
    const modeButtons = $$('.ct-mode-btn');

    const state = {
      id,
      totalSeconds: 0,
      countdown: null,
      isPaused: false,
      isAlarming: false,
      alarmInterval: null,
      mode: 'duration', // 'duration' | 'datetime'
    };

    widgets.set(id, state);

    // ── Display ──
    function updateDisplay() {
      const h = Math.floor(state.totalSeconds / 3600);
      const m = Math.floor((state.totalSeconds % 3600) / 60);
      const s = state.totalSeconds % 60;
      displayH.textContent = pad(h);
      displayM.textContent = pad(m);
      displayS.textContent = pad(s);
      updatePageTitle();
    }

    // ── Tick ──
    function tick() {
      if (state.totalSeconds > 0) {
        state.totalSeconds--;
        updateDisplay();
      } else {
        clearInterval(state.countdown);
        state.countdown = null;
        statusEl.textContent = COPY.statusTimesUp;
        displayWrap.classList.add('ct-widget__display--finished');
        startAlarmFor(state);
        btnPause.disabled = true;
        btnStart.textContent = COPY.btnStart;
        btnStart.disabled = true;
        btnReset.disabled = false;
        updatePageTitle();
        const label = (titleEl.textContent || '').trim() || fmtTimer(state.id);
        notifyTimerFinished(state, label);
        disarmServerPush(state);
      }
    }

    function pushSpecFor(state) {
      const label = (titleEl.textContent || '').trim() || fmtTimer(state.id);
      return {
        id: 'ct-' + state.id,
        fireAt: Date.now() + state.totalSeconds * 1000,
        title: COPY.notifFinishFmt.replace('{label}', label),
        body: COPY.notifBodyOpen,
        url: '/tools/countdown-timer/',
        tag: NOTIF_TAG_PREFIX + state.id
      };
    }
    function armServerPush(state) {
      if (window.MentriaPush && MentriaPush.permission() === 'granted' && state.totalSeconds > 0) {
        MentriaPush.schedule(pushSpecFor(state));
      }
    }
    function disarmServerPush(state) {
      if (window.MentriaPush) MentriaPush.cancel('ct-' + state.id);
    }

    // ── Compute seconds from datetime ──
    function getSecondsFromDatetime() {
      const val = inputDT.value;
      if (!val) { dtError.textContent = COPY.errPickDt; return -1; }
      const target = new Date(val).getTime();
      const diff = Math.floor((target - Date.now()) / 1000);
      if (diff <= 0) { dtError.textContent = COPY.errPassed; return -1; }
      if (diff > MAX_SECONDS) { dtError.textContent = COPY.errMax99; return -1; }
      dtError.textContent = '';
      return diff;
    }

    // ── Start / Pause / Resume ──
    function startTimer() {
      initAudio();

      if (state.countdown) {
        clearInterval(state.countdown);
        state.countdown = null;
        state.isPaused = true;
        disarmServerPush(state);
        btnStart.textContent = COPY.btnResume;
        btnPause.disabled = true;
        statusEl.textContent = COPY.statusPaused;
        return;
      }

      if (state.isPaused && state.totalSeconds > 0) {
        state.isPaused = false;
        state.countdown = setInterval(tick, 1000);
        armServerPush(state);
        btnStart.textContent = COPY.btnPause;
        btnPause.disabled = false;
        statusEl.textContent = COPY.statusRunning;
        return;
      }

      // New start
      if (state.mode === 'datetime') {
        const secs = getSecondsFromDatetime();
        if (secs < 0) return;
        state.totalSeconds = secs;
      } else {
        const h = parseInt(inputH.value) || 0;
        const m = parseInt(inputM.value) || 0;
        const s = parseInt(inputS.value) || 0;
        state.totalSeconds = h * 3600 + m * 60 + s;
      }

      if (state.totalSeconds <= 0) {
        statusEl.textContent = COPY.errSetTime;
        setTimeout(() => { if (!state.countdown) statusEl.textContent = COPY.statusReady; }, 2000);
        return;
      }
      if (state.totalSeconds > MAX_SECONDS) {
        statusEl.textContent = COPY.errMax99Brief;
        setTimeout(() => { if (!state.countdown) statusEl.textContent = COPY.statusReady; }, 2000);
        return;
      }

      displayWrap.classList.remove('ct-widget__display--finished');
      statusEl.textContent = COPY.statusRunning;
      updateDisplay();
      state.countdown = setInterval(tick, 1000);
      armServerPush(state);
      btnStart.textContent = COPY.btnPause;
      btnPause.disabled = false;
      btnReset.disabled = false;
      panelDuration.classList.add('ct-widget__inputs--hidden');
      panelDatetime.classList.add('ct-widget__inputs--hidden');
    }

    function resetTimer() {
      stopAlarmFor(state);
      if (state.countdown) { clearInterval(state.countdown); state.countdown = null; }
      disarmServerPush(state);
      state.isPaused = false;
      state.totalSeconds = 0;
      updateDisplay();
      statusEl.textContent = COPY.statusReady;
      displayWrap.classList.remove('ct-widget__display--finished');
      btnStart.textContent = COPY.btnStart;
      btnStart.disabled = false;
      btnPause.disabled = true;
      btnReset.disabled = true;
      dtError.textContent = '';
      // Show the active panel
      if (state.mode === 'duration') {
        panelDuration.classList.remove('ct-widget__inputs--hidden');
      } else {
        panelDatetime.classList.remove('ct-widget__inputs--hidden');
      }
      updatePageTitle();
    }

    function setPreset(seconds) {
      resetTimer();
      if (state.mode === 'datetime') {
        // Switch to duration mode for presets
        state.mode = 'duration';
        modeButtons.forEach(b => b.classList.toggle('ct-mode-btn--active', b.dataset.mode === 'duration'));
        panelDuration.classList.remove('ct-widget__inputs--hidden');
        panelDatetime.classList.add('ct-widget__inputs--hidden');
      }
      const h = Math.floor(seconds / 3600);
      const m = Math.floor((seconds % 3600) / 60);
      const s = seconds % 60;
      inputH.value = h;
      inputM.value = m;
      inputS.value = s;
      state.totalSeconds = seconds;
      updateDisplay();
    }

    // ── Events ──
    btnStart.addEventListener('click', startTimer);
    btnPause.addEventListener('click', () => {
      if (state.countdown) {
        clearInterval(state.countdown);
        state.countdown = null;
        state.isPaused = true;
        disarmServerPush(state);
        btnStart.textContent = COPY.btnResume;
        statusEl.textContent = COPY.statusPaused;
      }
    });
    btnReset.addEventListener('click', resetTimer);

    btnClose.addEventListener('click', () => removeWidget(id));

    // Mode switching
    modeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        if (state.countdown || state.isPaused) return; // don't switch while running
        state.mode = btn.dataset.mode;
        modeButtons.forEach(b => b.classList.toggle('ct-mode-btn--active', b === btn));
        panelDuration.classList.toggle('ct-widget__inputs--hidden', state.mode !== 'duration');
        panelDatetime.classList.toggle('ct-widget__inputs--hidden', state.mode !== 'datetime');
      });
    });

    // Duration inputs update display
    [inputH, inputM, inputS].forEach(inp => {
      inp.addEventListener('input', () => {
        if (!state.countdown && !state.isPaused) {
          const h = parseInt(inputH.value) || 0;
          const m = parseInt(inputM.value) || 0;
          const s = parseInt(inputS.value) || 0;
          state.totalSeconds = h * 3600 + m * 60 + s;
          updateDisplay();
        }
      });
    });

    // Datetime input live preview
    inputDT.addEventListener('input', () => {
      if (!state.countdown && !state.isPaused) {
        const secs = getSecondsFromDatetime();
        if (secs > 0) { state.totalSeconds = secs; updateDisplay(); }
      }
    });

    // Presets
    el.querySelectorAll('.ct-preset').forEach(btn => {
      btn.addEventListener('click', () => setPreset(parseInt(btn.dataset.seconds)));
    });

    // Placeholder behaviour for contenteditable title
    titleEl.addEventListener('focus', () => {
      if (titleEl.dataset.isDefault === '1') titleEl.textContent = '';
    });
    titleEl.addEventListener('input', () => { titleEl.dataset.isDefault = ''; });
    titleEl.addEventListener('blur', () => {
      if (!titleEl.textContent.trim()) {
        titleEl.textContent = fmtTimer(id);
        titleEl.dataset.isDefault = '1';
      }
    });
    titleEl.addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); titleEl.blur(); }
    });

    // Set default datetime-local to 5 minutes from now
    const now = new Date(Date.now() + 5 * 60 * 1000);
    const iso = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
    inputDT.value = iso;

    grid.appendChild(el);
    refreshAddBtn();
    updateDisplay();
  }

  function removeWidget(id) {
    const state = widgets.get(id);
    if (!state) return;
    stopAlarmFor(state);
    if (state.countdown) clearInterval(state.countdown);
    if (window.MentriaPush) MentriaPush.cancel('ct-' + state.id);
    widgets.delete(id);
    const el = grid.querySelector(`[data-widget-id="${id}"]`);
    if (el) el.remove();
    refreshAddBtn();
    updatePageTitle();
  }

  // ── Boot ──
  addBtn.addEventListener('click', addWidget);
  addWidget(); // spawn first widget on load
})();
</script>

