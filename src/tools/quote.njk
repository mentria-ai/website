---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/quote/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.quote.title' | t }}"
  description: "{{ 'tools.quote.lede' | t }}"
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><a class="eyebrow__link" href="{{ locale.pathPrefix }}/tools/">tools</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">quote</span></p>
  <h1>{{ "tools.quote.title" | t }}</h1>
  <p>{{ "tools.quote.lede" | t }}</p>
  {% include "tldr.njk" %}
</section>

{% set terminalTitle = "quote.js" %}
{% include "terminal-frame-open.njk" %}
<section class="mq">
  <div class="mq__status">
    <span class="mq__status-dot" id="mq-status-dot"></span>
    <span class="mq__status-text" id="mq-status-text">{{ "tool.quote.status_initializing" | t }}</span>
  </div>

  <div class="mq__progress-wrap" id="mq-progress-wrap" style="display:none;">
    <div class="mq__progress-info">
      <span id="mq-progress-label">{{ "tool.quote.progress_label" | t }}</span>
      <span id="mq-progress-pct">0%</span>
    </div>
    <div class="mq__progress-bar">
      <div class="mq__progress-fill" id="mq-progress-fill"></div>
    </div>
    <div class="mq__progress-detail" id="mq-progress-detail"></div>
  </div>

  <div class="mq__quote-area">
    <div class="mq__quote" id="mq-quote"></div>
  </div>

  <div class="mq__actions">
    <button class="mq__btn mq__btn--primary" id="mq-new" disabled>{{ "tool.quote.btn_new" | t }}</button>
    <button class="mq__btn mq__btn--secondary" id="mq-copy" style="display:none;">{{ "tool.quote.btn_copy" | t }}</button>
  </div>
</section>
{% include "terminal-frame-close.njk" %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Mentria Motivational Quote",
  "operatingSystem": "Web",
  "applicationCategory": "UtilitiesApplication",
  "description": "AI-generated original motivational quotes running locally in your browser via custom finetuned Qwen3.5-0.8B model.",
  "offers": { "@type": "Offer", "price": "0" }
}
</script>

<script src="/assets/js/markdown.js?v={{ buildHash }}"></script>

<script type="module">
const COPY = {
  statusLoadingModel: {{ ("tool.quote.status_loading_model" | t) | dump | safe }},
  statusReady:        {{ ("tool.quote.status_ready"         | t) | dump | safe }},
  statusGenerating:   {{ ("tool.quote.status_generating"    | t) | dump | safe }},
  btnCopy:            {{ ("tool.quote.btn_copy"             | t) | dump | safe }},
  btnCopied:          {{ ("tool.quote.btn_copied"           | t) | dump | safe }},
  btnFailed:          {{ ("tool.quote.btn_failed"           | t) | dump | safe }},
  errNoWebGpu:        {{ ("tool.quote.err_no_webgpu"        | t) | dump | safe }},
  errUnsupportedBody: {{ ("tool.quote.err_unsupported_body" | t) | dump | safe }},
  errLoadRuntime:     {{ ("tool.quote.err_load_runtime"     | t) | dump | safe }},
  errDeviceLost:      {{ ("tool.quote.err_device_lost"      | t) | dump | safe }},
  errLoadPrefix:      {{ ("tool.quote.err_load_prefix"      | t) | dump | safe }},
  errNoQuote:         {{ ("tool.quote.err_no_quote"         | t) | dump | safe }},
  errGeneration:      {{ ("tool.quote.err_generation"       | t) | dump | safe }}
};

const MENTRIA_DIST_BASE  = '/assets/mentria/dist/';
const MENTRIA_MODEL_BASE = 'https://huggingface.co/mentriaai/Qwen3.5-0.8B-mentria/resolve/main/';
const MENTRIA_TOKEN_BASE = MENTRIA_MODEL_BASE;

const QUOTES_LORA_CONFIG_URL  = MENTRIA_MODEL_BASE + 'loras/quotes/adapter_config.json';
const QUOTES_LORA_WEIGHTS_URL = MENTRIA_MODEL_BASE + 'loras/quotes/adapter_model.safetensors';

const SYSTEM_PROMPT =
  'You are a poetic thinker. Write one short, original motivational quote ' +
  '(1-2 sentences). Do not attribute it to anyone. No preamble, no ' +
  'quotation marks \u2014 just the quote itself.';
const MAX_TOKENS = 128;

/* \u2500\u2500 Status helpers \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */
const statusDot  = document.getElementById('mq-status-dot');
const statusText = document.getElementById('mq-status-text');
function setStatus(state, text) {
  statusDot.className = 'mq__status-dot mq__status-dot--' + state;
  statusText.textContent = text;
}

/* \u2500\u2500 WebGPU gate \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */
function showUnsupportedError(reason) {
  setStatus('error', reason);
  const quoteEl = document.getElementById('mq-quote');
  if (quoteEl) {
    quoteEl.textContent = COPY.errUnsupportedBody;
  }
  document.getElementById('mq-new').disabled = true;
}

if (!navigator.gpu) {
  showUnsupportedError(COPY.errNoWebGpu);
} else {
  let MentriaEngine;
  try {
    ({ MentriaEngine } = await import(MENTRIA_DIST_BASE + 'mentria.mjs'));
  } catch (err) {
    console.error('Failed to load mentria-engine bundle:', err);
    showUnsupportedError(COPY.errLoadRuntime);
  }
  if (MentriaEngine) runApp(MentriaEngine);
}

function runApp(MentriaEngine) {
  /* DOM refs */
  const progressWrap   = document.getElementById('mq-progress-wrap');
  const progressLabel  = document.getElementById('mq-progress-label');
  const progressPct    = document.getElementById('mq-progress-pct');
  const progressFill   = document.getElementById('mq-progress-fill');
  const progressDetail = document.getElementById('mq-progress-detail');
  const quoteEl        = document.getElementById('mq-quote');
  const newBtn         = document.getElementById('mq-new');
  const copyBtn        = document.getElementById('mq-copy');

  let engine = null;
  let generating = false;

  function formatBytes(b) {
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(1) + ' MB';
  }

  /* Progress tracking — clamps ratio to [0,1] and suppresses the byte-line
     for non-byte stages (engine multiplexes byte counts and step counters
     on the same channel; see ai-chat.njk for the long-form rationale). */
  function onEngineProgress(p) {
    if (!p) return;
    progressWrap.style.display = '';
    if (p.message) progressLabel.textContent = p.message;
    if (p.loaded != null && p.total != null && p.total > 0) {
      const ratio = Math.max(0, Math.min(1, p.loaded / p.total));
      const pct = Math.round(ratio * 100);
      progressFill.style.width = pct + '%';
      progressPct.textContent = pct + '%';
      progressDetail.textContent =
        p.total >= 1024 ? (formatBytes(p.loaded) + ' / ' + formatBytes(p.total)) : '';
    }
  }

  /* Load engine + model */
  async function loadModel() {
    setStatus('loading', COPY.statusLoadingModel);
    progressWrap.style.display = '';
    try {
      engine = new MentriaEngine(MENTRIA_DIST_BASE + 'worker.mjs');
      engine.onProgress = onEngineProgress;
      engine.onDeviceLost = (info) => {
        setStatus('error', COPY.errDeviceLost);
        newBtn.disabled = true;
        console.error('WebGPU device lost:', info);
      };
      await engine.init();
      // Text-only — no vision tower needed for quote generation.
      await engine.loadModel({
        modelUrl: MENTRIA_MODEL_BASE,
        shards: ['qwen3.5-0.8b-q4.safetensors'],
        tokenizerUrl: MENTRIA_TOKEN_BASE,
      });

      // Optional LoRA — load only if both URLs are configured. Failure is
      // not fatal; falls back to base model + system-prompt shaping.
      if (QUOTES_LORA_CONFIG_URL && QUOTES_LORA_WEIGHTS_URL) {
        try {
          await engine.swapAdapter({
            name: 'quotes-v1',
            configUrl: QUOTES_LORA_CONFIG_URL,
            weightsUrl: QUOTES_LORA_WEIGHTS_URL,
          });
        } catch (err) {
          console.warn('Quotes LoRA load failed, using base model:', err);
        }
      }

      progressWrap.style.display = 'none';
      setStatus('ready', COPY.statusReady);
      newBtn.disabled = false;
    } catch (err) {
      progressWrap.style.display = 'none';
      console.error('Model load error:', err);
      setStatus('error', COPY.errLoadPrefix + (err.message || err));
    }
  }

  /* Generate quote */
  async function generateQuote() {
    if (generating || !engine) return;
    generating = true;
    newBtn.disabled = true;
    copyBtn.style.display = 'none';
    quoteEl.textContent = '';
    quoteEl.classList.add('mq__quote--typing');
    setStatus('generating', COPY.statusGenerating);

    const messages = [
      { role: 'system', content: SYSTEM_PROMPT },
      { role: 'user',   content: 'Give me a motivational quote.' },
    ];

    let fullText = '';
    let pendingPaint = false;

    function paintToken() {
      const display = fullText.replace(/<think>[\s\S]*?<\/think>/g, '').trim();
      // Markdown-rendered output (escapes html first → safe). Falls back to text.
      if (window.renderMarkdown) quoteEl.innerHTML = renderMarkdown(display) || '<p>…</p>';
      else quoteEl.textContent = display || '…';
      pendingPaint = false;
    }

    try {
      await engine.generate({
        messages,
        maxTokens: MAX_TOKENS,
        // Match the original transformers.js sampling for similar
        // creative variance: do_sample=true, temp=0.9, top_p=0.95.
        temperature: 0.9,
        topP: 0.95,
        topK: 50,
        repetitionPenalty: 1.1,
        enableThinking: false,
      }, (event) => {
        if (typeof event.token === 'string' && event.token.length > 0) {
          // Skip Qwen special tokens (<|im_end|>, <|endoftext|>, etc) from the visible stream
          if (/^<\|[^|]*\|>$/.test(event.token)) return;
          fullText += event.token;
          if (!pendingPaint) {
            pendingPaint = true;
            requestAnimationFrame(paintToken);
          }
        }
      });

      const display = fullText
        .replace(/<think>[\s\S]*?<\/think>/g, '')
        .replace(/<\|[^|]*\|>/g, '')
        .trim();
      const escNoQuote = COPY.errNoQuote.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      if (window.renderMarkdown) quoteEl.innerHTML = renderMarkdown(display) || `<p>${escNoQuote}</p>`;
      else quoteEl.textContent = display || COPY.errNoQuote;
      quoteEl.classList.remove('mq__quote--typing');
      if (display) copyBtn.style.display = '';
    } catch (err) {
      console.error('Generation error:', err);
      quoteEl.textContent = COPY.errGeneration;
      quoteEl.classList.remove('mq__quote--typing');
    }

    generating = false;
    newBtn.disabled = false;
    setStatus('ready', COPY.statusReady);
  }

  /* Copy to clipboard */
  async function copyQuote() {
    const text = quoteEl.textContent;
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      copyBtn.textContent = COPY.btnCopied;
      setTimeout(() => { copyBtn.textContent = COPY.btnCopy; }, 1500);
    } catch {
      copyBtn.textContent = COPY.btnFailed;
      setTimeout(() => { copyBtn.textContent = COPY.btnCopy; }, 1500);
    }
  }

  /* Events */
  newBtn.addEventListener('click', generateQuote);
  copyBtn.addEventListener('click', copyQuote);

  /* Init */
  (async () => {
    setStatus('idle', COPY.statusLoadingModel);
    await loadModel();
    if (engine) generateQuote();
  })();
}
</script>

<style>
.mq {
  display: flex;
  flex-direction: column;
  font-family: var(--font-mono);
  min-height: min(420px, 55vh);
}

/* Status bar */
.mq__status {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.75rem;
  border-bottom: 1px solid var(--term-border);
  font-size: 0.75rem;
  color: var(--term-muted);
  flex-shrink: 0;
}

.mq__status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--term-muted);
  flex-shrink: 0;
}
.mq__status-dot--idle     { background: var(--term-muted); }
.mq__status-dot--loading  { background: var(--syn-amber); box-shadow: 0 0 6px var(--syn-amber); animation: mq-pulse 1.5s ease-in-out infinite; }
.mq__status-dot--ready    { background: var(--syn-green); box-shadow: 0 0 6px var(--syn-green); }
.mq__status-dot--generating { background: var(--syn-cyan); box-shadow: 0 0 6px var(--syn-cyan); animation: mq-pulse 1s ease-in-out infinite; }
.mq__status-dot--error    { background: var(--syn-pink); box-shadow: 0 0 6px var(--syn-pink); }

@keyframes mq-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* Progress bar */
.mq__progress-wrap {
  padding: 0.75rem;
  border-bottom: 1px solid var(--term-border);
  flex-shrink: 0;
}
.mq__progress-info {
  display: flex;
  justify-content: space-between;
  font-size: 0.7rem;
  color: var(--term-muted);
  margin-bottom: 0.4rem;
}
.mq__progress-bar {
  height: 4px;
  background: rgba(255,255,255,0.06);
  border-radius: 2px;
  overflow: hidden;
}
.mq__progress-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--syn-cyan), var(--syn-purple));
  border-radius: 2px;
  transition: width 0.3s ease;
}
.mq__progress-detail {
  font-size: 0.65rem;
  color: var(--term-muted);
  margin-top: 0.3rem;
  text-align: right;
}

/* Quote area */
.mq__quote-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2.5rem 2rem;
}

.mq__quote {
  font-size: 1.15rem;
  line-height: 1.7;
  color: var(--term-fg);
  text-align: center;
  max-width: 540px;
  word-wrap: break-word;
  overflow-wrap: break-word;
  /* white-space: pre-wrap dropped; markdown render now owns whitespace */
  min-height: 1.7em;
}
/* ── Markdown-rendered quote: tight, centered ─────────────────── */
.mq__quote p              { margin: 0 0 0.4rem; }
.mq__quote p:last-child   { margin-bottom: 0; }
.mq__quote ol,
.mq__quote ul             { margin: 0.3rem auto; padding-left: 0; list-style-position: inside; display: inline-block; text-align: left; }
.mq__quote li             { margin: 0.05rem 0; }
.mq__quote li > p         { margin: 0; }
.mq__quote h1,
.mq__quote h2,
.mq__quote h3             { margin: 0.4rem 0 0.25rem; font-family: var(--font-mono); color: var(--syn-cyan); }
.mq__quote strong         { font-weight: 700; }
.mq__quote em             { font-style: italic; }
.mq__quote code           { font-family: var(--font-mono); background: rgba(255,255,255,0.06); padding: 0.05em 0.3em; border-radius: 3px; }

.mq__quote--typing::after {
  content: '';
  display: inline-block;
  width: 2px;
  height: 1.15em;
  background: var(--syn-cyan);
  margin-left: 2px;
  vertical-align: text-bottom;
  animation: mq-blink 0.6s step-end infinite;
}

@keyframes mq-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* Buttons */
.mq__actions {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  padding: 1rem 0.75rem 1.5rem;
  flex-shrink: 0;
}

.mq__btn {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  padding: 0.5rem 1.2rem;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.mq__btn--primary {
  background: var(--syn-cyan);
  color: #000;
  border: none;
}
.mq__btn--primary:hover:not(:disabled) {
  background: #67e8f9;
  box-shadow: 0 0 12px rgba(34, 211, 238, 0.3);
}
.mq__btn--primary:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.mq__btn--secondary {
  background: none;
  border: 1px solid var(--term-border);
  color: var(--term-muted);
}
.mq__btn--secondary:hover {
  border-color: var(--syn-cyan);
  color: var(--syn-cyan);
}

/* Responsive */
@media (max-width: 480px) {
  .mq__quote-area {
    padding: 1.5rem 1rem;
  }
  .mq__quote {
    font-size: 1rem;
  }
}
</style>
