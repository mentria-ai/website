---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/color-picker/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.color-picker.title' | t }}"
  description: "{{ 'tools.color-picker.lede' | t }}"
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><a class="eyebrow__link" href="{{ locale.pathPrefix }}/tools/">tools</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">color-picker</span></p>
  <h1>{{ "tools.color-picker.title" | t }}</h1>
  <p>{{ "tools.color-picker.lede" | t }}</p>
  {% include "tldr.njk" %}
</section>

{% set terminalTitle = "color-picker.js" %}
{% include "terminal-frame-open.njk" %}
<section class="cp">
  <!-- Main color area -->
  <div class="cp__main">
    <div class="cp__swatch-wrap">
      <div class="cp__swatch" id="cp-swatch" title="{{ 'tool.color-picker.title_pick_color' | t }}">
        <input type="color" id="cp-native" value="#22d3ee" aria-label="{{ 'tool.color-picker.aria_pick_color' | t }}" />
      </div>
      <div class="cp__hex-input-wrap">
        <span class="cp__hash">#</span>
        <input type="text" id="cp-hex-input" class="cp__hex-input" maxlength="6" spellcheck="false" inputmode="latin" lang="en" dir="ltr" autocapitalize="off" value="22d3ee" aria-label="{{ 'tool.color-picker.aria_hex_value' | t }}" />
      </div>
    </div>

    <div class="cp__values">
      <div class="cp__value-row" data-format="hex">
        <span class="cp__value-label">HEX</span>
        <code class="cp__value-code" id="cp-val-hex">#22d3ee</code>
        <button class="cp__copy-btn" data-copy="hex" title="{{ 'tool.color-picker.title_copy_hex' | t }}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        </button>
      </div>
      <div class="cp__value-row" data-format="rgb">
        <span class="cp__value-label">RGB</span>
        <code class="cp__value-code" id="cp-val-rgb">rgb(34, 211, 238)</code>
        <button class="cp__copy-btn" data-copy="rgb" title="{{ 'tool.color-picker.title_copy_rgb' | t }}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        </button>
      </div>
      <div class="cp__value-row" data-format="hsl">
        <span class="cp__value-label">HSL</span>
        <code class="cp__value-code" id="cp-val-hsl">hsl(187, 82%, 53%)</code>
        <button class="cp__copy-btn" data-copy="hsl" title="{{ 'tool.color-picker.title_copy_hsl' | t }}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="cp__actions">
    <button class="m-btn m-btn--ghost cp__btn" id="cp-random" title="{{ 'tool.color-picker.title_random' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 4l3 3-3 3"/><path d="M18 20l3-3-3-3"/><path d="M3 7h4a5 5 0 015 5 5 5 0 005 5h4"/><path d="M21 7h-4a5 5 0 00-3.07 1.05"/><path d="M3 17h4a5 5 0 003.07-1.05"/></svg>
      {{ "tool.color-picker.btn_random" | t }}
    </button>
    <button class="m-btn m-btn--primary cp__btn" id="cp-save" title="{{ 'tool.color-picker.title_save' | t }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      {{ "tool.color-picker.btn_save" | t }}
    </button>
  </div>

  <div class="cp__saved" id="cp-saved" style="display:none;">
    <div class="cp__section-label">{{ "tool.color-picker.saved_label" | t }}</div>
    <div class="cp__saved-list" id="cp-saved-list"></div>
  </div>

  <div class="cp__palette-section">
    <div class="cp__section-label">{{ "tool.color-picker.palette_label" | t }}</div>
    <div class="cp__palette-btns">
      <button class="m-btn m-btn--ghost cp__palette-btn" data-harmony="complementary">{{ "tool.color-picker.harmony_complementary" | t }}</button>
      <button class="m-btn m-btn--ghost cp__palette-btn" data-harmony="analogous">{{ "tool.color-picker.harmony_analogous" | t }}</button>
      <button class="m-btn m-btn--ghost cp__palette-btn" data-harmony="triadic">{{ "tool.color-picker.harmony_triadic" | t }}</button>
      <button class="m-btn m-btn--ghost cp__palette-btn" data-harmony="split">{{ "tool.color-picker.harmony_split" | t }}</button>
      <button class="m-btn m-btn--ghost cp__palette-btn" data-harmony="tetradic">{{ "tool.color-picker.harmony_tetradic" | t }}</button>
    </div>
    <div class="cp__palette" id="cp-palette"></div>
  </div>
</section>
{% include "terminal-frame-close.njk" %}

{% include "tool-schema.njk" %}

<script>
(() => {
  /* ── DOM refs ──────────────────────────────────────── */
  const swatch     = document.getElementById('cp-swatch');
  const native     = document.getElementById('cp-native');
  const hexInput   = document.getElementById('cp-hex-input');
  const valHex     = document.getElementById('cp-val-hex');
  const valRgb     = document.getElementById('cp-val-rgb');
  const valHsl     = document.getElementById('cp-val-hsl');
  const paletteEl  = document.getElementById('cp-palette');
  const savedWrap  = document.getElementById('cp-saved');
  const savedList  = document.getElementById('cp-saved-list');
  const STORAGE_KEY = 'mentria-color-picker-saved';

  const COPY = {
    selectSwatchTitle: {{ ("tool.color-picker.title_select_swatch" | t) | dump | safe }},
    removeTitle:       {{ ("tool.color-picker.title_remove"        | t) | dump | safe }},
    toastCopied:       {{ ("tool.color-picker.toast_copied"        | t) | dump | safe }},
    toastSaved:        {{ ("tool.color-picker.toast_saved"         | t) | dump | safe }},
    toastAlreadySaved: {{ ("tool.color-picker.toast_already_saved" | t) | dump | safe }},
    confirmRemove:     {{ ("tool.color-picker.confirm_remove"      | t) | dump | safe }}
  };

  let currentHex = '#22d3ee';
  let currentHarmony = null;

  /* ── Color conversion helpers ──────────────────────── */
  function hexToRgb(hex) {
    const h = hex.replace('#', '');
    return {
      r: parseInt(h.substring(0, 2), 16),
      g: parseInt(h.substring(2, 4), 16),
      b: parseInt(h.substring(4, 6), 16)
    };
  }

  function rgbToHsl(r, g, b) {
    r /= 255; g /= 255; b /= 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    let h, s, l = (max + min) / 2;
    if (max === min) {
      h = s = 0;
    } else {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      switch (max) {
        case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
        case g: h = ((b - r) / d + 2) / 6; break;
        case b: h = ((r - g) / d + 4) / 6; break;
      }
    }
    return {
      h: Math.round(h * 360),
      s: Math.round(s * 100),
      l: Math.round(l * 100)
    };
  }

  function hslToHex(h, s, l) {
    s /= 100; l /= 100;
    const a = s * Math.min(l, 1 - l);
    const f = n => {
      const k = (n + h / 30) % 12;
      const color = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
      return Math.round(255 * color).toString(16).padStart(2, '0');
    };
    return '#' + f(0) + f(8) + f(4);
  }

  function rgbString(r, g, b) {
    return `rgb(${r}, ${g}, ${b})`;
  }

  function hslString(h, s, l) {
    return `hsl(${h}, ${s}%, ${l}%)`;
  }

  /* ── Update UI with current color ──────────────────── */
  function setColor(hex, skipNative) {
    hex = hex.toLowerCase();
    if (!/^#[0-9a-f]{6}$/.test(hex)) return;
    currentHex = hex;

    swatch.style.backgroundColor = hex;
    if (!skipNative) native.value = hex;
    hexInput.value = hex.replace('#', '');

    const { r, g, b } = hexToRgb(hex);
    const hsl = rgbToHsl(r, g, b);

    valHex.textContent = hex;
    valRgb.textContent = rgbString(r, g, b);
    valHsl.textContent = hslString(hsl.h, hsl.s, hsl.l);

    // Re-generate palette if one is active
    if (currentHarmony) generatePalette(currentHarmony);
  }

  /* ── Palette generation ────────────────────────────── */
  function getHarmonyColors(hex, type) {
    const { r, g, b } = hexToRgb(hex);
    const { h, s, l } = rgbToHsl(r, g, b);
    const colors = [hex];

    switch (type) {
      case 'complementary':
        colors.push(hslToHex((h + 180) % 360, s, l));
        break;
      case 'analogous':
        colors.push(hslToHex((h + 30) % 360, s, l));
        colors.push(hslToHex((h + 330) % 360, s, l));
        break;
      case 'triadic':
        colors.push(hslToHex((h + 120) % 360, s, l));
        colors.push(hslToHex((h + 240) % 360, s, l));
        break;
      case 'split':
        colors.push(hslToHex((h + 150) % 360, s, l));
        colors.push(hslToHex((h + 210) % 360, s, l));
        break;
      case 'tetradic':
        colors.push(hslToHex((h + 90) % 360, s, l));
        colors.push(hslToHex((h + 180) % 360, s, l));
        colors.push(hslToHex((h + 270) % 360, s, l));
        break;
    }
    return colors;
  }

  function generatePalette(type) {
    currentHarmony = type;
    const colors = getHarmonyColors(currentHex, type);
    paletteEl.innerHTML = '';
    colors.forEach((c, i) => {
      const item = document.createElement('div');
      item.className = 'cp__palette-item';
      item.setAttribute('role', 'button');
      item.tabIndex = 0;
      item.setAttribute('aria-label', COPY.selectSwatchTitle.replace('{color}', c));
      item.innerHTML =
        '<div class="cp__palette-swatch" style="background:' + c + '" title="' + COPY.selectSwatchTitle.replace('{color}', c) + '"></div>' +
        '<span class="cp__palette-label">' + c + '</span>';
      const activate = () => {
        copyText(c);
        if (i !== 0) setColor(c);
      };
      item.addEventListener('click', activate);
      item.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
      });
      paletteEl.appendChild(item);
    });

    // highlight active button
    document.querySelectorAll('.cp__palette-btn').forEach(btn => {
      btn.classList.toggle('cp__palette-btn--active', btn.dataset.harmony === type);
    });
  }

  /* ── Copy helper ───────────────────────────────────── */
  function copyText(text) {
    navigator.clipboard.writeText(text).then(() => {
      MentriaUI.toast(COPY.toastCopied.replace('{color}', text));
    }).catch(() => {});
  }

  /* ── Saved colors ──────────────────────────────────── */
  function loadSaved() {
    const v = MentriaUI.migrateStore('tools', 'color_picker_palette', STORAGE_KEY, []);
    return Array.isArray(v) ? v : [];
  }

  function saveSaved(arr) {
    if (window.MentriaStore) window.MentriaStore.set('tools', 'color_picker_palette', arr);
    else localStorage.setItem(STORAGE_KEY, JSON.stringify(arr));
  }

  function renderSaved() {
    const saved = loadSaved();
    savedList.innerHTML = '';
    if (saved.length === 0) {
      savedWrap.style.display = 'none';
      return;
    }
    savedWrap.style.display = '';
    saved.forEach((c, i) => {
      const el = document.createElement('div');
      el.className = 'cp__saved-item';
      el.innerHTML =
        '<div class="cp__saved-swatch" role="button" tabindex="0" style="background:' + c + '" title="' + c + '" aria-label="' + COPY.selectSwatchTitle.replace('{color}', c) + '"></div>' +
        '<button class="cp__saved-remove" title="' + COPY.removeTitle + '" aria-label="' + COPY.removeTitle + '" data-index="' + i + '">&times;</button>';
      const sw = el.querySelector('.cp__saved-swatch');
      sw.addEventListener('click', () => setColor(c));
      sw.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); setColor(c); }
      });
      const removeColor = async () => {
        if (!(await window.mentriaConfirm(COPY.confirmRemove.replace('{color}', c)))) return;
        const arr = loadSaved();
        arr.splice(i, 1);
        saveSaved(arr);
        renderSaved();
      };
      el.querySelector('.cp__saved-remove').addEventListener('click', e => { e.stopPropagation(); removeColor(); });
      el.addEventListener('contextmenu', e => { e.preventDefault(); removeColor(); });
      savedList.appendChild(el);
    });
  }

  /* ── Event listeners ───────────────────────────────── */
  // Native color input
  native.addEventListener('input', () => setColor(native.value, true));

  // Click swatch to open native picker
  swatch.addEventListener('click', e => {
    if (e.target === native) return;
    native.click();
  });

  // Hex text input
  hexInput.addEventListener('input', () => {
    const v = hexInput.value.replace(/[^0-9a-fA-F]/g, '').substring(0, 6);
    hexInput.value = v;
    if (v.length === 6) setColor('#' + v);
  });

  hexInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') hexInput.blur();
  });

  // Copy buttons
  document.querySelectorAll('.cp__copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const fmt = btn.dataset.copy;
      const el = document.getElementById('cp-val-' + fmt);
      if (el) copyText(el.textContent);
    });
  });

  // Random
  document.getElementById('cp-random').addEventListener('click', () => {
    const hex = '#' + Math.floor(Math.random() * 0xffffff).toString(16).padStart(6, '0');
    setColor(hex);
  });

  // Save
  document.getElementById('cp-save').addEventListener('click', () => {
    const saved = loadSaved();
    if (!saved.includes(currentHex)) {
      saved.push(currentHex);
      saveSaved(saved);
      renderSaved();
      MentriaUI.toast(COPY.toastSaved.replace('{color}', currentHex));
    } else {
      MentriaUI.toast(COPY.toastAlreadySaved);
    }
  });

  // Palette harmony buttons
  document.querySelectorAll('.cp__palette-btn').forEach(btn => {
    btn.addEventListener('click', () => generatePalette(btn.dataset.harmony));
  });

  /* ── Init ──────────────────────────────────────────── */
  const init = () => { setColor('#22d3ee'); renderSaved(); };
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

<style>
/* ── Color Picker Styles ─────────────────────────────── */
.cp {
  padding: 1.5rem;
  font-family: var(--font-body, 'Inter', sans-serif);
  color: var(--term-fg);
  max-width: 540px;
  margin: 0 auto;
}

.cp__main {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  margin-bottom: 1.25rem;
}

/* ── Swatch ──────────────────────────────────────────── */
.cp__swatch-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

.cp__swatch {
  width: 96px;
  height: 96px;
  border-radius: 12px;
  border: 2px solid var(--term-border);
  cursor: pointer;
  position: relative;
  overflow: hidden;
  background: var(--syn-cyan);
  transition: box-shadow 0.25s ease;
}

.cp__swatch:hover {
  box-shadow: 0 0 20px var(--cyan-30);
}

.cp__swatch input[type="color"] {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0;
  cursor: pointer;
  border: none;
  padding: 0;
}

.cp__hex-input-wrap {
  display: flex;
  align-items: center;
  gap: 2px;
  background: var(--term-bg-raised);
  border: 1px solid var(--term-border);
  border-radius: var(--radius-md);
  padding: 0.25rem 0.5rem;
}

.cp__hash {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 0.85rem;
  color: var(--term-muted);
}

.cp__hex-input {
  background: transparent;
  border: none;
  outline: none;
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 0.85rem;
  color: var(--term-fg);
  width: 5.5ch;
  letter-spacing: 0.04em;
}

/* ── Color values ────────────────────────────────────── */
.cp__values {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.cp__value-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--term-bg-raised);
  border: 1px solid var(--term-border);
  border-radius: var(--radius-md);
  padding: 0.45rem 0.65rem;
}

.cp__value-label {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--syn-cyan);
  width: 2.5rem;
  flex-shrink: 0;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.cp__value-code {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 0.8rem;
  color: var(--term-fg);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cp__copy-btn {
  background: none;
  border: none;
  color: var(--term-muted);
  cursor: pointer;
  padding: 4px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.2s, background 0.2s;
  flex-shrink: 0;
}

.cp__copy-btn:hover {
  color: var(--syn-cyan);
  background: var(--cyan-8);
}

/* ── Action buttons ──────────────────────────────────── */
.cp__actions {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
}

.cp__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

/* ── Section labels ──────────────────────────────────── */
.cp__section-label {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 0.7rem;
  color: var(--term-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.6rem;
}

/* ── Saved colors ────────────────────────────────────── */
.cp__saved {
  margin-bottom: 1.25rem;
}

.cp__saved-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.cp__saved-item {
  position: relative;
}

.cp__saved-swatch {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  border: 1px solid var(--term-border);
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.2s;
}

.cp__saved-swatch:hover {
  transform: scale(1.1);
  box-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
}

.cp__saved-remove {
  position: absolute;
  top: -5px;
  right: -5px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: none;
  background: var(--syn-pink);
  color: #000;
  font-size: 10px;
  line-height: 1;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.15s;
}

.cp__saved-item:hover .cp__saved-remove {
  opacity: 1;
}

@media (hover: none) {
  .cp__saved-remove { opacity: 1; }
}

.cp__saved-remove::after {
  content: '';
  position: absolute;
  inset: -6px;
}

/* ── Palette section ─────────────────────────────────── */
.cp__palette-section {
  margin-bottom: 0.5rem;
}

.cp__palette-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-bottom: 1rem;
}

.cp__palette-btn {
  padding: 0.35rem 0.7rem;
  font-size: 0.75rem;
}

.cp__palette-btn--active {
  color: var(--syn-cyan);
  border-color: var(--syn-cyan);
  box-shadow: 0 0 10px var(--cyan-15);
}

.cp__palette {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.cp__palette-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.35rem;
  cursor: pointer;
}

.cp__palette-swatch {
  width: 56px;
  height: 56px;
  border-radius: 10px;
  border: 2px solid var(--term-border);
  transition: transform 0.15s, box-shadow 0.2s;
}

.cp__palette-item:hover .cp__palette-swatch {
  transform: scale(1.08);
  box-shadow: 0 0 14px rgba(255, 255, 255, 0.12);
}

.cp__palette-label {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 0.65rem;
  color: var(--term-muted);
}

/* ── Responsive ──────────────────────────────────────── */
@media (max-width: 520px) {
  .cp { padding: 1rem; }

  .cp__main {
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
  }

  .cp__swatch-wrap {
    flex-direction: row;
    gap: 1rem;
  }

  .cp__swatch {
    width: 72px;
    height: 72px;
  }

  .cp__palette-swatch {
    width: 44px;
    height: 44px;
  }

  .cp__palette-btns {
    gap: 0.3rem;
  }

  .cp__palette-btn {
    font-size: 0.7rem;
