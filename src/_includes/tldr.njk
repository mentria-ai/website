{%- set tldrKey = "tools." + page.fileSlug + ".tldr" -%}
{%- set titleKey = "tools." + page.fileSlug + ".title" -%}
{%- if tldrKey | hasKey -%}
<details class="tldr">
  <summary class="tldr__summary">
    <span class="tldr__cta-more">{{ "common.tldr.read_more" | t }}</span>
    <span class="tldr__cta-less">{{ "common.tldr.read_less" | t }}</span>
    <span class="tldr__caret" aria-hidden="true">▾</span>
  </summary>
  <div class="tldr__panel">
    <h2 class="tldr__heading">{% tvar "common.tldr.what_is", "name", titleKey %}</h2>
    <p class="tldr__body">{{ tldrKey | t }}</p>
  </div>
</details>
{%- endif %}
