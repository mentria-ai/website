.comms__meta{display:flex;gap:.5rem;align-items:center}
.comms__lbl{color:var(--muted);text-transform:lowercase;letter-spacing:.05em;font-size:.78rem}
.comms__input{background:#0a0d10;border:1px solid #2a3138;color:#e6edf3;padding:.45rem .6rem;border-radius:6px;font-family:inherit;font-size:.9rem;flex:1;min-width:6rem}
.comms__input:focus{outline:none;border-color:var(--accent,#6ef3c5)}
