<!--
  Non-blocking PWA install prompt.
  Slim dismissible bottom banner + bottom sheet with platform-specific
  steps. Hidden when already installed (display-mode: standalone) or on
  unsupported browsers (Firefox, etc).
-->
<div id="pwaInstallBanner" class="pwa-install-banner" hidden>
  <img src="/assets/img/icon-192x192.png" alt="" class="pwa-install-banner__icon" width="40" height="40">
  <div class="pwa-install-banner__body">
    <div class="pwa-install-banner__title">{{ "pwa.banner_title" | t }}</div>
    <div class="pwa-install-banner__desc"><span class="pwa-install-banner__desc-inner">{{ "pwa.banner_desc" | t }}</span></div>
  </div>
  <button type="button" id="pwaInstallBannerBtn" class="pwa-install-banner__cta">{{ "pwa.install_btn" | t }}</button>
  <button type="button" id="pwaInstallBannerClose" class="pwa-install-banner__close" aria-label="{{ 'pwa.dismiss' | t }}">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
</div>

<div id="pwaInstallSheet" class="pwa-install-sheet" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="pwaInstallSheetTitle">
  <div class="pwa-install-sheet__backdrop" data-close="1"></div>
  <div class="pwa-install-sheet__panel">
    <div class="pwa-install-sheet__handle"></div>
    <button type="button" class="pwa-install-sheet__close" aria-label="{{ 'pwa.dismiss' | t }}" data-close="1">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="pwa-install-sheet__body">
      <h2 class="pwa-install-sheet__title" id="pwaInstallSheetTitle">{{ "pwa.banner_title" | t }}</h2>
      <!--
        MP4 listed first so iOS Safari (no WebM) picks it up. Square
        720x720 source. width/height attrs + poster + preload give
        Safari intrinsic dimensions before metadata loads.
      -->
      <video class="pwa-install-sheet__video" id="pwaInstallSheetVideo"
             width="720" height="720"
             poster="/assets/videos/mentria-install-poster.jpg"
             muted playsinline loop autoplay preload="metadata" hidden>
        <source src="/assets/videos/mentria-install.mp4" type="video/mp4">
        <source src="/assets/videos/mentria-install.webm" type="video/webm">
      </video>
      <ol class="pwa-install-sheet__steps" id="pwaInstallSheetSteps"></ol>
      <p class="pwa-install-sheet__note" id="pwaInstallSheetNote"></p>
    </div>
  </div>
</div>

<script>
(function () {
  // Skip entirely if already installed (detected pre-paint in base.njk).
  if (document.documentElement.classList.contains('is-standalone')) return;

  var DISMISS_KEY   = 'mentria_pwa_install_dismissed_at';
  var INSTALLED_KEY = 'mentria_pwa_installed_at';
  var DISMISS_MS    = 7 * 24 * 60 * 60 * 1000; // 7 days
  var SHOW_DELAY    = 3000;                     // 3s on first visit

  // Already installed (any prior session)? skip permanently.
  if (localStorage.getItem(INSTALLED_KEY)) return;

  // Respect prior dismissal.
  var dismissed = parseInt(localStorage.getItem(DISMISS_KEY), 10);
  if (dismissed && (Date.now() - dismissed) < DISMISS_MS) return;

  // ── Platform detection ─────────────────────────────────────
  var ua = navigator.userAgent;
  var isIos = /iPad|iPhone|iPod/.test(ua) && !window.MSStream;
  var isMac = /Macintosh/.test(ua);
  var isSafari = /^((?!chrome|android).)*safari/i.test(ua);
  var isChromeLike = /Chrome|CriOS|EdgA?|OPR/.test(ua);
  var isApplePlatform = isIos || (isMac && isSafari && !isChromeLike);
  var canInstall = isChromeLike || isApplePlatform;

  // Firefox / unsupported: silently skip — no nag.
  if (!canInstall) return;

  var banner       = document.getElementById('pwaInstallBanner');
  var bannerBtn    = document.getElementById('pwaInstallBannerBtn');
  var bannerClose  = document.getElementById('pwaInstallBannerClose');
  var sheet        = document.getElementById('pwaInstallSheet');
  var sheetTitle   = document.getElementById('pwaInstallSheetTitle');
  var sheetSteps   = document.getElementById('pwaInstallSheetSteps');
  var sheetNote    = document.getElementById('pwaInstallSheetNote');
  var sheetVideo   = document.getElementById('pwaInstallSheetVideo');

  var deferredPrompt = null;

  // beforeinstallprompt: only fires on eligible Chrome-family browsers
  window.addEventListener('beforeinstallprompt', function (e) {
    e.preventDefault();
    deferredPrompt = e;
  });

  // appinstalled: hide everything, don't nag again
  window.addEventListener('appinstalled', function () {
    banner.hidden = true;
    banner.classList.remove('pwa-install-banner--visible');
    closeSheet();
    localStorage.setItem(INSTALLED_KEY, String(Date.now()));
    localStorage.setItem(DISMISS_KEY, String(Date.now()));
  });

  // Belt-and-suspenders: Chromium exposes getInstalledRelatedApps(); if it
  // reports this site's PWA already installed (even from a previous browser
  // session with localStorage cleared), hide the banner and persist the flag.
  if (navigator.getInstalledRelatedApps) {
    navigator.getInstalledRelatedApps().then(function (apps) {
      if (apps && apps.length) {
        localStorage.setItem(INSTALLED_KEY, String(Date.now()));
        banner.hidden = true;
        banner.classList.remove('pwa-install-banner--visible');
        closeSheet();
      }
    }).catch(function () {});
  }

  var bannerDesc = banner.querySelector('.pwa-install-banner__desc');
  var bannerDescInner = banner.querySelector('.pwa-install-banner__desc-inner');
  function setupDescMarquee() {
    if (!bannerDesc || !bannerDescInner || banner.hidden) return;
    bannerDesc.classList.remove('is-marquee');
    var overflow = bannerDescInner.scrollWidth - bannerDesc.clientWidth;
    if (overflow > 2) {
      bannerDesc.style.setProperty('--marquee-shift', (-overflow) + 'px');
      bannerDesc.style.setProperty('--marquee-duration', Math.min(16, Math.max(7, 5 + overflow / 16)).toFixed(1) + 's');
      bannerDesc.classList.add('is-marquee');
    }
  }
  if (window.ResizeObserver) {
    var descRO = new ResizeObserver(function () { setupDescMarquee(); });
    if (bannerDesc) descRO.observe(bannerDesc);
    if (bannerDescInner) descRO.observe(bannerDescInner);
  }

  function showBanner() {
    banner.hidden = false;
    void banner.offsetHeight; // reflow so the slide-in transition runs
    banner.classList.add('pwa-install-banner--visible');
    setupDescMarquee();
  }

  function dismissBanner() {
    localStorage.setItem(DISMISS_KEY, String(Date.now()));
    banner.classList.remove('pwa-install-banner--visible');
    setTimeout(function () { banner.hidden = true; }, 280);
  }

  function openSheet() {
    sheet.classList.add('pwa-install-sheet--open');
    sheet.setAttribute('aria-hidden', 'false');
    document.body.classList.add('pwa-sheet-open');
    if (!sheetVideo.hidden) {
      sheetVideo.play().catch(function () { /* autoplay blocked — ignore */ });
    }
  }

  function closeSheet() {
    sheet.classList.remove('pwa-install-sheet--open');
    sheet.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('pwa-sheet-open');
    try { sheetVideo.pause(); } catch (_) {}
  }

  // Inline SVG icons for the iOS step strings — small enough to sit
  // inline with the text without breaking the line.
  var SHARE_SVG =
    '<svg class="pwa-inline-icon" width="14" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>';
  var ADD_SVG =
    '<svg class="pwa-inline-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>';

  // Localized strings for sheet content — emitted from the template so
  // the JS doesn't have to know the active language.
  var COPY = {
    iosTitle:    {{ ("pwa.sheet_title_ios"   | t) | dump | safe }},
    macosTitle:  {{ ("pwa.sheet_title_macos" | t) | dump | safe }},
    chromeTitle: {{ ("pwa.sheet_title_chrome"| t) | dump | safe }},
    iosStep1:    {{ ("pwa.ios_step1"  | t) | dump | safe }},
    iosStep2:    {{ ("pwa.ios_step2"  | t) | dump | safe }},
    iosStep3:    {{ ("pwa.ios_step3"  | t) | dump | safe }},
    macosStep1:  {{ ("pwa.macos_step1"| t) | dump | safe }},
    macosStep2:  {{ ("pwa.macos_step2"| t) | dump | safe }},
    macosStep3:  {{ ("pwa.macos_step3"| t) | dump | safe }},
    chromeStep1: {{ ("pwa.chrome_step1"| t) | dump | safe }},
    chromeStep2: {{ ("pwa.chrome_step2"| t) | dump | safe }},
    note:        {{ ("pwa.note"       | t) | dump | safe }}
  };

  function populateSheet() {
    var stepsHtml = '';
    var noteHtml  = '';
    var title     = '';
    var showVideo = true; // single Mentria install video — works for any platform

    if (isIos) {
      title = COPY.iosTitle;
      stepsHtml =
        '<li>' + COPY.iosStep1 + ' ' + SHARE_SVG + '</li>' +
        '<li>' + COPY.iosStep2 + ' ' + ADD_SVG + '</li>' +
        '<li>' + COPY.iosStep3 + '</li>';
      noteHtml = COPY.note;
    } else if (isApplePlatform) {
      title = COPY.macosTitle;
      stepsHtml =
        '<li>' + COPY.macosStep1 + '</li>' +
        '<li>' + COPY.macosStep2 + '</li>' +
        '<li>' + COPY.macosStep3 + '</li>';
      noteHtml = COPY.note;
    } else {
      // Chrome-family fallback if beforeinstallprompt never fired
      title = COPY.chromeTitle;
      stepsHtml =
        '<li>' + COPY.chromeStep1 + '</li>' +
        '<li>' + COPY.chromeStep2 + '</li>';
      noteHtml = COPY.note;
    }

    sheetTitle.textContent = title;
    sheetSteps.innerHTML   = stepsHtml;
    sheetNote.innerHTML    = noteHtml || '';
    sheetNote.hidden       = !noteHtml;
    sheetVideo.hidden      = !showVideo;
    if (showVideo) sheetVideo.load();
  }

  // ── Wire up interactions ───────────────────────────────────
  bannerBtn.addEventListener('click', function () {
    if (deferredPrompt) {
      // Chrome-family with native prompt ready — trigger directly.
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then(function (result) {
        deferredPrompt = null;
        if (result.outcome === 'accepted') dismissBanner();
      });
      return;
    }
    populateSheet();
    openSheet();
  });

  bannerClose.addEventListener('click', dismissBanner);

  sheet.addEventListener('click', function (e) {
    var target = e.target;
    if (target && target.closest && target.closest('[data-close]')) {
      closeSheet();
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && sheet.classList.contains('pwa-install-sheet--open')) {
      closeSheet();
    }
  });

  // First-paint grace: 3-second delay so users orient before we pop a CTA.
  setTimeout(showBanner, SHOW_DELAY);

  document.addEventListener('mentria:localechange', function () {
    if (!window.MentriaI18n || !window.MentriaI18n.t) return;
    var t = window.MentriaI18n.t;
    var map = {
      iosTitle: 'pwa.sheet_title_ios', macosTitle: 'pwa.sheet_title_macos', chromeTitle: 'pwa.sheet_title_chrome',
      iosStep1: 'pwa.ios_step1', iosStep2: 'pwa.ios_step2', iosStep3: 'pwa.ios_step3',
      macosStep1: 'pwa.macos_step1', macosStep2: 'pwa.macos_step2', macosStep3: 'pwa.macos_step3',
      chromeStep1: 'pwa.chrome_step1', chromeStep2: 'pwa.chrome_step2', note: 'pwa.note'
    };
    for (var k in map) { var v = t(map[k]); if (v != null) COPY[k] = v; }
    if (sheet.classList.contains('pwa-install-sheet--open')) populateSheet();
  });
})();
</script>
