---
layout: deck-layout.njk
pagination:
  data: deepcutsLocalized
  size: 1
  alias: pair
permalink: "{{ pair.locale.pathPrefix }}/feed/deepcuts/{{ pair.edition.id }}/"
eleventyComputed:
  lang: "{{ pair.locale.code }}"
  title: "{{ pair.edition.title }} · Deep Cuts"
  description: "{{ pair.edition.subtitle | tloc(pair.locale.code) }}"
---
<link rel="stylesheet" href="/assets/css/feed-deck.css?v={{ buildHash }}">

<div class="deck"
     id="deckRoot"
     data-chapter-id="{{ pair.edition.id }}"
     data-chapter-title="{{ pair.edition.title }}"
     data-slide-count="{{ pair.edition.slides.length }}">

  <div class="deck__progress" role="progressbar" aria-label="Deep Cuts progress">
    {% for slide in pair.edition.slides %}
    <div class="deck__progress-seg{% if loop.first %} is-active{% endif %}" data-idx="{{ loop.index0 }}">
      <span class="deck__progress-fill"></span>
    </div>
    {% endfor %}
  </div>

  <button class="deck__close" id="deckClose" aria-label="Exit">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <div class="deck__chapter-meta">
    <span class="deck__chapter-num">DC·{% if pair.edition.order < 10 %}0{% endif %}{{ pair.edition.order }}</span>
    <span class="deck__chapter-title">{{ pair.edition.title }}</span>
  </div>

  <button class="deck__tap deck__tap--prev" aria-label="Previous slide"></button>
  <button class="deck__tap deck__tap--next" aria-label="Next slide"></button>

  {% for slide in pair.edition.slides %}
  <article class="deck__slide{% if loop.first %} is-active{% endif %}"
           data-idx="{{ loop.index0 }}"
           data-slide-id="{{ slide.id }}"
           data-story-type="{{ slide.story_type }}"
           {% if slide.image and slide.image_status != "pending" %}style="--slide-bg: url('{{ slide.image }}')"{% endif %}>
    {% if slide.image_status == "pending" %}
    <div class="deck__slide-img deck__slide-img--placeholder">
      <span class="deck__placeholder-tag">{{ slide.story_type }}</span>
    </div>
    {% else %}
    <img class="deck__slide-img" src="{{ slide.image }}" alt="{{ slide.caption | tloc(pair.locale.code) }}" loading="lazy">
    {% endif %}

    <div class="deck__slide-overlay">
      <p class="deck__caption">{{ slide.caption | tloc(pair.locale.code) }}</p>

      {% if slide.long_press %}
      <div class="deck__body">{{ slide.long_press | tloc(pair.locale.code) | safe }}</div>
      {% endif %}

      {% if slide.actions.length %}
      <div class="deck__actions">
        {% for action in slide.actions %}
          {% if action.type == "open_url" %}
          <a class="deck__action deck__action--link" href="{{ action.url }}" target="_blank" rel="noopener">
            {{ action.label }} →
          </a>
          {% elif action.type == "share" %}
          <button class="deck__action deck__action--share" data-action="share">
            {{ action.label }}
          </button>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </article>
  {% endfor %}

  <div class="deck__hint" id="deckHint">
    <span>tap →</span><span>swipe ↑ for depth</span><span>swipe ↓ to exit</span>
  </div>

{% if devMode %}{% include "dev-feedback.njk" %}{% endif %}
</div>

<script src="/assets/js/feed-deck.js?v={{ buildHash }}" defer></script>
