.comms__input--msg{min-width:0}
</style>

<script type="module">
import { joinRoom, selfId, createPersistentEvent, getRelaySockets } from '/assets/vendor/trystero-nostr.js';
import { MentriaBus } from '/assets/js/mentria-bus.js';
import { confirmInstall } from '/assets/js/mentria-ext-install-ui.js';

const RELAY = 'wss://relay.mentria.ai';
const TURN_CRED_URL = 'https://relay.mentria.ai/turn-cred';

let cachedIce = null;
let iceExpiry = 0;
const REFRESH_LEAD = 60;
const FALLBACK_ICE = [{ urls: 'stun:turn.mentria.ai:3478' }];

const getIce = async () => {
  const nowS = Date.now() / 1000;
  if (cachedIce && nowS < iceExpiry - REFRESH_LEAD) return cachedIce;
  try {
    const r = await fetch(TURN_CRED_URL, { cache: 'no-store' });
    if (!r.ok) throw new Error(`status ${r.status}`);
    const data = await r.json();
    iceExpiry = nowS + (data.ttl || 3600);
    cachedIce = data.iceServers || FALLBACK_ICE;
    return cachedIce;
  } catch (err) {
    console.warn('turn-cred fetch failed, using STUN-only fallback:', err);
    return FALLBACK_ICE;
  }
};

const $ = (id) => document.getElementById(id);
const els = {
  room: $('comms-room'), join: $('comms-join'),
  status: $('comms-status'), peers: $('comms-peers'), mute: $('comms-mute'), eph: $('comms-eph'), enc: $('comms-enc'),
  share: $('comms-share'), url: $('comms-url'), copy: $('comms-copy'), genkey: $('comms-genkey'),
  peerlist: $('comms-peerlist'),
  log: $('comms-log'), drop: $('comms-drop'), file: $('comms-file'),
  send: $('comms-send'), msg: $('comms-msg'), go: $('comms-go')
};

const MAX_FILE = 50 * 1024 * 1024;
const MAX_TOTAL_WARN = 100 * 1024 * 1024;

let room = null;
let chatAction = null;
let metaAction = null;
let chunkAction = null;
const peers = new Set();
let muted = localStorage.getItem('comms.muted') === '1';
let audioCtx = null;

const CHAT_TOPIC_PREFIX = 'mentria.chat.v1.';
const CHAT_KIND = 3838;
const EPHEMERAL_PREFIX = '!';
const HISTORY_LOOKBACK_SEC = 7 * 24 * 60 * 60;
const HISTORY_LIMIT = 100;
const HISTORY_FLUSH_TIMEOUT_MS = 4000;

let chatSubId = null;
let chatTopic = null;
let chatPersist = true;
let historyBuffered = false;
let historyBuffer = [];
let historyTimer = null;
let seenCmids = new Set();
const socketListenersAttached = new WeakSet();

const isEphemeralRoom = (name) => typeof name === 'string' && name.startsWith(EPHEMERAL_PREFIX);
const newCmid = () => selfId + ':' + Math.random().toString(36).slice(2);

let chatKey = null;

const b64encode = (bytes) => btoa(String.fromCharCode(...bytes));
const b64decode = (str) => Uint8Array.from(atob(str), c => c.charCodeAt(0));
const b64urlEncode = (bytes) => b64encode(bytes).replaceAll('+','-').replaceAll('/','_').replaceAll('=','');
const b64urlDecode = (str) => {
  const b64 = str.replaceAll('-','+').replaceAll('_','/');
  const padded = b64 + '='.repeat((4 - b64.length % 4) % 4);
  return b64decode(padded);
};

const parseHash = (hash) => {
  const raw = (hash || '').slice(1).trim();
  if (!raw) return { room: null, b64Key: null };
  const colonIdx = raw.indexOf(':');
  if (colonIdx === -1) return { room: raw, b64Key: null };
  return { room: raw.slice(0, colonIdx), b64Key: raw.slice(colonIdx + 1) || null };
};

const formatHash = (room, b64Key) => '#' + room + (b64Key ? ':' + b64Key : '');

const deriveKey = async (b64Key) => {
  try {
    const raw = b64urlDecode(b64Key);
    if (raw.length !== 32) throw new Error('key must be 32 bytes');
    return await crypto.subtle.importKey('raw', raw, { name: 'AES-GCM' }, false, ['encrypt', 'decrypt']);
  } catch (err) {
    console.warn('key parse failed:', err);
    return null;
  }
};

const encryptText = async (key, plaintext) => {
  const iv = crypto.getRandomValues(new Uint8Array(12));
  const ct = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, key, new TextEncoder().encode(plaintext));
  return { v: 1, iv: b64encode(iv), ct: b64encode(new Uint8Array(ct)) };
};

const decryptText = async (key, payload) => {
  if (!payload || payload.v !== 1) throw new Error('bad payload');
  const iv = b64decode(payload.iv);
  const ct = b64decode(payload.ct);
  const pt = await crypto.subtle.decrypt({ name: 'AES-GCM', iv }, key, ct);
  return new TextDecoder().decode(pt);
};

const short = (id) => id ? id.slice(0, 6) : 'unknown';

const peerColor = (id) => {
  let h = 0;
  for (let i = 0; i < (id || '').length; i++) h = (h * 31 + id.charCodeAt(i)) >>> 0;
  return `hsl(${h % 360}, 55%, 65%)`;
};

const escapeHtml = (s) => String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
const fmtKB = (n) => (n / 1024).toFixed(1) + ' KB';
const fmtMB = (n) => (n / 1024 / 1024).toFixed(1) + ' MB';
const fmtSize = (n) => n >= 1024 * 1024 ? fmtMB(n) : fmtKB(n);
const nowHHMM = () => { const d = new Date(); return String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0'); };

const playPing = (freq = 880) => {
  if (muted) return;
  try {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const ctx = audioCtx;
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.frequency.value = freq;
    osc.type = 'sine';
    const t = ctx.currentTime;
    gain.gain.setValueAtTime(0.0001, t);
    gain.gain.exponentialRampToValueAtTime(0.12, t + 0.01);
    gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.18);
    osc.connect(gain).connect(ctx.destination);
    osc.start(t);
    osc.stop(t + 0.22);
  } catch {}
};

const renderPeerList = () => {
  if (!peers.size) { els.peerlist.hidden = true; els.peerlist.innerHTML = ''; return; }
  els.peerlist.hidden = false;
  els.peerlist.innerHTML = '';
  peers.forEach(p => {
    const chip = document.createElement('span');
    chip.className = 'comms__chip';
    chip.style.color = peerColor(p);
    chip.textContent = short(p);
    chip.title = p;
    els.peerlist.append(chip);
  });
};

const renderLine = (who, what, opts = {}) => {
  const line = document.createElement('div');
  line.className = 'comms__line';
  const w = document.createElement('span');
  w.className = 'comms__who' + (opts.sys ? ' comms__who--sys' : opts.me ? ' comms__who--me' : '');
  w.textContent = who;
  if (opts.peerId) w.style.color = peerColor(opts.peerId);
  if (!opts.sys && !opts.me) {
    const time = document.createElement('span');
    time.className = 'comms__time';
    time.textContent = nowHHMM();
    w.append(time);
  }
  const t = document.createElement('span');
  t.className = 'comms__what' + (opts.sys ? ' comms__what--sys' : '');
  if (opts.html) t.innerHTML = opts.html; else t.textContent = what;
  line.append(w, t);
  els.log.append(line);
  els.log.scrollTop = els.log.scrollHeight;
  return { line, what: t };
};

const sys = (text) => renderLine('--', text, { sys: true });

const progressHTML = (verb, name, size, transferred) => {
  const pct = size > 0 ? Math.min(100, Math.round((transferred / size) * 100)) : 0;
  return `${verb} <strong>${escapeHtml(name)}</strong>` +
    ` <span class="comms__prog"><span class="comms__prog-fill" style="width:${pct}%"></span></span>` +
    ` <span class="comms__prog-text">${pct}% (${fmtKB(transferred)} / ${fmtKB(size)})</span>`;
};

const completeHTML = (name, size, type, url) => {
  const isImg = type && type.startsWith('image/');
  const preview = isImg ? `<br><a href="${url}" target="_blank" rel="noopener"><img class="comms__thumb" src="${url}" alt="${escapeHtml(name)}"></a>` : '';
  return `<a href="${url}" download="${escapeHtml(name)}">${escapeHtml(name)}</a> (${fmtKB(size)})${preview}`;
};

const updatePeers = () => {
  els.peers.textContent = `peers: ${peers.size}`;
  els.peers.hidden = false;
};

const refreshShareUrl = (roomName, b64Key) => {
  const u = new URL(window.location.href);
  u.hash = formatHash(roomName, b64Key);
  els.url.textContent = u.toString();
  els.share.hidden = false;
};

const renderRemoteChat = (item, opts = {}) => {
  renderLine(short(item.senderId), item.text, { peerId: item.senderId });
  if (!opts.silent) playPing(880);
};

const flushHistory = () => {
  if (!historyBuffered) return;
  historyBuffered = false;
  if (historyTimer) { clearTimeout(historyTimer); historyTimer = null; }
  historyBuffer.sort((a, b) => a.ts - b.ts);
  if (historyBuffer.length) {
    sys(`— recent history (${historyBuffer.length}) —`);
    historyBuffer.forEach(item => renderRemoteChat(item, { silent: true }));
    sys('— live —');
  }
  historyBuffer = [];
};

const handleNostrMsg = async (msgEvent) => {
  let msg;
  try { msg = JSON.parse(msgEvent.data); } catch { return; }
  if (!Array.isArray(msg)) return;
  if (msg[0] === 'EVENT' && msg[1] === chatSubId && msg[2]) {
    const ev = msg[2];
    let content;
    try { content = JSON.parse(ev.content); } catch { return; }
    if (!content || !content.cmid || seenCmids.has(content.cmid)) return;
    let text;
    if (content.enc) {
      if (!chatKey) return;
      try { text = await decryptText(chatKey, content.enc); } catch { return; }
    } else if (typeof content.text === 'string') {
      text = content.text;
    } else {
      return;
    }
    seenCmids.add(content.cmid);
    const senderId = (content.cmid.split(':')[0]) || ev.pubkey;
    const ts = (typeof content.ts === 'number' && content.ts > 0) ? content.ts : ((ev.created_at || 0) * 1000);
    const item = { senderId, text, ts };
    if (historyBuffered) historyBuffer.push(item);
    else renderRemoteChat(item);
  } else if (msg[0] === 'EOSE' && msg[1] === chatSubId) {
    flushHistory();
  }
};

const closeChatSub = () => {
  if (!chatSubId) return;
  const closeMsg = JSON.stringify(['CLOSE', chatSubId]);
  const sockets = getRelaySockets() || {};
  for (const ws of Object.values(sockets)) {
    try { ws.send(closeMsg); } catch {}
  }
};

const setupChatPersistence = async (roomName) => {
  chatTopic = CHAT_TOPIC_PREFIX + roomName;
  chatPersist = !isEphemeralRoom(roomName);
  seenCmids = new Set();

  if (!chatPersist) {
    historyBuffered = false;
    historyBuffer = [];
    chatSubId = null;
    sys('ephemeral room — messages aren\'t saved. drop the leading ! to persist.');
    return;
  }

  chatSubId = 'mc-' + Math.random().toString(36).slice(2);
  historyBuffered = true;
  historyBuffer = [];

  const deadline = Date.now() + 8000;
  let openSockets = [];
  while (Date.now() < deadline) {
    const socketsMap = getRelaySockets() || {};
    openSockets = Object.values(socketsMap).filter(ws => ws && ws.readyState === 1);
    if (openSockets.length > 0) break;
    await new Promise(r => setTimeout(r, 200));
  }
  if (!openSockets.length) {
    sys('relay unreachable — history disabled this session.');
    historyBuffered = false;
    return;
  }

  const sinceSec = Math.floor(Date.now() / 1000) - HISTORY_LOOKBACK_SEC;
  const req = JSON.stringify(['REQ', chatSubId, {
    kinds: [CHAT_KIND],
    '#x': [chatTopic],
    since: sinceSec,
    limit: HISTORY_LIMIT
  }]);

  for (const ws of openSockets) {
    try {
      if (!socketListenersAttached.has(ws)) {
        ws.addEventListener('message', handleNostrMsg);
        socketListenersAttached.add(ws);
      }
      ws.send(req);
    } catch (err) {
      console.warn('chat history setup failed for socket:', err);
    }
  }

  historyTimer = setTimeout(flushHistory, HISTORY_FLUSH_TIMEOUT_MS);
};

const publishChat = async (text, cmid) => {
  if (!chatTopic || !chatPersist) return;
  try {
    let payload;
    if (chatKey) {
      const enc = await encryptText(chatKey, text);
      payload = { cmid, ts: Date.now(), enc };
    } else {
      payload = { text, cmid, ts: Date.now() };
    }
    const eventStr = await createPersistentEvent(CHAT_KIND, chatTopic, JSON.stringify(payload));
    const sockets = getRelaySockets() || {};
    for (const ws of Object.values(sockets)) {
      if (ws && ws.readyState === 1) {
        try { ws.send(eventStr); } catch {}
      }
    }
  } catch (err) {
    console.warn('chat publish failed:', err);
  }
};

const joinNew = async (roomName, b64Key = null) => {
  if (room) {
    closeChatSub();
    try { await room.leave(); } catch {}
    room = null;
    chatAction = metaAction = chunkAction = null;
    peers.clear();
    if (historyTimer) { clearTimeout(historyTimer); historyTimer = null; }
    historyBuffered = false;
    historyBuffer = [];
    chatSubId = null;
    chatTopic = null;
    chatKey = null;
  }
  els.log.innerHTML = '';
  els.status.textContent = 'connecting…';
  els.peers.hidden = true;
  els.enc.hidden = true;

  chatKey = b64Key ? await deriveKey(b64Key) : null;
  if (b64Key && !chatKey) sys('encryption key in URL is invalid — chat will appear unreadable.');

  window.location.hash = formatHash(roomName, b64Key);
  refreshShareUrl(roomName, b64Key);

  let iceServers;
  try {
    iceServers = await getIce();
  } catch {
    iceServers = FALLBACK_ICE;
  }

  try {
    room = joinRoom(
      {
        appId: 'mentria',
        relayConfig: { urls: [RELAY] },
        rtcConfig: { iceServers }
      },
      roomName
    );
  } catch (err) {
    sys(`failed to join: ${err.message}`);
    els.status.textContent = 'error';
    return;
  }

  els.status.textContent = `room: ${roomName}`;
  els.eph.hidden = !isEphemeralRoom(roomName);
  els.enc.hidden = !chatKey;
  els.msg.disabled = false;
  els.go.disabled = false;
  updatePeers();
  sys(`you are ${short(selfId)} — alone in "${roomName}". share the URL to invite someone.`);
  if (chatKey) sys('end-to-end encrypted. anyone with the full URL (including the key after the colon) can decrypt.');

  chatAction = room.makeAction('chat');
  chatAction.onMessage = async (data, ctx) => {
    const cmid = data && data.cmid;
    if (cmid && seenCmids.has(cmid)) return;
    let text;
    if (data && data.enc) {
      if (!chatKey) return;
      try { text = await decryptText(chatKey, data.enc); } catch { return; }
    } else {
      text = String(data && data.text || '');
    }
    if (cmid) seenCmids.add(cmid);
    if (historyBuffered) {
      historyBuffer.push({ senderId: ctx.peerId, text, ts: Date.now() });
      return;
    }
    renderLine(short(ctx.peerId), text, { peerId: ctx.peerId });
    playPing(880);
  };

  const incoming = new Map();
  metaAction = room.makeAction('fmeta');
  metaAction.onMessage = (meta, ctx) => {
    const line = renderLine(short(ctx.peerId), '', { peerId: ctx.peerId, html: progressHTML('receiving', meta.name, meta.size, 0) });
    incoming.set(ctx.peerId + ':' + meta.id, { meta, chunks: [], received: 0, line });
  };

  chunkAction = room.makeAction('fchunk');
  chunkAction.onMessage = (data, ctx) => {
    const m = ctx.metadata || {};
    const key = ctx.peerId + ':' + m.id;
    const entry = incoming.get(key);
    if (!entry) return;
    entry.chunks.push(data);
    entry.received += (data.byteLength || data.size || 0);
    entry.line.what.innerHTML = progressHTML('receiving', entry.meta.name, entry.meta.size, entry.received);
    if (m.done) {
      const blob = new Blob(entry.chunks, { type: entry.meta.type || 'application/octet-stream' });
      const url = URL.createObjectURL(blob);
      entry.line.what.innerHTML = 'received ' + completeHTML(entry.meta.name, entry.meta.size, entry.meta.type, url);
      incoming.delete(key);
      playPing(660);
    }
  };

  room.onPeerJoin = (peerId) => {
    peers.add(peerId);
    updatePeers();
    renderPeerList();
    sys(`${short(peerId)} joined`);
  };
  room.onPeerLeave = (peerId) => {
    peers.delete(peerId);
    updatePeers();
    renderPeerList();
    sys(`${short(peerId)} left`);
  };

  setupChatPersistence(roomName);

  MentriaBus.provide('comms.peers', () => ({ count: peers.size }), { description: 'Number of connected comms peers.', parameters: { type: 'object', properties: {} }, ai: false });
  MentriaBus.provide('comms.share', async ({ filename, html, name }) => {
    if (!metaAction || !chunkAction) throw new Error('comms not connected');
    if (peers.size === 0) throw new Error('no peers to send to');
    const file = new File([html], filename || 'extension.html', { type: 'text/html' });
    await sendOne(file, { kind: 'mentria-ext', extName: name });
    return { sentTo: peers.size };
  }, { description: 'Send an extension to connected comms peers.', parameters: { type: 'object', properties: { filename: { type: 'string' }, html: { type: 'string' }, name: { type: 'string' } }, required: ['html'] }, ai: false });
};

els.join.addEventListener('click', () => {
  const name = (els.room.value || (EPHEMERAL_PREFIX + randomRoomSlug())).trim().slice(0, 64);
  const { b64Key } = parseHash(window.location.hash);
  joinNew(name, b64Key);
});

els.genkey.addEventListener('click', async () => {
  const bytes = crypto.getRandomValues(new Uint8Array(32));
  const key = b64urlEncode(bytes);
  const name = (els.room.value || (EPHEMERAL_PREFIX + randomRoomSlug())).trim().slice(0, 64);
  await joinNew(name, key);
  try {
    await navigator.clipboard.writeText(window.location.href);
    els.genkey.textContent = 'key generated · url copied';
    setTimeout(() => { els.genkey.textContent = '+ key'; }, 2000);
  } catch {
    els.genkey.textContent = 'key generated';
    setTimeout(() => { els.genkey.textContent = '+ key'; }, 2000);
  }
});

els.send.addEventListener('submit', async (e) => {
  e.preventDefault();
  const text = els.msg.value.trim();
  if (!text || !chatAction) return;
  const cmid = newCmid();
  seenCmids.add(cmid);
  let livePayload;
  if (chatKey) {
    try {
      const enc = await encryptText(chatKey, text);
      livePayload = { cmid, enc };
    } catch (err) {
      sys('encryption failed: ' + err.message);
      return;
    }
  } else {
    livePayload = { text, cmid };
  }
  chatAction.send(livePayload);
  publishChat(text, cmid);
  renderLine('you', text, { me: true });
  els.msg.value = '';
});

els.copy.addEventListener('click', async () => {
  try { await navigator.clipboard.writeText(els.url.textContent); els.copy.textContent = 'copied'; setTimeout(() => els.copy.textContent = 'copy', 1200); } catch {}
});

const dragEvents = ['dragenter', 'dragover'];
const undragEvents = ['dragleave', 'drop'];
dragEvents.forEach(ev => els.drop.addEventListener(ev, (e) => { e.preventDefault(); els.drop.classList.add('comms__drop--hot'); }));
undragEvents.forEach(ev => els.drop.addEventListener(ev, (e) => { e.preventDefault(); els.drop.classList.remove('comms__drop--hot'); }));
const CHUNK = 32 * 1024;
const sendOne = async (file, extra) => {
  const id = Math.random().toString(36).slice(2);
  const line = renderLine('you', '', { me: true, html: progressHTML('sending', file.name, file.size, 0) });
  await metaAction.send(Object.assign({ id, name: file.name, size: file.size, type: file.type }, extra || {}));
  const buf = await file.arrayBuffer();
  let sent = 0;
  for (let offset = 0; offset < buf.byteLength; offset += CHUNK) {
    const slice = buf.slice(offset, Math.min(offset + CHUNK, buf.byteLength));
    const done = offset + CHUNK >= buf.byteLength;
    await chunkAction.send(slice, { metadata: { id, done } });
    sent += slice.byteLength;
    line.what.innerHTML = progressHTML('sending', file.name, file.size, sent);
  }
  const previewUrl = URL.createObjectURL(file);
  line.what.innerHTML = 'sent ' + completeHTML(file.name, file.size, file.type, previewUrl);
};

const sendFiles = async (fileList) => {
  if (!metaAction || !chunkAction || peers.size === 0) { sys('no peers to send to.'); return; }
  const all = Array.from(fileList || []);
  if (!all.length) return;
  const tooBig = all.filter(f => f.size > MAX_FILE);
  const ok = all.filter(f => f.size <= MAX_FILE);
  if (tooBig.length) {
    sys(`skipped (over ${fmtMB(MAX_FILE)} cap): ${tooBig.map(f => `${f.name} ${fmtSize(f.size)}`).join(', ')}`);
  }
  if (!ok.length) return;
  const total = ok.reduce((s, f) => s + f.size, 0);
  if (ok.length > 1) sys(`sending ${ok.length} file${ok.length===1?'':'s'} (${fmtSize(total)}) to ${peers.size} peer${peers.size===1?'':'s'}…`);
  if (total > MAX_TOTAL_WARN) sys(`heads up: ${fmtSize(total)} total — this may take a while.`);
  for (const file of ok) {
    try { await sendOne(file); } catch (err) { sys(`send failed for ${file.name}: ${err.message}`); }
  }
};

els.drop.addEventListener('drop', (e) => { sendFiles(e.dataTransfer.files); });
els.file.addEventListener('change', (e) => { sendFiles(e.target.files); e.target.value = ''; });

const attachExtBtn = document.getElementById('comms-attach-ext');
attachExtBtn.addEventListener('click', async () => {
  if (peers.size === 0) { sys('no peers to send to.'); return; }
  let list;
  try { list = await MentriaBus.invoke('extensions.list'); } catch (e) { sys('extensions unavailable: ' + e.message); return; }
  if (!list.length) { sys('no installed extensions to share.'); return; }
  const names = list.map((e, i) => (i + 1) + ') ' + e.name + ' v' + e.version).join('\n');
  const pick = window.prompt('share which extension?\n' + names, '1');
  const idx = pick ? parseInt(pick, 10) - 1 : -1;
  if (!(idx >= 0 && idx < list.length)) return;
  const chosen = list[idx];
  let html;
  try { html = await MentriaBus.invoke('extensions.getSource', { id: chosen.id }); } catch (e) { sys('could not read extension: ' + e.message); return; }
  if (!html) { sys('extension source missing.'); return; }
  try {
    const file = new File([html], chosen.id + '.html', { type: 'text/html' });
    await sendOne(file, { kind: 'mentria-ext', extName: chosen.name });
  } catch (e) { sys('send failed: ' + e.message); }
});

els.mute.addEventListener('click', () => {
  muted = !muted;
  els.mute.textContent = muted ? 'sound: off' : 'sound: on';
  els.mute.setAttribute('aria-pressed', String(muted));
  localStorage.setItem('comms.muted', muted ? '1' : '0');
  if (!muted) playPing(880);
});
if (muted) { els.mute.textContent = 'sound: off'; els.mute.setAttribute('aria-pressed', 'true'); }

function randomRoomSlug() {
  const bytes = crypto.getRandomValues(new Uint8Array(5));
  const alpha = 'abcdefghijklmnopqrstuvwxyz234567';
  let bits = 0, value = 0, out = '';
  for (let i = 0; i < bytes.length; i++) {
    value = (value << 8) | bytes[i]; bits += 8;
    while (bits >= 5) { out += alpha[(value >>> (bits - 5)) & 0x1f]; bits -= 5; }
  }
  return out;
}

let initialRoom, initialKey;
const hasHash = window.location.hash && window.location.hash !== '#';
if (hasHash) {
  const parsed = parseHash(window.location.hash);
  initialRoom = parsed.room;
  initialKey = parsed.b64Key;
} else {
  initialRoom = EPHEMERAL_PREFIX + randomRoomSlug();
  initialKey = b64urlEncode(crypto.getRandomValues(new Uint8Array(32)));
  window.history.replaceState(null, '', formatHash(initialRoom, initialKey));
}
els.room.value = initialRoom;
refreshShareUrl(initialRoom, initialKey);
window.addEventListener('load', () => joinNew(initialRoom, initialKey));
window.addEventListener('hashchange', () => {
  const next = parseHash(window.location.hash);
  const sameRoom = next.room === (els.room.value || '').trim();
  const sameKey = next.b64Key === (chatKey ? next.b64Key : null);
  if (!sameRoom || !sameKey) {
    els.room.value = next.room;
    joinNew(next.room, next.b64Key);
  }
});
</script>
