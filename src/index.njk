---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'nav.home' | t }}"
  description: "{{ 'site.metaDescription' | t }}"
---
<section class="cli grid-bg">
    <div class="cli__output" role="log" aria-live="polite"></div>
    <div class="cli__prompt-line">
        <span class="cli__prompt">$&nbsp;</span>
        <input type="text" class="cli__input" aria-label="{{ 'home.cli.placeholder' | t }}" placeholder="{{ 'home.cli.placeholder' | t }}" autocomplete="off" spellcheck="false">
    </div>
    <div class="cli__suggestions" id="cli-suggestions" popover="manual" role="listbox" aria-label="Command suggestions"></div>
</section>

{% include "tool-launcher.njk" %}
<script src="/assets/js/tool-launcher.js?v={{ buildHash }}"></script>
<script src="/assets/js/mentria-ext-launch.js" defer></script>

<script>
  // Welcome lines for the home CLI, localized per page.
  window.MENTRIA_CLI_WELCOME = {
    cmd:  {{ ("home.cli.welcomeCmd"  | t) | dump | safe }},
    out1: {{ ("home.cli.welcomeOut1" | t) | dump | safe }},
    out2: {{ ("home.cli.welcomeOut2" | t) | dump | safe }}
  };
</script>
<script src="/assets/js/mentria-cli.js"></script>
