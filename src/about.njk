---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/about/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'about.title' | t }}"
  description: "{{ 'about.meta_description' | t }}"
---
<div class="about-page">

  <div class="about-hero reveal">
    <p class="about-crumb"><a href="{{ locale.pathPrefix }}/">~</a><span class="slash">/</span>about</p>
    <h1 class="about-wordmark">MENTRIA<span class="underscore">_</span></h1>
    <p class="about-tagline">{{ "about.tagline" | t }}</p>
  </div>

  <section class="reveal">
    <div class="about-section-label">{{ "about.s1_label" | t }}</div>
    <div class="about-essay">
      <p>{{ "about.s1_p1" | t }}</p>
      <p>{{ "about.s1_p2" | t | safe }}</p>
      <span class="about-estd">estd. 2025</span>
    </div>
  </section>

  <section class="reveal">
    <div class="about-section-label">{{ "about.ship_label" | t }}</div>
    <h2 class="about-section-h">{{ "about.ship_h" | t }}</h2>
    {% set postCount = collections.post | length %}
    {% set maxCount = shelves.utility if shelves.utility > shelves.games else shelves.games %}
    {% set maxCount = maxCount if maxCount > shelves.ai else shelves.ai %}
    {% set maxCount = maxCount if maxCount > postCount else postCount %}
    <div class="about-ship-grid">
      <a class="about-ship-card amber" href="{{ '/tools/' | localeUrl(lang) }}">
        <span class="about-ship-num">{{ shelves.utility }}</span>
        <span class="about-ship-label">{{ "about.shelf_tools" | t }}</span>
        <div class="about-units" aria-hidden="true">{% for i in range(0, maxCount) %}<i class="unit{% if i < shelves.utility %} on{% endif %}" style="--i:{{ i }}"></i>{% endfor %}</div>
      </a>
      <a class="about-ship-card pink" href="{{ '/tools/' | localeUrl(lang) }}">
        <span class="about-ship-num">{{ shelves.games }}</span>
        <span class="about-ship-label">{{ "about.shelf_games" | t }}</span>
        <div class="about-units" aria-hidden="true">{% for i in range(0, maxCount) %}<i class="unit{% if i < shelves.games %} on{% endif %}" style="--i:{{ i }}"></i>{% endfor %}</div>
      </a>
      <a class="about-ship-card cyan" href="{{ '/tools/' | localeUrl(lang) }}">
        <span class="about-ship-num">{{ shelves.ai }}</span>
        <span class="about-ship-label">{{ "about.shelf_ai" | t }}</span>
        <div class="about-units" aria-hidden="true">{% for i in range(0, maxCount) %}<i class="unit{% if i < shelves.ai %} on{% endif %}" style="--i:{{ i }}"></i>{% endfor %}</div>
      </a>
      <a class="about-ship-card purple" href="{{ '/feed/' | localeUrl(lang) }}">
        <span class="about-ship-num">{{ collections.post | length }}</span>
        <span class="about-ship-label">{{ "about.shelf_writing" | t }}</span>
        <div class="about-units" aria-hidden="true">{% for i in range(0, maxCount) %}<i class="unit{% if i < postCount %} on{% endif %}" style="--i:{{ i }}"></i>{% endfor %}</div>
      </a>
    </div>
  </section>

  <section class="reveal">
    <div class="about-section-label">{{ "about.stack_label" | t }}</div>
    <h2 class="about-section-h">{{ "about.stack_h" | t }}</h2>
    <div class="about-stack">
      <div class="about-stack-row"><span class="bullet">·</span> <span>{{ "about.stack_1" | t }}</span></div>
      <div class="about-stack-row"><span class="bullet">·</span> <span>{{ "about.stack_2" | t }}</span></div>
      <div class="about-stack-row"><span class="bullet">·</span> <span>{{ "about.stack_3" | t }}</span></div>
      <div class="about-stack-row"><span class="bullet">·</span> <span>{{ "about.stack_4" | t }}</span></div>
      <div class="about-stack-row"><span class="bullet">·</span> <span>{{ "about.stack_5" | t }}</span></div>
    </div>
  </section>

  <section class="reveal">
    <div class="about-section-label">{{ "about.principles_label" | t }}</div>
    <h2 class="about-section-h">{{ "about.principles_h" | t }}</h2>
    <div class="about-principles">
      <div class="about-principle"><span class="num">01</span><span class="text">{{ "about.principle_1" | t }}</span></div>
      <div class="about-principle"><span class="num">02</span><span class="text">{{ "about.principle_2" | t }}</span></div>
      <div class="about-principle"><span class="num">03</span><span class="text">{{ "about.principle_3" | t }}</span></div>
    </div>
  </section>

  <section class="reveal about-data">
    <h2 class="about-section-h">{{ "about.data_section_title" | t }}</h2>
    <p class="about-tagline" style="margin-bottom: 20px;">{{ "about.data_section_lede" | t }}</p>

    <div class="about-data-stats">
      <div class="about-data-stat">
        <span class="about-data-stat__label">{{ "about.data_persist_status_granted" | t | upper }}</span>
        <span class="about-data-stat__value" id="about-data-persist">…</span>
      </div>
      <div class="about-data-stat">
        <span class="about-data-stat__label">USAGE</span>
        <span class="about-data-stat__value" id="about-data-usage">…</span>
      </div>
    </div>

    <div class="about-data-grid">
      <div class="about-data-card">
        <h3 class="about-data-card__h">{{ "about.data_export_title" | t }}</h3>
        <p class="about-data-card__p">{{ "about.data_export_lede" | t }}</p>
        <label class="about-data-field">
          <span>{{ "about.data_pass_label" | t }}</span>
          <input type="password" id="about-data-pass" autocomplete="new-password" spellcheck="false">
        </label>
        <div class="about-data-strength" id="about-data-strength" aria-live="polite"></div>
        <label class="about-data-field">
          <span>{{ "about.data_pass_confirm" | t }}</span>
          <input type="password" id="about-data-pass2" autocomplete="new-password" spellcheck="false">
        </label>
        <button type="button" class="about-data-btn" id="about-data-export-btn">{{ "about.data_export_button" | t }}</button>
        <div class="about-data-status" id="about-data-export-status" aria-live="polite"></div>
      </div>

      <div class="about-data-card">
        <h3 class="about-data-card__h">{{ "about.data_import_title" | t }}</h3>
        <p class="about-data-card__p">{{ "about.data_import_lede" | t }}</p>
        <label class="about-data-field">
          <span>{{ "about.data_import_choose" | t }}</span>
          <input type="file" id="about-data-import-file" accept="application/json,.json">
        </label>
        <label class="about-data-field">
          <span>{{ "about.data_pass_label" | t }}</span>
          <input type="password" id="about-data-import-pass" autocomplete="current-password" spellcheck="false">
        </label>
        <button type="button" class="about-data-btn about-data-btn--ghost" id="about-data-import-btn">{{ "about.data_import_button" | t }}</button>
        <div class="about-data-status" id="about-data-import-status" aria-live="polite"></div>
      </div>
    </div>
  </section>

  <section class="reveal about-sync">
    <h2 class="about-section-h">{{ "about.sync_section_title" | t }}</h2>
    <p class="about-tagline" style="margin-bottom: 20px;">{{ "about.sync_section_lede" | t }}</p>

    <div class="about-data-grid">
      <div class="about-data-card">
        <h3 class="about-data-card__h">{{ "about.sync_pair_title" | t }}</h3>
        <p class="about-data-card__p">{{ "about.sync_pair_lede" | t }}</p>
        <button type="button" class="about-data-btn" id="about-sync-start-btn">{{ "about.sync_pair_button" | t }}</button>
        <div class="about-sync-code" id="about-sync-code" hidden>
          <div class="about-sync-code__label">{{ "about.sync_pair_show_code" | t }}</div>
          <code class="about-sync-code__value" id="about-sync-code-value"></code>
        </div>
      </div>

      <div class="about-data-card">
        <h3 class="about-data-card__h">{{ "about.sync_join_title" | t }}</h3>
        <p class="about-data-card__p">{{ "about.sync_join_lede" | t }}</p>
        <label class="about-data-field">
          <span>{{ "about.sync_join_label" | t }}</span>
          <input type="text" id="about-sync-code-input" autocomplete="off" spellcheck="false" placeholder="XXXX-XXXX-XXXX-XXXX">
        </label>
        <button type="button" class="about-data-btn about-data-btn--ghost" id="about-sync-join-btn">{{ "about.sync_join_button" | t }}</button>
      </div>
    </div>

    <div class="about-sync-status" id="about-sync-status">
      <span class="about-sync-status__label" id="about-sync-status-label">{{ "about.sync_status_idle" | t }}</span>
      <button type="button" class="about-data-btn about-data-btn--ghost" id="about-sync-disconnect-btn" hidden>{{ "about.sync_disconnect" | t }}</button>
    </div>
  </section>

  <div class="about-end reveal">
    <div class="left">
      <a class="about-contact-link" href="https://x.com/mentria_ai">{{ "about.contact" | t }}</a>
      <span class="about-build">build <span class="h">{{ buildHash }}</span></span>
      <button type="button" class="about-refresh" id="about-refresh" aria-label="{{ 'about.update_check' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        <span class="about-refresh__label">{{ "about.update_check" | t }}</span>
      </button>
      <button type="button" class="about-refresh about-refresh--hard" id="about-clear" aria-label="{{ 'about.cache_clear' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
        <span class="about-refresh__label">{{ "about.cache_clear" | t }}</span>
      </button>
    </div>
    <div class="right">
      <div class="about-socials">
        <a href="https://github.com/mentria-ai" aria-label="GitHub" title="GitHub" rel="me noopener" target="_blank">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.5-.3-5.2-1.3-5.2-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.7.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.2 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
        </a>
        <a href="https://huggingface.co/mentriaai" aria-label="Hugging Face" title="Hugging Face" rel="me noopener" target="_blank">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="9" cy="10.5" r="1.2" fill="currentColor"/><circle cx="15" cy="10.5" r="1.2" fill="currentColor"/><path d="M8.5 14.5c1 1.4 2.2 2 3.5 2s2.5-.6 3.5-2"/></svg>
        </a>
        <a href="https://x.com/mentria_ai" aria-label="X" title="X" rel="me noopener" target="_blank">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21.5l-7.46 8.53L23 22h-6.84l-5.36-7-6.13 7H1.41l7.98-9.12L1 2h7.02l4.85 6.42L18.244 2zm-2.4 18h1.9L7.27 4h-2L15.844 20z"/></svg>
        </a>
      </div>
      <span class="about-build">© <span id="about-year">2026</span></span>
    </div>
  </div>

</div>

<style>
  .about-page { position: relative; }
  .about-page::before { content: ""; position: absolute; top: -40px; left: 50%; transform: translateX(-50%); width: 100%; height: 30%; background: var(--gradient-aura); pointer-events: none; z-index: 0; }

  .about-hero { text-align: center; padding: 56px 0 48px; position: relative; z-index: 1; }
  .about-crumb { font-size: var(--text-xs); color: var(--term-muted); letter-spacing: 0.12em; margin: 0 0 18px; }
  .about-crumb .slash { color: var(--syn-cyan); }
  .about-crumb a { color: inherit; text-decoration: none; transition: color 120ms; }
  .about-crumb a:hover { color: var(--syn-cyan); }
  .about-wordmark { font-family: 'mentrialogofont', var(--font-mono); font-weight: 700; font-size: clamp(2.4rem, 9vw, 6rem); letter-spacing: 0; color: var(--term-fg-strong); margin: 0; line-height: 0.95; text-shadow: 0 0 30px rgba(34,211,238,0.18); }
  .about-wordmark .underscore { font-family: var(--font-mono); color: var(--syn-cyan); text-shadow: 0 0 18px rgba(34,211,238,0.55); animation: about-blink 1s steps(2, end) infinite; display: inline-block; }
  @keyframes about-blink { 0%,49% { opacity: 1; } 50%,100% { opacity: 0; } }
  .about-tagline { color: var(--term-muted); font-size: 14px; margin-top: 22px; letter-spacing: 0.02em; }

  .about-page section { position: relative; z-index: 1; padding: 56px 0; border-top: 1px solid var(--term-divider); }
  .about-page section:first-of-type { border-top: none; }
  .about-section-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em; color: var(--term-muted); font-weight: 500; margin-bottom: 24px; display: flex; align-items: center; gap: 10px; }
  .about-section-label::before { content: "§"; color: var(--syn-cyan); font-weight: 700; }
  .about-section-h { font-family: var(--font-mono); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: var(--term-fg-strong); margin: 0 0 20px; letter-spacing: -0.005em; }

  .about-essay { max-width: 56ch; font-family: var(--font-body, var(--font-mono)); }
  .about-essay p { color: var(--term-fg); font-size: 16px; line-height: 1.7; margin: 0 0 18px; }
  .about-essay strong { color: var(--term-fg-strong); font-weight: 600; }
  .about-estd { display: block; margin-top: 28px; font-family: var(--font-mono); font-size: 11px; color: var(--term-muted); letter-spacing: 0.18em; text-transform: uppercase; }
  .about-estd::before { content: "// "; color: var(--syn-cyan); }

  .about-ship-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  .about-ship-card { --accent: var(--syn-cyan); --accent-rgb: 34,211,238; background: var(--term-bg-raised); border: 1px solid var(--term-border); border-radius: var(--radius-lg); padding: 22px 20px 18px; text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 10px; transition: border-color 200ms, box-shadow 200ms, transform 200ms; position: relative; overflow: hidden; }
  .about-ship-card.cyan { --accent: var(--syn-cyan); --accent-rgb: 34,211,238; }
  .about-ship-card.pink { --accent: var(--syn-pink); --accent-rgb: 244,114,182; }
  .about-ship-card.purple { --accent: var(--syn-purple); --accent-rgb: 167,139,250; }
  .about-ship-card.amber { --accent: var(--syn-amber); --accent-rgb: 251,191,36; }
  .about-ship-card::after { content: "→"; position: absolute; top: 16px; right: 18px; color: var(--term-subtle); font-size: 14px; transition: all 200ms; }
  .about-ship-card:hover { border-color: rgba(var(--accent-rgb), 0.45); box-shadow: 0 0 20px rgba(var(--accent-rgb), 0.15); transform: translateY(-2px); }
  .about-ship-card:hover::after { color: var(--accent); transform: translate(2px, -2px); }
  .about-ship-num { font-family: var(--font-mono); font-size: 36px; font-weight: 700; line-height: 1; color: var(--accent); letter-spacing: -0.02em; text-shadow: 0 0 14px rgba(var(--accent-rgb), 0.35); }
  .about-ship-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--term-muted); font-weight: 500; }
  .about-units { margin-top: auto; display: flex; align-items: flex-end; gap: 4px; height: 34px; }
  .about-units .unit { flex: 1; height: 36%; border-radius: 3px; background: rgba(var(--accent-rgb), 0.12); transform-origin: bottom; }
  .about-units .unit.on { height: 100%; background: var(--accent); box-shadow: 0 0 8px rgba(var(--accent-rgb), 0.45); }
  .reveal .about-units .unit { opacity: 0; transform: scaleY(0.25); }
  .reveal.revealed .about-units .unit { opacity: 1; transform: scaleY(1); transition: opacity 0.35s ease, transform 0.5s cubic-bezier(0.2, 1, 0.3, 1); transition-delay: calc(var(--i) * 35ms); }
  @media (prefers-reduced-motion: reduce) {
    .reveal .about-units .unit, .reveal.revealed .about-units .unit { opacity: 1; transform: none; transition: none; }
  }

  .about-stack { border-left: 2px solid var(--cyan-30); padding: 4px 0 4px 22px; display: flex; flex-direction: column; gap: 12px; }
  .about-stack-row { font-family: var(--font-mono); font-size: 14px; color: var(--term-fg); display: flex; gap: 12px; align-items: baseline; }
  .about-stack-row .bullet { color: var(--syn-cyan); flex-shrink: 0; font-weight: 700; }

  .about-principles { display: flex; flex-direction: column; gap: 18px; }
  .about-principle { display: flex; align-items: baseline; gap: 24px; padding: 14px 0; border-bottom: 1px solid var(--term-divider); }
  .about-principle:last-child { border-bottom: none; }
  .about-principle .num { font-family: var(--font-mono); font-weight: 700; font-size: clamp(2rem, 5vw, 3rem); color: var(--syn-cyan); line-height: 1; text-shadow: 0 0 14px rgba(34,211,238,0.35); letter-spacing: -0.02em; flex-shrink: 0; min-width: 80px; }
  .about-principle .text { font-family: var(--font-mono); font-weight: 600; font-size: clamp(1.1rem, 2.4vw, 1.6rem); color: var(--term-fg-strong); letter-spacing: -0.005em; }

  .about-end { margin-top: 60px; padding: 24px 0; border-top: 1px solid var(--term-border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; font-size: 12px; color: var(--term-muted); }
  .about-end a { color: var(--term-fg); text-decoration: none; transition: color 120ms; }
  .about-end a:hover { color: var(--syn-cyan); }
  .about-end .left, .about-end .right { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .about-socials { display: flex; gap: 14px; }
  .about-socials a { display: inline-flex; width: 28px; height: 28px; align-items: center; justify-content: center; border: 1px solid var(--term-border); border-radius: 6px; transition: all 150ms; }
  .about-socials a:hover { border-color: var(--cyan-30); color: var(--syn-cyan); box-shadow: var(--glow-cyan-soft); }
  .about-socials svg { width: 14px; height: 14px; }
  .about-build { font-family: var(--font-mono); font-size: 11px; color: var(--term-subtle); }
  .about-build .h { color: var(--syn-cyan); }
  .about-refresh { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 11px; padding: 3px 10px; border: 1px solid var(--term-border); border-radius: 999px; background: transparent; color: var(--term-subtle); cursor: pointer; transition: color 120ms, border-color 120ms; }
  .about-refresh:hover { color: var(--syn-cyan); border-color: var(--syn-cyan); }
  .about-refresh:disabled { cursor: default; }
  .about-refresh svg { width: 12px; height: 12px; flex-shrink: 0; }
  .about-refresh.is-busy svg { animation: about-spin 0.8s linear infinite; }
  .about-refresh--hard.is-busy svg { animation: about-shake 0.32s ease-in-out infinite; }
  .about-refresh--hard:hover { color: var(--syn-amber, #f7b015); border-color: var(--syn-amber, #f7b015); }
  @keyframes about-spin { to { transform: rotate(360deg); } }
  @keyframes about-shake {
    0%, 100% { transform: translateX(0) rotate(0); }
    25%      { transform: translateX(-1.6px) rotate(-4deg); }
    75%      { transform: translateX(1.6px)  rotate(4deg); }
  }
  @media (prefers-reduced-motion: reduce) { .about-refresh.is-busy svg { animation: none; } }
  .about-contact-link { font-family: var(--font-mono); padding: 6px 12px; border: 1px solid var(--term-border); border-radius: 6px; }
  .about-contact-link::before { content: "$ "; color: var(--syn-cyan); }

  .about-data-stats { display: flex; gap: 24px; flex-wrap: wrap; margin-bottom: 24px; font-family: var(--font-mono); font-size: 12px; }
  .about-data-stat { display: flex; flex-direction: column; gap: 4px; }
  .about-data-stat__label { color: var(--term-subtle); letter-spacing: 0.1em; font-size: 10px; }
  .about-data-stat__value { color: var(--term-fg); font-size: 13px; }
  .about-data-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .about-data-card { border: 1px solid var(--term-border); border-radius: 8px; padding: 18px; background: var(--term-bg-raised); display: flex; flex-direction: column; gap: 10px; }
  .about-data-card__h { font-family: var(--font-mono); font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--syn-cyan); margin: 0; }
  .about-data-card__p { font-size: 12px; line-height: 1.5; color: var(--term-muted); margin: 0; }
  .about-data-field { display: flex; flex-direction: column; gap: 4px; font-family: var(--font-mono); font-size: 11px; color: var(--term-muted); }
  .about-data-field input[type="password"], .about-data-field input[type="file"] { background: var(--term-bg); border: 1px solid var(--term-border); color: var(--term-fg); padding: 7px 9px; border-radius: 5px; font-family: inherit; font-size: 13px; }
  .about-data-field input[type="password"]:focus { outline: none; border-color: var(--syn-cyan); }
  .about-data-strength { font-family: var(--font-mono); font-size: 10px; min-height: 14px; letter-spacing: 0.1em; }
  .about-data-strength[data-level="weak"]   { color: var(--syn-red, #f25fa8); }
  .about-data-strength[data-level="medium"] { color: var(--syn-amber, #f7b015); }
  .about-data-strength[data-level="strong"] { color: var(--syn-green, #34c46a); }
  .about-data-btn { background: transparent; border: 1px solid var(--syn-cyan); color: var(--syn-cyan); padding: 8px 14px; border-radius: 6px; font-family: var(--font-mono); font-size: 12px; cursor: pointer; transition: background 120ms, color 120ms; margin-top: 4px; }
  .about-data-btn:hover:not(:disabled) { background: var(--syn-cyan); color: var(--term-bg); }
  .about-data-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .about-data-btn--ghost { border-color: var(--term-border); color: var(--term-fg); }
  .about-data-btn--ghost:hover:not(:disabled) { background: var(--term-bg-raised); color: var(--syn-cyan); border-color: var(--syn-cyan); }
  .about-data-status { font-family: var(--font-mono); font-size: 11px; min-height: 14px; color: var(--term-muted); }
  .about-data-status[data-tone="ok"]   { color: var(--syn-green, #34c46a); }
  .about-data-status[data-tone="err"]  { color: var(--syn-red, #f25fa8); }
  @media (max-width: 600px) { .about-data-grid { grid-template-columns: 1fr; } }

  .about-sync-code { margin-top: 8px; display: flex; flex-direction: column; gap: 4px; }
  .about-sync-code__label { font-family: var(--font-mono); font-size: 10px; color: var(--term-subtle); letter-spacing: 0.1em; }
  .about-sync-code__value { font-family: var(--font-mono); font-size: 16px; letter-spacing: 0.08em; color: var(--syn-cyan); padding: 8px 12px; background: var(--term-bg); border: 1px solid var(--syn-cyan); border-radius: 5px; word-break: break-all; user-select: all; }
  .about-data-field input[type="text"] { background: var(--term-bg); border: 1px solid var(--term-border); color: var(--term-fg); padding: 7px 9px; border-radius: 5px; font-family: var(--font-mono); font-size: 13px; letter-spacing: 0.05em; }
  .about-data-field input[type="text"]:focus { outline: none; border-color: var(--syn-cyan); }
  .about-sync-status { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-top: 22px; padding: 12px 18px; border: 1px dashed var(--term-border); border-radius: 8px; }
  .about-sync-status__label { font-family: var(--font-mono); font-size: 12px; color: var(--term-muted); }
  .about-sync-status__label[data-tone="connected"] { color: var(--syn-green, #34c46a); }
  .about-sync-status__label[data-tone="pairing"]   { color: var(--syn-amber, #f7b015); }
  .about-sync-status__label[data-tone="err"]       { color: var(--syn-red, #f25fa8); }

  @media (max-width: 760px) {
    .about-ship-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .about-hero { padding: 32px 0 28px; }
    .about-tagline { font-size: 12px; }
    .about-page section { padding: 36px 0; }
    .about-section-h { font-size: 1.3rem; }
    .about-essay p { font-size: 14px; line-height: 1.65; }
    .about-ship-card { padding: 16px 14px 14px; }
    .about-ship-num { font-size: 28px; }
    .about-stack-row { font-size: 13px; }
    .about-principle { flex-direction: column; gap: 4px; padding: 10px 0; }
    .about-principle .num { min-width: 0; }
    .about-end { flex-direction: column; align-items: flex-start; padding: 18px 0; }
  }
</style>

<script>
  (function () {
    var y = document.getElementById('about-year');
    if (y) y.textContent = String(new Date().getFullYear());
  })();
  (function () {
    var btn = document.getElementById('about-refresh');
    if (!btn) return;
    var COPY = {
      idle:     {{ ("about.update_check"    | t) | dump | safe }},
      checking: {{ ("about.update_checking" | t) | dump | safe }},
      updating: {{ ("about.update_updating" | t) | dump | safe }},
      latest:   {{ ("about.update_latest"   | t) | dump | safe }}
    };
    function setLabel(txt) {
      var l = btn.querySelector('.about-refresh__label');
      if (l) l.textContent = txt;
    }
    if (!('serviceWorker' in navigator)) {
      btn.addEventListener('click', function () { location.reload(); });
      return;
    }
    var reloading = false;
    var checking = false;
    navigator.serviceWorker.addEventListener('controllerchange', function () {
      if (!checking || reloading) return;
      reloading = true;
      location.reload();
    });
    btn.addEventListener('click', async function () {
      if (btn.disabled) return;
      btn.disabled = true;
      checking = true;
      btn.classList.add('is-busy');
      setLabel(COPY.checking);
      var reg = null;
      try { reg = await navigator.serviceWorker.getRegistration(); } catch (_) {}
      if (!reg) { location.reload(); return; }
      var updating = false;
      function onFound() { if (!updating) { updating = true; setLabel(COPY.updating); } }
      reg.addEventListener('updatefound', onFound);
      try { await reg.update(); } catch (_) {}
      if (reg.installing || reg.waiting) onFound();
      setTimeout(function () {
        if (updating || reloading) return;
        checking = false;
        setLabel(COPY.latest);
        btn.classList.remove('is-busy');
        setTimeout(function () { setLabel(COPY.idle); btn.disabled = false; }, 2000);
      }, 1500);
    });
  })();

  (function () {
    var btn = document.getElementById('about-clear');
    if (!btn) return;
    var COPY = {
      idle:     {{ ("about.cache_clear"    | t) | dump | safe }},
      clearing: {{ ("about.cache_clearing" | t) | dump | safe }},
      cleared:  {{ ("about.cache_cleared"  | t) | dump | safe }}
    };
    function setLabel(t) { var l = btn.querySelector('.about-refresh__label'); if (l) l.textContent = t; }
    btn.addEventListener('click', async function () {
      if (btn.disabled) return;
      btn.disabled = true;
      btn.classList.add('is-busy');
      setLabel(COPY.clearing);
      try {
        if ('serviceWorker' in navigator) {
          var regs = await navigator.serviceWorker.getRegistrations();
          await Promise.all(regs.map(function (r) { return r.unregister(); }));
        }
        if (window.caches) {
          var keys = await caches.keys();
          await Promise.all(keys.map(function (k) { return caches.delete(k); }));
        }
      } catch (_) {}
      setLabel(COPY.cleared);
      setTimeout(function () { location.reload(); }, 500);
    });
  })();

  (function () {
    if (!window.MentriaStore || !window.MentriaBackup) return;
    var COPY = {
      persistGranted:    {{ ('about.data_persist_status_granted' | t) | dump | safe }},
      persistPending:    {{ ('about.data_persist_status_pending' | t) | dump | safe }},
      persistUnsupp:     {{ ('about.data_persist_unsupported'    | t) | dump | safe }},
      persistRequest:    {{ ('about.data_persist_request'        | t) | dump | safe }},
      storageUsage:      {{ ('about.data_storage_usage'          | t) | dump | safe }},
      storageUnknown:    {{ ('about.data_storage_unknown'        | t) | dump | safe }},
      strengthWeak:      {{ ('about.data_strength_weak'          | t) | dump | safe }},
      strengthMedium:    {{ ('about.data_strength_medium'        | t) | dump | safe }},
      strengthStrong:    {{ ('about.data_strength_strong'        | t) | dump | safe }},
      passMismatch:      {{ ('about.data_pass_mismatch'          | t) | dump | safe }},
      passTooShort:      {{ ('about.data_pass_too_short'         | t) | dump | safe }},
      exportButton:      {{ ('about.data_export_button'          | t) | dump | safe }},
      exportBusy:        {{ ('about.data_export_busy'            | t) | dump | safe }},
      exportDone:        {{ ('about.data_export_done'            | t) | dump | safe }},
      importBusy:        {{ ('about.data_import_busy'            | t) | dump | safe }},
      importDone:        {{ ('about.data_import_done'            | t) | dump | safe }},
      importFail:        {{ ('about.data_import_fail'            | t) | dump | safe }}
    };

    var persistEl = document.getElementById('about-data-persist');
    var usageEl   = document.getElementById('about-data-usage');
    var passEl    = document.getElementById('about-data-pass');
    var pass2El   = document.getElementById('about-data-pass2');
    var strengthEl= document.getElementById('about-data-strength');
    var exportBtn = document.getElementById('about-data-export-btn');
    var exportStat= document.getElementById('about-data-export-status');
    var fileEl    = document.getElementById('about-data-import-file');
    var importPass= document.getElementById('about-data-import-pass');
    var importBtn = document.getElementById('about-data-import-btn');
    var importStat= document.getElementById('about-data-import-status');

    function fmtBytes(n) {
      if (n == null || isNaN(n)) return '—';
      if (n < 1024) return n + ' B';
      if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
      if (n < 1024 * 1024 * 1024) return (n / 1024 / 1024).toFixed(1) + ' MB';
      return (n / 1024 / 1024 / 1024).toFixed(2) + ' GB';
    }

    async function refreshStats() {
      try {
        var p = await window.MentriaStore.persisted();
        if (typeof navigator.storage === 'undefined' || !navigator.storage.persist) {
          persistEl.textContent = COPY.persistUnsupp;
        } else if (p) {
          persistEl.textContent = '✓ ' + COPY.persistGranted;
        } else {
          persistEl.innerHTML = '';
          var span = document.createElement('span');
          span.textContent = COPY.persistPending + ' · ';
          persistEl.appendChild(span);
          var link = document.createElement('a');
          link.href = '#';
          link.textContent = COPY.persistRequest;
          link.style.color = 'var(--syn-cyan)';
          link.addEventListener('click', async function (e) {
            e.preventDefault();
            await window.MentriaStore.requestPersist();
            refreshStats();
          });
          persistEl.appendChild(link);
        }
      } catch (_) { persistEl.textContent = COPY.persistUnsupp; }
      try {
        var est = await window.MentriaStore.estimate();
        if (est.usage == null || est.quota == null) usageEl.textContent = COPY.storageUnknown;
        else usageEl.textContent = COPY.storageUsage.replace('{used}', fmtBytes(est.usage)).replace('{quota}', fmtBytes(est.quota));
      } catch (_) { usageEl.textContent = COPY.storageUnknown; }
    }
    refreshStats();

    passEl.addEventListener('input', function () {
      var s = window.MentriaBackup.scorePassphrase(passEl.value);
      strengthEl.dataset.level = s.label;
      strengthEl.textContent = passEl.value ? '· ' + (COPY['strength' + s.label[0].toUpperCase() + s.label.slice(1)] || s.label) : '';
    });

    function setStatus(el, txt, tone) {
      el.textContent = txt;
      if (tone) el.dataset.tone = tone; else delete el.dataset.tone;
    }

    exportBtn.addEventListener('click', async function () {
      setStatus(exportStat, '', null);
      var pw = passEl.value;
      var pw2 = pass2El.value;
      if (!pw || pw.length < 8) { setStatus(exportStat, COPY.passTooShort, 'err'); return; }
      if (pw !== pw2) { setStatus(exportStat, COPY.passMismatch, 'err'); return; }
      exportBtn.disabled = true;
      setStatus(exportStat, COPY.exportBusy, null);
      try {
        var data = window.MentriaStore.exportAll();
        var env = await window.MentriaBackup.encryptBackup(data, pw);
        window.MentriaBackup.downloadBackupJson(env, 'mentria-backup');
        setStatus(exportStat, COPY.exportDone, 'ok');
      } catch (err) {
        setStatus(exportStat, String(err && err.message || err), 'err');
      } finally {
        pw = pw2 = ''; passEl.value = ''; pass2El.value = ''; strengthEl.textContent = ''; delete strengthEl.dataset.level;
        exportBtn.disabled = false;
      }
    });

    importBtn.addEventListener('click', async function () {
      setStatus(importStat, '', null);
      var f = fileEl.files && fileEl.files[0];
      var pw = importPass.value;
      if (!f) { setStatus(importStat, COPY.importFail.replace('{err}', 'no file'), 'err'); return; }
      if (!pw) { setStatus(importStat, COPY.passTooShort, 'err'); return; }
      if (f.size > 32 * 1024 * 1024) { setStatus(importStat, COPY.importFail.replace('{err}', 'file too large'), 'err'); return; }
      importBtn.disabled = true;
      setStatus(importStat, COPY.importBusy, null);
      try {
        var text = await f.text();
        var env = JSON.parse(text);
        var data = await window.MentriaBackup.decryptBackup(env, pw);
        var result = window.MentriaStore.importAll(data, { mode: 'merge' });
        setStatus(importStat, COPY.importDone.replace('{n}', result.restored), 'ok');
        setTimeout(function () { location.reload(); }, 1200);
      } catch (err) {
        setStatus(importStat, COPY.importFail.replace('{err}', String(err && err.message || err)), 'err');
      } finally {
        pw = ''; importPass.value = '';
        importBtn.disabled = false;
      }
    });
  })();

  (function () {
    var COPY = {
      statusIdle:      {{ ('about.sync_status_idle'      | t) | dump | safe }},
      statusPairing:   {{ ('about.sync_status_pairing'   | t) | dump | safe }},
      statusConnecting:{{ ('about.sync_status_connecting'| t) | dump | safe }},
      statusConnected: {{ ('about.sync_status_connected' | t) | dump | safe }},
      statusError:     {{ ('about.sync_status_error'     | t) | dump | safe }},
      pairButton:      {{ ('about.sync_pair_button'      | t) | dump | safe }},
      joinButton:      {{ ('about.sync_join_button'      | t) | dump | safe }},
      codeInvalid:     {{ ('about.sync_code_invalid'     | t) | dump | safe }}
    };
    var startBtn      = document.getElementById('about-sync-start-btn');
    var joinBtn       = document.getElementById('about-sync-join-btn');
    var disconnectBtn = document.getElementById('about-sync-disconnect-btn');
    var codeBox       = document.getElementById('about-sync-code');
    var codeValue     = document.getElementById('about-sync-code-value');
    var codeInput     = document.getElementById('about-sync-code-input');
    var statusLabel   = document.getElementById('about-sync-status-label');
    if (!startBtn || !joinBtn) return;

    function setStatus(text, tone) {
      statusLabel.textContent = text;
      if (tone) statusLabel.dataset.tone = tone; else delete statusLabel.dataset.tone;
    }

    function whenReady(cb) {
      if (window.MentriaSync) return cb();
      var t = 0;
      var iv = setInterval(function () {
        if (window.MentriaSync) { clearInterval(iv); cb(); }
        else if (++t > 50) { clearInterval(iv); setStatus(COPY.statusError + ': sync engine not loaded', 'err'); }
      }, 100);
    }

    whenReady(function () {
      window.MentriaSync.on('state', function (st) {
        if (st.status === 'idle') {
          setStatus(COPY.statusIdle, null);
          disconnectBtn.hidden = true;
          codeBox.hidden = true;
          startBtn.disabled = false;
          joinBtn.disabled = false;
        } else if (st.status === 'pairing') {
          setStatus(COPY.statusPairing, 'pairing');
          disconnectBtn.hidden = false;
        } else if (st.status === 'connecting') {
          setStatus(COPY.statusConnecting, 'pairing');
          disconnectBtn.hidden = false;
        } else if (st.status === 'connected') {
          setStatus(COPY.statusConnected.replace('{n}', String(st.peers || 1)), 'connected');
          disconnectBtn.hidden = false;
        }
      });
      window.MentriaSync.on('error', function (err) {
        setStatus(COPY.statusError + ': ' + (err && err.message || err), 'err');
      });
    });

    startBtn.addEventListener('click', function () {
      whenReady(async function () {
        startBtn.disabled = true;
        joinBtn.disabled = true;
        try {
          var code = await window.MentriaSync.start();
          codeValue.textContent = code;
          codeBox.hidden = false;
        } catch (err) {
          setStatus(COPY.statusError + ': ' + (err && err.message || err), 'err');
          startBtn.disabled = false;
          joinBtn.disabled = false;
        }
      });
    });

    joinBtn.addEventListener('click', function () {
      whenReady(async function () {
        var raw = codeInput.value;
        var norm = window.MentriaSync.normalizeCode(raw);
        if (norm.length < 16) { setStatus(COPY.codeInvalid, 'err'); return; }
        startBtn.disabled = true;
        joinBtn.disabled = true;
        codeBox.hidden = true;
        try {
          await window.MentriaSync.joinWithCode(raw);
          codeInput.value = '';
        } catch (err) {
          setStatus(COPY.statusError + ': ' + (err && err.message || err), 'err');
          startBtn.disabled = false;
          joinBtn.disabled = false;
        }
      });
    });

    disconnectBtn.addEventListener('click', function () {
      whenReady(async function () {
        await window.MentriaSync.disconnect();
      });
    });
  })();
</script>
<script type="module" src="/assets/js/mentria-sync.js?v={{ buildHash }}"></script>
