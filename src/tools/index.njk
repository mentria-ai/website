---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools_page.title' | t }}"
  description: "{{ 'tools_page.lede' | t }}"
---
<section class="hero" style="padding-top:1rem;">
    <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">tools</span></p>
    <h1>{{ "tools_page.title" | t }}</h1>
    <p>{{ "tools_page.lede" | t }}</p>
</section>

{% set toolList = tools | default([]) %}
{% if toolList.length %}
<div class="tools-listing">
    <div class="tools-listing__header">
        <span>{{ "tools_page.header.category" | t }}</span>
        <span>{{ "tools_page.header.name" | t }}</span>
        <span>{{ "tools_page.header.summary" | t }}</span>
    </div>
    {% for tool in toolList %}
    <div class="tools-listing__row">
        <span class="tools-listing__category">{{ ("category." + tool.category) | t }}</span>
        <span class="tools-listing__name"><a href="{{ ('/tools/' + tool.slug + '/') | localeUrl(lang) }}">{{ ("tools." + tool.slug + ".title") | t }}</a></span>
        <span class="tools-listing__summary">{{ ("tools." + tool.slug + ".lede") | t }}</span>
    </div>
    {% endfor %}
</div>
{% else %}
<div style="margin-top: 2rem; font-family: var(--font-mono); color: var(--term-muted);">
    <p>{{ "tools_page.empty_cmd" | t }}</p>
    <p>{{ "tools_page.empty_msg" | t }}<span class="cursor-blink"></span></p>
</div>
{% endif %}
