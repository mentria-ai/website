---
layout: base.njk
title: Motivational Quote
description: AI-generated original motivational quotes running locally in your browser. No server, no API keys.
permalink: /tools/quote/index.html
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow">~/tools/quote</p>
  <h1>Motivational Quote</h1>
  <p>
    Original quotes generated by AI, running locally in your browser. No data leaves your device.
  </p>
</section>

{% set terminalTitle = "quote.js" %}
{% include "terminal-frame-open.njk" %}
<section class="mq">
  <!-- Status bar -->
  <div class="mq__status">
    <span class="mq__status-dot" id="mq-status-dot"></span>
    <span class="mq__status-text" id="mq-status-text">Initializing…</span>
  </div>

  <!-- Progress bar -->
  <div class="mq__progress-wrap" id="mq-progress-wrap" style="display:none;">
    <div class="mq__progress-info">
      <span id="mq-progress-label">Downloading model…</span>
      <span id="mq-progress-pct">0%</span>
    </div>
    <div class="mq__progress-bar">
      <div class="mq__progress-fill" id="mq-progress-fill"></div>
    </div>
    <div class="mq__progress-detail" id="mq-progress-detail"></div>
  </div>

  <!-- Quote area -->
  <div class="mq__quote-area">
    <div class="mq__quote" id="mq-quote"></div>
  </div>

  <!-- Buttons -->
  <div class="mq__actions">
    <button class="mq__btn mq__btn--primary" id="mq-new" disabled>New Quote</button>
    <button class="mq__btn mq__btn--secondary" id="mq-copy" style="display:none;">Copy</button>
  </div>
</section>
{% include "terminal-frame-close.njk" %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Mentria Motivational Quote",
  "operatingSystem": "Web",
  "applicationCategory": "UtilitiesApplication",
  "description": "AI-generated original motivational quotes running locally in your browser via custom finetuned Qwen3.5-0.8B model.",
  "offers": { "@type": "Offer", "price": "0" }
}
</script>

<script type="module">
const LIB_URLS = [
  'https://cdn.jsdelivr.net/npm/@huggingface/transformers@4',
  'https://cdn.jsdelivr.net/npm/@huggingface/transformers@latest'
];

const statusDot  = document.getElementById('mq-status-dot');
const statusText = document.getElementById('mq-status-text');

function setStatus(state, text) {
  statusDot.className = 'mq__status-dot mq__status-dot--' + state;
  statusText.textContent = text;
}

let lib = null;
for (const url of LIB_URLS) {
  try {
    lib = await import(url);
    break;
  } catch (e) {
    console.warn('Failed to load', url, e);
  }
}

if (!lib) {
  setStatus('error', 'Failed to load Transformers.js library. Check network/ad-blocker.');
} else {
  runApp(lib);
}

function runApp({ AutoProcessor, AutoModelForImageTextToText, TextStreamer }) {
  const MODEL_ID = 'mentriaai/Qwen3.5-0.8B-quotes-ONNX';
  const SYSTEM_PROMPT = 'You are a poetic thinker. Write one short, original motivational quote (1-2 sentences). Do not attribute it to anyone. No preamble, no quotation marks \u2014 just the quote itself.';
  const MAX_TOKENS = 128;

  function getBestDevice() {
    if (!navigator.gpu) return 'wasm';
    const ua = navigator.userAgent;
    if (ua.includes('Safari') && !ua.includes('Chrome') && !ua.includes('Android')) return 'wasm';
    return 'webgpu';
  }

  const DEVICE = getBestDevice();
  const DTYPE = DEVICE === 'webgpu'
    ? { embed_tokens: 'q4', vision_encoder: 'fp16', decoder_model_merged: 'q4' }
    : { embed_tokens: 'q4', vision_encoder: 'q4', decoder_model_merged: 'q4' };

  /* DOM refs */
  const progressWrap  = document.getElementById('mq-progress-wrap');
  const progressLabel = document.getElementById('mq-progress-label');
  const progressPct   = document.getElementById('mq-progress-pct');
  const progressFill  = document.getElementById('mq-progress-fill');
  const progressDetail = document.getElementById('mq-progress-detail');
  const quoteEl       = document.getElementById('mq-quote');
  const newBtn        = document.getElementById('mq-new');
  const copyBtn       = document.getElementById('mq-copy');

  let processor = null;
  let model = null;
  let generating = false;

  function formatBytes(b) {
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(1) + ' MB';
  }

  /* Progress tracking */
  const fileProgress = {};
  function onProgress(event) {
    if (event.status === 'progress' && event.total) {
      fileProgress[event.file] = { loaded: event.loaded, total: event.total };
      const totals = Object.values(fileProgress);
      const loaded = totals.reduce((s, f) => s + f.loaded, 0);
      const total  = totals.reduce((s, f) => s + f.total, 0);
      const pct = Math.round((loaded / total) * 100);
      progressFill.style.width = pct + '%';
      progressPct.textContent = pct + '%';
      progressDetail.textContent = formatBytes(loaded) + ' / ' + formatBytes(total);
    } else if (event.status === 'ready') {
      progressLabel.textContent = 'Loading model…';
    }
  }

  /* Load model */
  async function loadModel() {
    setStatus('loading', 'Loading model…');
    progressWrap.style.display = '';
    try {
      processor = await AutoProcessor.from_pretrained(MODEL_ID, {
        progress_callback: onProgress
      });
      model = await AutoModelForImageTextToText.from_pretrained(MODEL_ID, {
        dtype: DTYPE,
        device: DEVICE,
        progress_callback: onProgress
      });
      progressWrap.style.display = 'none';
      setStatus('ready', DEVICE === 'webgpu' ? 'Ready' : 'Ready (WASM)');
      newBtn.disabled = false;
    } catch (err) {
      progressWrap.style.display = 'none';
      console.error('Model load error:', err);
      setStatus('error', 'Failed to load: ' + (err.message || err));
    }
  }

  /* Generate quote */
  async function generateQuote() {
    if (generating || !model) return;
    generating = true;
    newBtn.disabled = true;
    copyBtn.style.display = 'none';
    quoteEl.textContent = '';
    quoteEl.classList.add('mq__quote--typing');
    setStatus('generating', 'Generating…');

    const messages = [
      { role: 'system', content: SYSTEM_PROMPT },
      { role: 'user', content: [{ type: 'text', text: 'Give me a motivational quote.' }] }
    ];

    try {
      const textContent = processor.apply_chat_template(messages, {
        tokenize: false,
        add_generation_prompt: true
      });

      const inputs = await processor(textContent, null, { padding: true, truncation: true });

      let fullText = '';
      let firstToken = true;
      let pendingPaint = false;

      function paintToken() {
        const display = fullText.replace(/<think>[\s\S]*?<\/think>/g, '').trim();
        quoteEl.textContent = display || '\u2026';
        pendingPaint = false;
      }

      const streamer = new TextStreamer(processor.tokenizer, {
        skip_prompt: true,
        skip_special_tokens: true,
        callback_function(token) {
          if (firstToken) {
            token = token.trimStart();
            firstToken = false;
          }
          fullText += token;
          if (!pendingPaint) {
            pendingPaint = true;
            requestAnimationFrame(paintToken);
          }
        }
      });

      await model.generate({
        ...inputs,
        max_new_tokens: MAX_TOKENS,
        do_sample: true,
        temperature: 0.9,
        top_p: 0.95,
        streamer
      });

      const display = fullText.replace(/<think>[\s\S]*?<\/think>/g, '').trim();
      quoteEl.textContent = display || 'Couldn\u2019t generate a quote. Try again.';
      quoteEl.classList.remove('mq__quote--typing');

      if (display) copyBtn.style.display = '';
    } catch (err) {
      console.error('Generation error:', err);
      quoteEl.textContent = 'Error generating quote. Try again.';
      quoteEl.classList.remove('mq__quote--typing');
    }

    generating = false;
    newBtn.disabled = false;
    setStatus('ready', DEVICE === 'webgpu' ? 'Ready' : 'Ready (WASM)');
  }

  /* Copy to clipboard */
  async function copyQuote() {
    const text = quoteEl.textContent;
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      copyBtn.textContent = 'Copied!';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
    } catch {
      copyBtn.textContent = 'Failed';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
    }
  }

  /* Events */
  newBtn.addEventListener('click', generateQuote);
  copyBtn.addEventListener('click', copyQuote);

  /* Init */
  async function init() {
    setStatus('idle', DEVICE === 'webgpu' ? 'WebGPU available. Loading model…' : 'Using WASM backend. Loading model…');
    await loadModel();
    if (model) generateQuote();
  }

  init();
}
</script>

<style>
.mq {
  display: flex;
  flex-direction: column;
  font-family: var(--font-mono);
  min-height: min(420px, 55vh);
}

/* Status bar */
.mq__status {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.75rem;
  border-bottom: 1px solid var(--term-border);
  font-size: 0.75rem;
  color: var(--term-muted);
  flex-shrink: 0;
}

.mq__status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--term-muted);
  flex-shrink: 0;
}
.mq__status-dot--idle     { background: var(--term-muted); }
.mq__status-dot--loading  { background: var(--syn-amber); box-shadow: 0 0 6px var(--syn-amber); animation: mq-pulse 1.5s ease-in-out infinite; }
.mq__status-dot--ready    { background: var(--syn-green); box-shadow: 0 0 6px var(--syn-green); }
.mq__status-dot--generating { background: var(--syn-cyan); box-shadow: 0 0 6px var(--syn-cyan); animation: mq-pulse 1s ease-in-out infinite; }
.mq__status-dot--error    { background: var(--syn-pink); box-shadow: 0 0 6px var(--syn-pink); }

@keyframes mq-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* Progress bar */
.mq__progress-wrap {
  padding: 0.75rem;
  border-bottom: 1px solid var(--term-border);
  flex-shrink: 0;
}
.mq__progress-info {
  display: flex;
  justify-content: space-between;
  font-size: 0.7rem;
  color: var(--term-muted);
  margin-bottom: 0.4rem;
}
.mq__progress-bar {
  height: 4px;
  background: rgba(255,255,255,0.06);
  border-radius: 2px;
  overflow: hidden;
}
.mq__progress-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--syn-cyan), var(--syn-purple));
  border-radius: 2px;
  transition: width 0.3s ease;
}
.mq__progress-detail {
  font-size: 0.65rem;
  color: var(--term-muted);
  margin-top: 0.3rem;
  text-align: right;
}

/* Quote area */
.mq__quote-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2.5rem 2rem;
}

.mq__quote {
  font-size: 1.15rem;
  line-height: 1.7;
  color: var(--term-fg);
  text-align: center;
  max-width: 540px;
  word-wrap: break-word;
  overflow-wrap: break-word;
  white-space: pre-wrap;
  min-height: 1.7em;
}

.mq__quote--typing::after {
  content: '';
  display: inline-block;
  width: 2px;
  height: 1.15em;
  background: var(--syn-cyan);
  margin-left: 2px;
  vertical-align: text-bottom;
  animation: mq-blink 0.6s step-end infinite;
}

@keyframes mq-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* Buttons */
.mq__actions {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  padding: 1rem 0.75rem 1.5rem;
  flex-shrink: 0;
}

.mq__btn {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  padding: 0.5rem 1.2rem;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.mq__btn--primary {
  background: var(--syn-cyan);
  color: #000;
  border: none;
}
.mq__btn--primary:hover:not(:disabled) {
  background: #67e8f9;
  box-shadow: 0 0 12px rgba(34, 211, 238, 0.3);
}
.mq__btn--primary:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.mq__btn--secondary {
  background: none;
  border: 1px solid var(--term-border);
  color: var(--term-muted);
}
.mq__btn--secondary:hover {
  border-color: var(--syn-cyan);
  color: var(--syn-cyan);
}

/* Responsive */
@media (max-width: 480px) {
  .mq__quote-area {
    padding: 1.5rem 1rem;
  }
  .mq__quote {
    font-size: 1rem;
  }
}
</style>
