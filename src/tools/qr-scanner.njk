---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/qr-scanner/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.qr-scanner.title' | t }}"
  description: "{{ 'tools.qr-scanner.lede' | t }}"
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><a class="eyebrow__link" href="{{ locale.pathPrefix }}/tools/">tools</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">qr-scanner</span></p>
  <h1>{{ "tools.qr-scanner.title" | t }}</h1>
  <p>{{ "tools.qr-scanner.lede" | t }}</p>
  {% include "tldr.njk" %}
</section>

{% set terminalTitle = "qr-scanner.js" %}
{% include "terminal-frame-open.njk" %}
<section class="qr qr--idle" id="qr" data-mode="scan">

  <div class="qr__modes" role="tablist" aria-label="{{ 'tools.qr-scanner.title' | t }}">
    <button type="button" class="qr__mode is-active" id="qr-mode-scan" role="tab" aria-selected="true">{{ "tool.qr-scanner.mode_scan" | t }}</button>
    <button type="button" class="qr__mode" id="qr-mode-gen" role="tab" aria-selected="false">{{ "tool.qr-scanner.mode_generate" | t }}</button>
  </div>

  <div class="qr__view" id="qr-view-scan">
  <div class="qr__main" id="qr-main">
    <div class="qr__stage">
      <video class="qr__video" id="qr-video" playsinline muted aria-label="{{ 'tool.qr-scanner.aria_video' | t }}"></video>
      <div class="qr__frame" aria-hidden="true">
        <span class="qr__corner qr__corner--tl"></span>
        <span class="qr__corner qr__corner--tr"></span>
        <span class="qr__corner qr__corner--bl"></span>
        <span class="qr__corner qr__corner--br"></span>
        <span class="qr__scanline"></span>
      </div>
      <div class="qr__placeholder">
        <svg class="qr__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9V5a2 2 0 0 1 2-2h4M21 9V5a2 2 0 0 0-2-2h-4M3 15v4a2 2 0 0 0 2 2h4M21 15v4a2 2 0 0 1-2 2h-4"/>
          <rect x="7.5" y="7.5" width="3.5" height="3.5"/>
          <rect x="13" y="13" width="3.5" height="3.5"/>
          <path d="M13 7.5h3.5V11M7.5 13h3.5v3.5"/>
        </svg>
        <p class="qr__placeholder-text" id="qr-idle-prompt">{{ "tool.qr-scanner.idle_prompt" | t }}</p>
      </div>
      <p class="qr__status" id="qr-status" aria-live="polite">{{ "tool.qr-scanner.scanning" | t }}</p>
    </div>

    <div class="qr__result" id="qr-result">
      <span class="qr__result-label">{{ "tool.qr-scanner.result_label" | t }}</span>
      <p class="qr__result-value" id="qr-result-value"></p>
      <span class="qr__result-format" id="qr-result-format"></span>
    </div>

    <p class="qr__note" id="qr-note" hidden></p>
    <p class="qr__note" id="qr-cap-note" hidden>{{ "tool.qr-scanner.note_qr_only" | t }}</p>

    <div class="qr__controls">
      <button type="button" class="qr__btn--start m-btn m-btn--primary m-btn--pill" id="qr-start">{{ "tool.qr-scanner.btn_start_camera" | t }}</button>
      <button type="button" class="qr__btn--stop m-btn m-btn--primary m-btn--pill" id="qr-stop">{{ "tool.qr-scanner.btn_stop" | t }}</button>
      <button type="button" class="qr__btn--again m-btn m-btn--primary m-btn--pill" id="qr-again">{{ "tool.qr-scanner.btn_scan_again" | t }}</button>
      <label class="qr__file-label m-btn m-btn--ghost m-btn--pill" for="qr-file">
        {{ "tool.qr-scanner.btn_scan_image" | t }}
        <input type="file" id="qr-file" accept="image/*" hidden>
      </label>
      <button type="button" class="m-btn m-btn--ghost m-btn--pill" id="qr-copy" hidden>{{ "tool.qr-scanner.btn_copy" | t }}</button>
      <button type="button" class="m-btn m-btn--ghost m-btn--pill" id="qr-open" hidden>{{ "tool.qr-scanner.btn_open" | t }}</button>
    </div>
  </div>

  <div class="qr__panel" id="qr-unsupported" hidden>
    <h2 class="qr__panel-title qr__panel-title--warn">{{ "tool.qr-scanner.unsupported_title" | t }}</h2>
    <p class="qr__panel-body">{{ "tool.qr-scanner.unsupported_body" | t }}</p>
  </div>
  </div>

  <div class="qr__view" id="qr-view-gen" hidden>
    <div class="qrg">
      <input type="text" class="qrg__input m-input" id="qrg-input" inputmode="url" autocomplete="off" autocapitalize="off" spellcheck="false"
             placeholder="{{ 'tool.qr-scanner.gen_prompt' | t }}" aria-label="{{ 'tool.qr-scanner.gen_input_label' | t }}">
      <div class="qrg__stage">
        <canvas class="qrg__canvas" id="qrg-canvas" role="img" aria-label="{{ 'tool.qr-scanner.gen_alt' | t }}" hidden></canvas>
        <p class="qrg__empty" id="qrg-empty">{{ "tool.qr-scanner.gen_empty" | t }}</p>
      </div>
      <p class="qr__note" id="qrg-note" hidden></p>
      <div class="qr__controls">
        <button type="button" class="m-btn m-btn--primary m-btn--pill" id="qrg-download">{{ "tool.qr-scanner.btn_download" | t }}</button>
        <button type="button" class="m-btn m-btn--ghost m-btn--pill" id="qrg-copy" hidden>{{ "tool.qr-scanner.btn_copy_image" | t }}</button>
        <button type="button" class="m-btn m-btn--ghost m-btn--pill" id="qrg-share" hidden>{{ "common.share" | t }}</button>
      </div>
    </div>
  </div>

</section>
{% include "terminal-frame-close.njk" %}
{% include "tool-schema.njk" %}

<script src="/assets/js/qrcode.js?v={{ buildHash }}"></script>
<script>
(() => {
  const COPY = {
    btnCopied:      {{ ("tool.qr-scanner.btn_copied"      | t) | dump | safe }},
    btnCopyFailed:  {{ ("common.copy_failed" | t) | dump | safe }},
    noteInsecure:   {{ ("tool.qr-scanner.note_insecure"   | t) | dump | safe }},
    noteDenied:     {{ ("tool.qr-scanner.note_denied"     | t) | dump | safe }},
    noteNoCamera:   {{ ("tool.qr-scanner.note_no_camera"  | t) | dump | safe }},
    noteCameraErr:  {{ ("tool.qr-scanner.note_camera_error" | t) | dump | safe }},
    noteNoMatch:    {{ ("tool.qr-scanner.note_no_match"   | t) | dump | safe }},
    noteNoMatchQrOnly: {{ ("tool.qr-scanner.note_no_match_qr_only" | t) | dump | safe }},
    idlePromptQr:   {{ ("tool.qr-scanner.idle_prompt_qr" | t) | dump | safe }},
    genTooLong:     {{ ("tool.qr-scanner.gen_too_long"    | t) | dump | safe }}
  };

  const $ = id => document.getElementById(id);
  const qr          = $('qr');
  const main        = $('qr-main');
  const panelUnsup  = $('qr-unsupported');
  const video       = $('qr-video');
  const noteEl      = $('qr-note');
  const capNote     = $('qr-cap-note');
  const idlePromptEl = $('qr-idle-prompt');
  const resultValue = $('qr-result-value');
  const resultFmt   = $('qr-result-format');
  const startBtn    = $('qr-start');
  const stopBtn     = $('qr-stop');
  const againBtn    = $('qr-again');
  const fileInput   = $('qr-file');
  const copyBtn     = $('qr-copy');
  const openBtn     = $('qr-open');

  const modeScanBtn = $('qr-mode-scan');
  const modeGenBtn  = $('qr-mode-gen');
  const viewScan    = $('qr-view-scan');
  const viewGen     = $('qr-view-gen');
  const genInput    = $('qrg-input');
  const genCanvas   = $('qrg-canvas');
  const genEmpty    = $('qrg-empty');
  const genNote     = $('qrg-note');
  const genDl       = $('qrg-download');
  const genCopy     = $('qrg-copy');
  const genShare    = $('qrg-share');

  function setMode(m) {
    const scan = m === 'scan';
    qr.setAttribute('data-mode', m);
    viewScan.hidden = !scan;
    viewGen.hidden = scan;
    modeScanBtn.classList.toggle('is-active', scan);
    modeGenBtn.classList.toggle('is-active', !scan);
    modeScanBtn.setAttribute('aria-selected', String(scan));
    modeGenBtn.setAttribute('aria-selected', String(!scan));
    if (!scan) { stopCamera(); setState('idle'); }
  }
  modeScanBtn.addEventListener('click', () => setMode('scan'));
  modeGenBtn.addEventListener('click', () => { setMode('generate'); genRender(); genInput.focus(); });

  let genText = '';
  let genTimer = 0;

  function setGenActions(on) {
    genDl.disabled = !on;
    genCopy.disabled = !on;
    genShare.disabled = !on;
  }

  function drawQR(code) {
    const border = 4;
    const dim = code.size + border * 2;
    const px = 10;
    genCanvas.width = dim * px;
    genCanvas.height = dim * px;
    const ctx = genCanvas.getContext('2d');
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, genCanvas.width, genCanvas.height);
    ctx.fillStyle = '#000000';
    for (let y = 0; y < code.size; y++) {
      for (let x = 0; x < code.size; x++) {
        if (code.getModule(x, y)) ctx.fillRect((x + border) * px, (y + border) * px, px, px);
      }
    }
  }

  function genRender() {
    const text = genInput.value.trim();
    genText = text;
    genNote.hidden = true;
    if (!text || typeof qrcodegen === 'undefined') {
      genCanvas.hidden = true;
      genEmpty.hidden = false;
      setGenActions(false);
      return;
    }
    let code;
    try {
      code = qrcodegen.QrCode.encodeText(text, qrcodegen.QrCode.Ecc.MEDIUM);
    } catch (_) {
      genCanvas.hidden = true;
      genEmpty.hidden = true;
      genNote.textContent = COPY.genTooLong;
      genNote.hidden = false;
      setGenActions(false);
      return;
    }
    drawQR(code);
    genEmpty.hidden = true;
    genCanvas.hidden = false;
    setGenActions(true);
  }

  function canvasToBlob() {
    return new Promise(res => genCanvas.toBlob(res, 'image/png'));
  }

  genInput.addEventListener('input', () => {
    clearTimeout(genTimer);
    genTimer = setTimeout(genRender, 120);
  });
  genDl.addEventListener('click', async () => {
    const blob = await canvasToBlob();
    if (!blob) return;
    MentriaUI.downloadFile('qr-code.png', blob);
  });
  if (navigator.clipboard && window.ClipboardItem) {
    genCopy.hidden = false;
    genCopy.addEventListener('click', async () => {
      const blob = await canvasToBlob();
      if (!blob) return;
      try {
        await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);
        const orig = genCopy.textContent;
        genCopy.textContent = COPY.btnCopied;
        setTimeout(() => { genCopy.textContent = orig; }, 1500);
      } catch (_) {}
    });
  }
  if (navigator.canShare && navigator.canShare({ files: [new File([new Blob(['x'])], 'q.png', { type: 'image/png' })] })) {
    genShare.hidden = false;
    genShare.addEventListener('click', async () => {
      const blob = await canvasToBlob();
      if (!blob) return;
      const file = new File([blob], 'qr-code.png', { type: 'image/png' });
      try { await navigator.share({ files: [file], text: genText }); } catch (_) {}
    });
  }
  setGenActions(false);

  let detector = null;
  let useJsQR = false;
  let stream = null;
  let rafId = 0;
  let lastDetect = 0;
  let scanning = false;
  let lastValue = '';
  let scanCanvas = null, scanCtx = null;

  function showUnsupported() {
    main.hidden = true;
    panelUnsup.hidden = false;
  }

  function applyQrOnlyHints() {
    capNote.hidden = false;
    if (idlePromptEl) idlePromptEl.textContent = COPY.idlePromptQr;
  }

  function loadScript(src) {
    return new Promise((res, rej) => {
      const s = document.createElement('script');
      s.src = src; s.onload = res; s.onerror = rej;
      document.head.appendChild(s);
    });
  }

  function jsqrDecode(source, sw, sh, both) {
    if (!window.jsQR || !sw || !sh) return null;
    let w = sw, h = sh;
    const maxDim = 640;
    if (Math.max(w, h) > maxDim) { const s = maxDim / Math.max(w, h); w = Math.round(w * s); h = Math.round(h * s); }
    if (!scanCanvas) { scanCanvas = document.createElement('canvas'); scanCtx = scanCanvas.getContext('2d', { willReadFrequently: true }); }
    scanCanvas.width = w; scanCanvas.height = h;
    scanCtx.drawImage(source, 0, 0, w, h);
    let img;
    try { img = scanCtx.getImageData(0, 0, w, h); } catch (_) { return null; }
    const r = window.jsQR(img.data, w, h, { inversionAttempts: both ? 'attemptBoth' : 'dontInvert' });
    return r && r.data ? { rawValue: r.data, format: 'qr_code' } : null;
  }

  function setState(s) {
    qr.className = 'qr qr--' + s;
    copyBtn.hidden = s !== 'result';
    if (s !== 'result') openBtn.hidden = true;
  }

  function showNote(msg) {
    noteEl.textContent = msg;
    noteEl.hidden = false;
  }
  function hideNote() {
    noteEl.hidden = true;
  }

  function stopCamera() {
    scanning = false;
    if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
    if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
    video.srcObject = null;
  }

  function showResult(value, format) {
    lastValue = value || '';
    resultValue.textContent = lastValue;
    resultFmt.textContent = format ? format.replace(/_/g, ' ') : '';
    setState('result');
    openBtn.hidden = !/^https?:\/\/\S+$/i.test(lastValue.trim());
    if (navigator.vibrate) navigator.vibrate(40);
  }

  function onCode(code) {
    stopCamera();
    showResult(code.rawValue, code.format);
  }

  async function scanLoop(ts) {
    if (!scanning) return;
    rafId = requestAnimationFrame(scanLoop);
    if (ts - lastDetect < 220) return;
    lastDetect = ts;
    if (video.readyState < 2) return;
    if (detector) {
      let codes;
      try { codes = await detector.detect(video); }
      catch (_) { return; }
      if (codes && codes.length) onCode(codes[0]);
    } else if (useJsQR) {
      const code = jsqrDecode(video, video.videoWidth, video.videoHeight, false);
      if (code) onCode(code);
    }
  }

  async function startCamera() {
    hideNote();
    if (!detector && !useJsQR) return;
    if (!window.isSecureContext) { showNote(COPY.noteInsecure); return; }
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      showNote(COPY.noteNoCamera);
      return;
    }
    try {
      stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
    } catch (err) {
      const name = err && err.name;
      if (name === 'NotAllowedError' || name === 'SecurityError') showNote(COPY.noteDenied);
      else if (name === 'NotFoundError' || name === 'OverconstrainedError') showNote(COPY.noteNoCamera);
      else showNote(COPY.noteCameraErr);
      return;
    }
    video.srcObject = stream;
    scanning = true;
    setState('scanning');
    try { await video.play(); } catch (_) {}
    lastDetect = 0;
    rafId = requestAnimationFrame(scanLoop);
  }

  async function scanImage(file) {
    hideNote();
    if (!file || (!detector && !useJsQR)) return;
    let bitmap;
    try { bitmap = await createImageBitmap(file); }
    catch (_) { showNote(COPY.noteNoMatch); return; }
    let result = null;
    if (detector) {
      let codes;
      try { codes = await detector.detect(bitmap); } catch (_) { codes = []; }
      if (codes && codes.length) result = { rawValue: codes[0].rawValue, format: codes[0].format };
    } else if (useJsQR) {
      result = jsqrDecode(bitmap, bitmap.width, bitmap.height, true);
    }
    if (bitmap.close) bitmap.close();
    if (result) showResult(result.rawValue, result.format);
    else showNote((useJsQR && !detector) ? COPY.noteNoMatchQrOnly : COPY.noteNoMatch);
  }

  startBtn.addEventListener('click', startCamera);
  stopBtn.addEventListener('click', () => { stopCamera(); setState('idle'); });
  againBtn.addEventListener('click', () => { hideNote(); setState('idle'); });
  fileInput.addEventListener('change', e => {
    const f = e.target.files && e.target.files[0];
    if (f) scanImage(f);
    fileInput.value = '';
  });
  MentriaUI.copyButton(copyBtn, () => lastValue, { copiedText: COPY.btnCopied, failedText: COPY.btnCopyFailed, restoreMs: 1500 });
  openBtn.addEventListener('click', () => {
    if (/^https?:\/\//i.test(lastValue)) window.open(lastValue, '_blank', 'noopener');
  });
  document.addEventListener('visibilitychange', () => {
    if (document.hidden && scanning) { stopCamera(); setState('idle'); }
  });
  window.addEventListener('pagehide', stopCamera);

  (async () => {
    if ('BarcodeDetector' in window) {
      try {
        const formats = await BarcodeDetector.getSupportedFormats();
        if (formats && formats.length) { detector = new BarcodeDetector({ formats }); return; }
      } catch (_) {}
    }
    try {
      if (!window.jsQR) await loadScript('/assets/js/jsqr.js?v={{ buildHash }}');
      if (window.jsQR) { useJsQR = true; applyQrOnlyHints(); return; }
    } catch (_) {}
    showUnsupported();
  })();

  setState('idle');
})();
</script>

<style>
.qr {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
  font-family: var(--font-mono);
  max-width: 420px;
  margin: 0 auto;
  padding: 0.5rem 0 1rem;
}
.qr__main {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.1rem;
  width: 100%;
}
.qr__main[hidden] { display: none; }

.qr__stage {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  max-width: 360px;
  border: 1px solid var(--term-border);
  border-radius: 12px;
  background: #060606;
  overflow: hidden;
}

.qr__video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: none;
}
.qr--scanning .qr__video { display: block; }

.qr__placeholder {
  position: absolute;
  inset: 0;
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.9rem;
  padding: 1.5rem;
  text-align: center;
}
.qr:not(.qr--scanning) .qr__placeholder { display: flex; }
.qr__placeholder-icon { width: 56px; height: 56px; color: var(--term-muted); }
.qr__placeholder-text {
  font-size: 0.8rem;
  color: var(--term-muted);
  line-height: 1.5;
  margin: 0;
  max-width: 28ch;
}

.qr__frame {
  position: absolute;
  inset: 17.5%;
  display: none;
  pointer-events: none;
}
.qr--scanning .qr__frame { display: block; }
.qr__corner {
  position: absolute;
  width: 22px;
  height: 22px;
  border: 2px solid var(--syn-cyan);
}
.qr__corner--tl { top: 0; left: 0; border-right: none; border-bottom: none; }
.qr__corner--tr { top: 0; right: 0; border-left: none; border-bottom: none; }
.qr__corner--bl { bottom: 0; left: 0; border-right: none; border-top: none; }
.qr__corner--br { bottom: 0; right: 0; border-left: none; border-top: none; }
.qr__scanline {
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--syn-cyan);
  box-shadow: 0 0 10px var(--syn-cyan);
  animation: qr-scan 2.2s ease-in-out infinite;
}
@keyframes qr-scan {
  0%, 100% { top: 0; }
  50% { top: 100%; }
}

.qr__status {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: none;
  padding: 0.45rem;
  text-align: center;
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--syn-cyan);
  background: linear-gradient(0deg, rgba(0,0,0,0.75), transparent);
}
.qr--scanning .qr__status { display: block; }

.qr__result {
  display: none;
  flex-direction: column;
  gap: 0.4rem;
  width: 100%;
  padding: 1rem;
  border: 1px solid var(--term-border-strong);
  border-radius: 10px;
  background: var(--cyan-8);
}
.qr--result .qr__result { display: flex; }
.qr__result-label {
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--term-muted);
}
.qr__result-value {
  margin: 0;
  font-size: 0.95rem;
  color: var(--term-fg);
  word-break: break-all;
  line-height: 1.5;
}
.qr__result-format {
  font-size: 0.65rem;
  color: var(--syn-cyan);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.qr__note {
  margin: 0;
  width: 100%;
  padding: 0.7rem 0.85rem;
  border: 1px solid var(--amber-30);
  border-radius: 8px;
  background: var(--amber-8);
  color: var(--syn-amber);
  font-size: 0.78rem;
  line-height: 1.5;
  text-align: center;
}

.qr__controls {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.6rem;
}
.qr__btn--start, .qr__btn--stop, .qr__btn--again { display: none; }
.qr--idle .qr__btn--start { display: inline-block; }
.qr--scanning .qr__btn--stop { display: inline-block; }
.qr--result .qr__btn--again { display: inline-block; }
.qr--scanning .qr__file-label { display: none; }

.qr__panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  text-align: center;
  padding: 2rem 1.5rem;
  border: 1px solid var(--term-border);
  border-radius: 10px;
  background: rgba(255,255,255,0.015);
  width: 100%;
}
.qr__panel[hidden] { display: none; }
.qr__panel-title {
  font-size: 1rem;
  color: var(--syn-cyan);
  margin: 0;
}
.qr__panel-title--warn { color: var(--syn-amber); }
.qr__panel-body {
  font-size: 0.85rem;
  color: var(--term-muted);
  line-height: 1.55;
  margin: 0;
  max-width: 40ch;
}

@media (prefers-reduced-motion: reduce) {
  .qr__scanline { animation: none; top: 50%; }
}

.qr__modes {
  display: inline-flex;
  gap: 0.25rem;
  padding: 0.25rem;
  border: 1px solid var(--term-border);
  border-radius: 999px;
  background: rgba(255,255,255,0.02);
}
.qr__mode {
