---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/decision-wheel/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.decision-wheel.title' | t }}"
  description: "{{ 'tools.decision-wheel.lede' | t }}"
tldr: >
  Spin a customizable wheel to pick from your own list of options. Add or remove choices on the fly; the outcome is selected locally with the browser's RNG. No accounts, no trackers, no server. Useful for restaurant picks, task assignment, or anything you would otherwise flip a coin for.
---
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow eyebrow--crumbs"><a class="eyebrow__link" href="{{ locale.pathPrefix }}/">~</a><span class="eyebrow__sep">/</span><a class="eyebrow__link" href="{{ locale.pathPrefix }}/tools/">tools</a><span class="eyebrow__sep">/</span><span class="eyebrow__current">decision-wheel</span></p>
  <h1>{{ "tools.decision-wheel.title" | t }}</h1>
  <p>{{ "tools.decision-wheel.lede" | t }}</p>
  {% include "tldr.njk" %}
</section>

{% set terminalTitle = "decision-wheel.js" %}
{% include "terminal-frame-open.njk" %}
<section class="dw">
  <div class="dw__stage">
    <!-- Outer ring decoration -->
    <div class="dw__ring-outer"></div>

    <!-- The wheel -->
    <div class="dw__wheel-wrap">
      <div class="dw__pointer" aria-hidden="true">
        <svg width="20" height="28" viewBox="0 0 20 28"><path d="M10 28L0 0h20z" fill="var(--syn-cyan)"/></svg>
      </div>
      <div class="dw__wheel" id="dw-wheel" role="img" aria-label="{{ 'tool.decision-wheel.aria_wheel' | t }}" aria-live="polite">
        <div class="dw__segment dw__segment--0"></div>
        <div class="dw__segment dw__segment--1"></div>
        <div class="dw__segment dw__segment--2"></div>
        <div class="dw__segment dw__segment--3"></div>
        <button class="dw__hub" id="dw-hub" type="button" aria-label="{{ 'tool.decision-wheel.aria_spin' | t }}"></button>
      </div>
    </div>
  </div>

  <div class="dw__result-wrap">
    <div class="dw__result-label">{{ "tool.decision-wheel.result_label" | t }}</div>
    <div class="dw__result" id="dw-result" data-outcome="">
      <span class="dw__result-text">{{ "tool.decision-wheel.result_ready" | t }}</span>
    </div>
  </div>

  <div class="dw__controls">
    <button class="dw__spin-btn" id="dw-spin">
      <span class="dw__spin-icon">&#x25B6;</span>
      {{ "tool.decision-wheel.btn_spin" | t }}
    </button>
  </div>

  <div class="dw__legend">
    <div class="dw__legend-item"><span class="dw__legend-dot" style="background:var(--syn-green)"></span>{{ "tool.decision-wheel.outcome_yes"   | t }}</div>
    <div class="dw__legend-item"><span class="dw__legend-dot" style="background:var(--syn-pink)"></span>{{ "tool.decision-wheel.outcome_no"    | t }}</div>
    <div class="dw__legend-item"><span class="dw__legend-dot" style="background:var(--syn-cyan)"></span>{{ "tool.decision-wheel.outcome_upto"  | t }}</div>
    <div class="dw__legend-item"><span class="dw__legend-dot" style="background:var(--syn-amber)"></span>{{ "tool.decision-wheel.outcome_wait"  | t }}</div>
  </div>
</section>
{% include "terminal-frame-close.njk" %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Mentria Decision Wheel",
  "operatingSystem": "Web",
  "applicationCategory": "ProductivityApplication",
  "description": "A minimal offline-ready decision wheel that helps you commit to an answer.",
  "offers": {
    "@type": "Offer",
    "price": "0"
  }
}
</script>

<script>
(() => {
  const outcomes = [
    { label: {{ ("tool.decision-wheel.outcome_yes"  | t) | dump | safe }}, cls: "yes",  color: "var(--syn-green)" },
    { label: {{ ("tool.decision-wheel.outcome_no"   | t) | dump | safe }}, cls: "no",   color: "var(--syn-pink)" },
    { label: {{ ("tool.decision-wheel.outcome_upto" | t) | dump | safe }}, cls: "upto", color: "var(--syn-cyan)" },
    { label: {{ ("tool.decision-wheel.outcome_wait" | t) | dump | safe }}, cls: "wait", color: "var(--syn-amber)" }
  ];

  const wheel = document.getElementById("dw-wheel");
  const resultEl = document.getElementById("dw-result");
  const resultText = resultEl.querySelector(".dw__result-text");
  const spinBtn = document.getElementById("dw-spin");
  const segments = wheel.querySelectorAll(".dw__segment");
  const segmentAngle = 360 / outcomes.length;

  let rotation = 0;
  let velocity = 0;
  let animating = false;
  let lastActiveIndex = -1;
  const FRICTION = 0.985;
  const STOP_THRESHOLD = 0.3;
  const SPIN_BOOST = 15 + Math.random() * 10;

  function getSegmentAtPointer() {
    const norm = ((rotation % 360) + 360) % 360;
    const pointerAngle = (360 - norm) % 360;
    return Math.floor(pointerAngle / segmentAngle) % outcomes.length;
  }

  function highlightSegment(index) {
    if (index === lastActiveIndex) return;
    segments.forEach(function(s) { s.classList.remove("dw__segment--active"); });
    if (index >= 0 && index < segments.length) {
      segments[index].classList.add("dw__segment--active");
    }
    lastActiveIndex = index;
  }

  function clearHighlights() {
    segments.forEach(function(s) {
      s.classList.remove("dw__segment--active");
      s.classList.remove("dw__segment--winner");
    });
    lastActiveIndex = -1;
  }

  function setWinner(index) {
    segments.forEach(function(s) { s.classList.remove("dw__segment--active"); });
    if (index >= 0 && index < segments.length) {
      segments[index].classList.add("dw__segment--winner");
    }
  }

  function tick() {
    if (!animating) return;

    velocity *= FRICTION;
    rotation += velocity;

    wheel.style.transform = "rotate(" + rotation + "deg)";

    var idx = getSegmentAtPointer();
    highlightSegment(idx);

    if (velocity < STOP_THRESHOLD) {
      // Stopped
      animating = false;
      velocity = 0;
      wheel.classList.remove("dw__wheel--spinning");

      var finalIndex = getSegmentAtPointer();
      var outcome = outcomes[finalIndex];
      resultText.textContent = outcome.label;
      resultEl.dataset.outcome = outcome.cls;
      resultEl.style.setProperty("--result-color", outcome.color);

      clearHighlights();
      setWinner(finalIndex);
      return;
    }

    requestAnimationFrame(tick);
  }

  function spin() {
    // Clear previous winner
    segments.forEach(function(s) { s.classList.remove("dw__segment--winner"); });

    // Add velocity — stacks on repeated clicks
    velocity += SPIN_BOOST + Math.random() * 8;

    // Cap max velocity
    if (velocity > 80) velocity = 80;

    resultText.textContent = "...";
    resultEl.dataset.outcome = "";
    wheel.classList.add("dw__wheel--spinning");

    if (!animating) {
      animating = true;
      requestAnimationFrame(tick);
    }
  }

  if (spinBtn) spinBtn.addEventListener("click", spin);
  var hubBtn = document.getElementById("dw-hub");
  if (hubBtn) hubBtn.addEventListener("click", spin);
})();
</script>

<style>
/* ── Decision Wheel — Terminal HUD ────────────────── */
.dw {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
  padding: 1rem 0;
  font-family: var(--font-mono);
}

/* ── Stage ────────────────────────────────────────── */
.dw__stage {
  position: relative;
  width: min(340px, 80vw);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dw__ring-outer {
  position: absolute;
  inset: -8px;
  border-radius: 50%;
  border: 1px solid rgba(34, 211, 238, 0.12);
  pointer-events: none;
}
.dw__ring-outer::before {
  content: '';
  position: absolute;
  inset: -12px;
  border-radius: 50%;
  border: 1px dashed rgba(34, 211, 238, 0.06);
}

/* ── Wheel ────────────────────────────────────────── */
.dw__wheel-wrap {
  position: relative;
  width: 100%;
  height: 100%;
}

.dw__wheel {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  background: #0d0d0d;
  box-shadow:
    0 0 0 2px rgba(255,255,255,0.06),
    0 0 40px rgba(0,0,0,0.6),
    inset 0 0 30px rgba(0,0,0,0.8);
}

.dw__wheel--spinning {
  box-shadow:
    0 0 0 2px rgba(34, 211, 238, 0.2),
    0 0 60px rgba(34, 211, 238, 0.1),
    inset 0 0 30px rgba(0,0,0,0.8);
}

/* ── Segments ─────────────────────────────────────── */
.dw__segment {
  position: absolute;
  width: 50%;
  height: 50%;
  transform-origin: 100% 100%;
  overflow: hidden;
  transition: background 0.15s ease, box-shadow 0.15s ease;
}

/* Active glow — segment passing under pointer */
.dw__segment--active.dw__segment--0 {
  background: linear-gradient(135deg, rgba(74, 222, 128, 0.3) 0%, rgba(74, 222, 128, 0.08) 100%);
  box-shadow: inset 0 0 30px rgba(74, 222, 128, 0.15);
}
.dw__segment--active.dw__segment--1 {
  background: linear-gradient(225deg, rgba(244, 114, 182, 0.3) 0%, rgba(244, 114, 182, 0.08) 100%);
  box-shadow: inset 0 0 30px rgba(244, 114, 182, 0.15);
}
.dw__segment--active.dw__segment--2 {
  background: linear-gradient(315deg, rgba(34, 211, 238, 0.3) 0%, rgba(34, 211, 238, 0.08) 100%);
  box-shadow: inset 0 0 30px rgba(34, 211, 238, 0.15);
}
.dw__segment--active.dw__segment--3 {
  background: linear-gradient(45deg, rgba(251, 191, 36, 0.3) 0%, rgba(251, 191, 36, 0.08) 100%);
  box-shadow: inset 0 0 30px rgba(251, 191, 36, 0.15);
}

/* Winner glow — final result */
.dw__segment--winner.dw__segment--0 {
  background: linear-gradient(135deg, rgba(74, 222, 128, 0.4) 0%, rgba(74, 222, 128, 0.1) 100%);
  box-shadow: inset 0 0 40px rgba(74, 222, 128, 0.2), 0 0 20px rgba(74, 222, 128, 0.1);
}
.dw__segment--winner.dw__segment--1 {
  background: linear-gradient(225deg, rgba(244, 114, 182, 0.4) 0%, rgba(244, 114, 182, 0.1) 100%);
  box-shadow: inset 0 0 40px rgba(244, 114, 182, 0.2), 0 0 20px rgba(244, 114, 182, 0.1);
}
.dw__segment--winner.dw__segment--2 {
  background: linear-gradient(315deg, rgba(34, 211, 238, 0.4) 0%, rgba(34, 211, 238, 0.1) 100%);
  box-shadow: inset 0 0 40px rgba(34, 211, 238, 0.2), 0 0 20px rgba(34, 211, 238, 0.1);
}
.dw__segment--winner.dw__segment--3 {
  background: linear-gradient(45deg, rgba(251, 191, 36, 0.4) 0%, rgba(251, 191, 36, 0.1) 100%);
  box-shadow: inset 0 0 40px rgba(251, 191, 36, 0.2), 0 0 20px rgba(251, 191, 36, 0.1);
}


/* Yes — top-right (green) */
.dw__segment--0 {
  top: 0; left: 50%;
  transform: rotate(0deg) skewY(0deg);
  background: linear-gradient(135deg, rgba(74, 222, 128, 0.12) 0%, rgba(74, 222, 128, 0.03) 100%);
  border-bottom: 1px solid rgba(74, 222, 128, 0.15);
  border-left: 1px solid rgba(74, 222, 128, 0.08);
}

/* No — bottom-right (pink) */
.dw__segment--1 {
  top: 50%; left: 50%;
  background: linear-gradient(225deg, rgba(244, 114, 182, 0.12) 0%, rgba(244, 114, 182, 0.03) 100%);
  border-top: 1px solid rgba(244, 114, 182, 0.15);
  border-left: 1px solid rgba(244, 114, 182, 0.08);
}

/* Up to you — bottom-left (cyan) */
.dw__segment--2 {
  top: 50%; left: 0;
  transform-origin: 100% 0%;
  background: linear-gradient(315deg, rgba(34, 211, 238, 0.12) 0%, rgba(34, 211, 238, 0.03) 100%);
  border-top: 1px solid rgba(34, 211, 238, 0.15);
  border-right: 1px solid rgba(34, 211, 238, 0.08);
}

/* Wait — top-left (amber) */
.dw__segment--3 {
  top: 0; left: 0;
  transform-origin: 100% 100%;
  background: linear-gradient(45deg, rgba(251, 191, 36, 0.12) 0%, rgba(251, 191, 36, 0.03) 100%);
  border-bottom: 1px solid rgba(251, 191, 36, 0.15);
  border-right: 1px solid rgba(251, 191, 36, 0.08);
}

/* ── Hub ──────────────────────────────────────────── */
.dw__hub {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: radial-gradient(circle, #1a1a1a 0%, #0a0a0a 100%);
  border: 2px solid rgba(255,255,255,0.08);
  box-shadow:
    0 0 20px rgba(0,0,0,0.8),
    inset 0 1px 0 rgba(255,255,255,0.05);
  z-index: 2;
  cursor: pointer;
  padding: 0;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.dw__hub:hover {
  border-color: rgba(34, 211, 238, 0.3);
  box-shadow:
    0 0 20px rgba(0,0,0,0.8),
    0 0 12px rgba(34, 211, 238, 0.15),
    inset 0 1px 0 rgba(255,255,255,0.05);
}
.dw__hub::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--syn-cyan);
  box-shadow: 0 0 10px var(--syn-cyan), 0 0 20px rgba(34, 211, 238, 0.3);
}

/* ── Pointer ──────────────────────────────────────── */
.dw__pointer {
  position: absolute;
  top: -14px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  filter: drop-shadow(0 0 8px rgba(34, 211, 238, 0.5));
  animation: dw-pointer-pulse 2s ease-in-out infinite;
}

@keyframes dw-pointer-pulse {
  0%, 100% { filter: drop-shadow(0 0 6px rgba(34, 211, 238, 0.4)); }
  50% { filter: drop-shadow(0 0 14px rgba(34, 211, 238, 0.7)); }
}

/* ── Result ───────────────────────────────────────── */
.dw__result-wrap {
  text-align: center;
}

.dw__result-label {
  font-size: 0.65rem;
  color: var(--term-muted);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 0.4rem;
}

.dw__result {
  --result-color: var(--term-muted);
  font-size: clamp(1.6rem, 5vw, 2.2rem);
  font-weight: 700;
  color: var(--result-color);
  min-height: 1.5em;
  display: flex;
  align-items: center;
  justify-content: center;
  text-shadow: 0 0 20px color-mix(in srgb, var(--result-color) 50%, transparent);
  transition: color 0.3s ease;
}

.dw__result[data-outcome="yes"] { --result-color: var(--syn-green); }
.dw__result[data-outcome="no"] { --result-color: var(--syn-pink); }
.dw__result[data-outcome="upto"] { --result-color: var(--syn-cyan); }
.dw__result[data-outcome="wait"] { --result-color: var(--syn-amber); }

/* ── Spin Button ──────────────────────────────────── */
.dw__controls {
  display: flex;
  justify-content: center;
}

.dw__spin-btn {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  border: none;
  border-radius: 999px;
  padding: 0.7rem 2rem;
  font-family: var(--font-mono);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  cursor: pointer;
  color: #000;
  background: linear-gradient(135deg, var(--syn-cyan) 0%, #0ea5e9 100%);
  box-shadow: 0 4px 20px rgba(34, 211, 238, 0.3);
  transition: all 0.25s ease;
}

.dw__spin-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 6px 28px rgba(34, 211, 238, 0.45);
}

.dw__spin-btn:active:not(:disabled) {
  transform: translateY(0);
}


.dw__spin-icon {
  font-size: 0.75rem;
}

/* ── Legend ────────────────────────────────────────── */
.dw__legend {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
  justify-content: center;
  font-size: 0.75rem;
  color: var(--term-muted);
}

.dw__legend-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.dw__legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  box-shadow: 0 0 6px currentColor;
}

/* ── Cross-hair lines ─────────────────────────────── */
.dw__wheel::before {
  content: '';
  position: absolute;
  top: 0; left: 50%;
  width: 1px;
  height: 100%;
  background: rgba(255,255,255,0.04);
  z-index: 1;
}
.dw__wheel::after {
  content: '';
  position: absolute;
  top: 50%; left: 0;
  width: 100%;
  height: 1px;
  background: rgba(255,255,255,0.04);
  z-index: 1;
}

/* ── Responsive ───────────────────────────────────── */
@media (max-width: 480px) {
  .dw__legend {
    gap: 0.75rem;
    font-size: 0.7rem;
  }
}
</style>
