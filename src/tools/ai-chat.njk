---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{{ locale.pathPrefix }}/tools/ai-chat/index.html"
eleventyComputed:
  lang: "{{ locale.code }}"
  title: "{{ 'tools.ai-chat.title' | t }}"
  description: "{{ 'tools.ai-chat.lede' | t }}"
tldr: >
  AI Chat runs Qwen3.5-0.8B locally in your browser via WebGPU. Your messages
  and any uploaded images never leave your device — no server, no API key, no
  account. Supports vision input. The model loads on first click; subsequent
  visits start instantly from local cache.
---
<section class="tldr">
  <h2 class="tldr__heading">{{ "tool.ai-chat.tldr_heading" | t }}</h2>
  <p class="tldr__body">{{ tldr }}</p>
</section>
<section class="hero" style="padding-top:1rem;">
  <p class="eyebrow">~/tools/ai-chat</p>
  <h1>{{ "tools.ai-chat.title" | t }}</h1>
  <p>{{ "tools.ai-chat.lede" | t }}</p>
</section>

{% set terminalTitle = "ai-chat.js" %}
{% include "terminal-frame-open.njk" %}
<section class="ac">
  <div class="ac__status" id="ac-status">
    <span class="ac__status-dot" id="ac-status-dot"></span>
    <span class="ac__status-text" id="ac-status-text">{{ "tool.ai-chat.status_checking_webgpu" | t }}</span>
    <button class="ac__delete-btn" id="ac-delete-model" title="{{ 'tool.ai-chat.btn_delete_model_title' | t }}" style="display:none;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
      <span>{{ "tool.ai-chat.btn_delete_model" | t }}</span>
    </button>
  </div>

  <div class="ac__progress-wrap" id="ac-progress-wrap" style="display:none;">
    <div class="ac__progress-info">
      <span id="ac-progress-label">{{ "tool.ai-chat.progress_label" | t }}</span>
      <span id="ac-progress-pct">0%</span>
    </div>
    <div class="ac__progress-bar">
      <div class="ac__progress-fill" id="ac-progress-fill"></div>
    </div>
    <div class="ac__progress-detail" id="ac-progress-detail"></div>
  </div>

  <div class="ac__messages" id="ac-messages">
    <div class="ac__empty" id="ac-empty">
      <div class="ac__empty-icon">&#9670;</div>
      <p>{{ "tool.ai-chat.empty_msg" | t }}</p>
      <p class="ac__empty-sub">{{ "tool.ai-chat.empty_sub" | t }}</p>
    </div>
  </div>

  <div class="ac__img-preview" id="ac-img-preview" style="display:none;">
    <img id="ac-img-thumb" alt="{{ 'tool.ai-chat.img_alt_attached' | t }}" />
    <button class="ac__img-remove" id="ac-img-remove" title="{{ 'tool.ai-chat.btn_remove_image' | t }}">&times;</button>
  </div>

  <div class="ac__input-wrap">
    <label class="ac__attach-btn" id="ac-attach-label" title="{{ 'tool.ai-chat.btn_attach_image' | t }}">
      <input type="file" id="ac-file-input" accept="image/*" hidden />
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
    </label>
    <textarea class="ac__input" id="ac-input" rows="1" placeholder="{{ 'tool.ai-chat.input_placeholder' | t }}" disabled></textarea>
    <button class="ac__send-btn" id="ac-send" title="{{ 'tool.ai-chat.btn_send' | t }}" disabled>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</section>
{% include "terminal-frame-close.njk" %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Mentria AI Chat",
  "operatingSystem": "Web",
  "applicationCategory": "UtilitiesApplication",
  "description": "Chat with a local AI model (Qwen3.5-0.8B) running entirely in your browser via WebGPU. Supports image input.",
  "offers": { "@type": "Offer", "price": "0" }
}
</script>

<script src="/assets/js/markdown.js?v={{ buildHash }}"></script>

<script type="module">
const COPY = {
  statusLoadingModel:  {{ ("tool.ai-chat.status_loading_model"  | t) | dump | safe }},
  statusGenerating:    {{ ("tool.ai-chat.status_generating"     | t) | dump | safe }},
  statusReady:         {{ ("tool.ai-chat.status_ready"          | t) | dump | safe }},
  statusModelDeleted:  {{ ("tool.ai-chat.status_model_deleted"  | t) | dump | safe }},
  imgAltAttachedShort: {{ ("tool.ai-chat.img_alt_attached_short" | t) | dump | safe }},
  labelYou:            {{ ("tool.ai-chat.label_you"             | t) | dump | safe }},
  errNoWebGpu:         {{ ("tool.ai-chat.err_no_webgpu"         | t) | dump | safe }},
  errUnsupportedMain:  {{ ("tool.ai-chat.err_unsupported_main"  | t) | dump | safe }},
  errUnsupportedSub:   {{ ("tool.ai-chat.err_unsupported_sub"   | t) | dump | safe }},
  errLoadRuntime:      {{ ("tool.ai-chat.err_load_runtime"      | t) | dump | safe }},
  errDeviceLost:       {{ ("tool.ai-chat.err_device_lost"       | t) | dump | safe }},
  errLoadPrefix:       {{ ("tool.ai-chat.err_load_prefix"       | t) | dump | safe }},
  errPrefix:           {{ ("tool.ai-chat.err_prefix"            | t) | dump | safe }},
  errDeletePrefix:     {{ ("tool.ai-chat.err_delete_prefix"     | t) | dump | safe }},
  emptyResponse:       {{ ("tool.ai-chat.empty_response"        | t) | dump | safe }},
  confirmDelete:       {{ ("tool.ai-chat.confirm_delete"        | t) | dump | safe }}
};

const MENTRIA_DIST_BASE  = '/assets/mentria/dist/';
const MENTRIA_MODEL_BASE = 'https://huggingface.co/mentriaai/Qwen3.5-0.8B-mentria/resolve/main/';
const MENTRIA_TOKEN_BASE = MENTRIA_MODEL_BASE;

// Vision tower config — mirrors src/model/vision_config.js
// QWEN35_VL_08B_VISION_CONFIG. Matches the on-disk layout of the
// qwen3.5-0.8b-vl-q4.safetensors file (S585).
const MENTRIA_VL_CONFIG = {
  hidden_size: 768,
  intermediate_size: 3072,
  num_heads: 12,
  head_dim: 64,                 // 768 / 12
  out_hidden_size: 1024,        // matches text H for 0.8B
  depth: 12,
  patch_size: 16,
  temporal_patch_size: 2,
  spatial_merge_size: 2,
  num_position_embeddings: 2304,
  num_grid_per_side: 48,        // sqrt(2304)
  eps: 1e-6,
  prefix: 'visual',
};

const MAX_TOKENS = 512;

/* ── Status helpers ────────────────────────────────────────────────────── */
const statusDot  = document.getElementById('ac-status-dot');
const statusText = document.getElementById('ac-status-text');
function setStatus(state, text) {
  statusDot.className = 'ac__status-dot ac__status-dot--' + state;
  statusText.textContent = text;
}

/* ── WebGPU gate ───────────────────────────────────────────────────────── */
// Mentria is WebGPU-only by design. If the browser doesn't expose WebGPU,
// surface a clean error rather than silently degrading. Common cases:
//   - Safari < 26 (no WebGPU)
//   - Firefox stable (WebGPU still in nightly as of 2026-04)
//   - Chrome on Linux without `--enable-features=Vulkan`
//   - Mobile browsers without WebGPU yet
function showUnsupportedError(reason) {
  setStatus('error', reason);
  const messagesEl = document.getElementById('ac-messages');
  const emptyEl    = document.getElementById('ac-empty');
  if (emptyEl) {
    const escSub = COPY.errUnsupportedSub.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    emptyEl.innerHTML =
      '<div class="ac__empty-icon">&#9888;</div>' +
      '<p>' + COPY.errUnsupportedMain + '</p>' +
      '<p class="ac__empty-sub">' + escSub + '</p>';
  }
  document.getElementById('ac-input').disabled = true;
  document.getElementById('ac-send').disabled  = true;
  document.getElementById('ac-attach-label').style.display = 'none';
}

if (!navigator.gpu) {
  showUnsupportedError(COPY.errNoWebGpu);
} else {
  let MentriaEngine;
  try {
    ({ MentriaEngine } = await import(MENTRIA_DIST_BASE + 'mentria.mjs'));
  } catch (err) {
    console.error('Failed to load mentria-engine bundle:', err);
    showUnsupportedError(COPY.errLoadRuntime);
  }
  if (MentriaEngine) runApp(MentriaEngine);
}

function runApp(MentriaEngine) {
  /* ── DOM refs ────────────────────────────────────── */
  const deleteBtn     = document.getElementById('ac-delete-model');
  const progressWrap  = document.getElementById('ac-progress-wrap');
  const progressLabel = document.getElementById('ac-progress-label');
  const progressPct   = document.getElementById('ac-progress-pct');
  const progressFill  = document.getElementById('ac-progress-fill');
  const progressDetail= document.getElementById('ac-progress-detail');
  const messagesEl    = document.getElementById('ac-messages');
  const emptyEl       = document.getElementById('ac-empty');
  const imgPreview    = document.getElementById('ac-img-preview');
  const imgThumb      = document.getElementById('ac-img-thumb');
  const imgRemoveBtn  = document.getElementById('ac-img-remove');
  const fileInput     = document.getElementById('ac-file-input');
  const inputEl       = document.getElementById('ac-input');
  const sendBtn       = document.getElementById('ac-send');

  /* ── State ───────────────────────────────────────── */
  let engine = null;
  let generating = false;
  let attachedImage = null;       // {rgbHwc, h, w} — pending attach for the NEXT send
  let attachedDataUrl = null;
  // conversationImages keeps every image sent in this conversation, in order.
  // The chat template re-renders the full message history every turn, so each
  // {type:'image'} placeholder needs its corresponding rgbHwc on every call —
  // not just the turn the image was first attached on.
  let conversationImages = [];
  let messages = [
    { role: 'system', content:
      'You are a vision-capable assistant running locally in the user\'s browser. ' +
      'When the user shares an image, describe what you see directly and concisely — ' +
      'do not say you can\'t access photos or apologize. Just describe the image. ' +
      'Be helpful, accurate, and brief.'
    },
  ];

  function scrollToBottom() { messagesEl.scrollTop = messagesEl.scrollHeight; }
  function autoResize() {
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 120) + 'px';
  }
  function formatBytes(b) {
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(1) + ' MB';
  }

  function addMessage(role, content, imageUrl) {
    if (emptyEl) emptyEl.style.display = 'none';
    const bubble = document.createElement('div');
    bubble.className = 'ac__msg ac__msg--' + role;
    const label = document.createElement('div');
    label.className = 'ac__msg-label';
    label.textContent = role === 'user' ? COPY.labelYou : 'qwen-0.8B';
    bubble.appendChild(label);
    if (imageUrl) {
      const img = document.createElement('img');
      img.className = 'ac__msg-img'; img.src = imageUrl; img.alt = COPY.imgAltAttachedShort;
      bubble.appendChild(img);
    }
    const body = document.createElement('div');
    body.className = 'ac__msg-body';
    if (content) body.textContent = content;
    bubble.appendChild(body);
    messagesEl.appendChild(bubble);
    scrollToBottom();
    return body;
  }

  /* ── Image preprocessing ─────────────────────────── */
  // Mentria expects {rgbHwc: Uint8Array, h, w} where h,w are multiples of
  // patch_size * spatial_merge_size = 32. We cap at 448² for predictable
  // prefill latency (~286 ms vision-tower pass on M-series; chat-friendly
  // per the engine's S463 bench).
  async function fileToEngineImage(file, targetSize = 448) {
    const bitmap = await createImageBitmap(file);
    const maxDim = Math.max(bitmap.width, bitmap.height);
    const scale = maxDim > targetSize ? (targetSize / maxDim) : 1;
    let w = Math.round(bitmap.width * scale);
    let h = Math.round(bitmap.height * scale);
    w = Math.max(32, Math.round(w / 32) * 32);
    h = Math.max(32, Math.round(h / 32) * 32);
    const canvas = document.createElement('canvas');
    canvas.width = w; canvas.height = h;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(bitmap, 0, 0, w, h);
    const { data } = ctx.getImageData(0, 0, w, h);
    const rgbHwc = new Uint8Array(w * h * 3);
    for (let i = 0, j = 0; i < data.length; i += 4, j += 3) {
      rgbHwc[j]     = data[i];
      rgbHwc[j + 1] = data[i + 1];
      rgbHwc[j + 2] = data[i + 2];
    }
    return { rgbHwc, h, w };
  }

  /* ── Progress tracking ───────────────────────────── */
  // The engine multiplexes two progress semantics on one channel: BYTE counts
  // for shard download/upload (loaded/total in the hundreds-of-millions) and
  // STEP counters for discrete stage transitions (loaded=0/1, loaded=1/1).
  // We clamp the ratio to [0,1] so a stale byte loaded paired with a step
  // total can't render as "60-billion-percent", and we only show the
  // human-readable byte line when total looks like real bytes (>= 1 KiB).
  function onEngineProgress(p) {
    if (!p) return;
    progressWrap.style.display = '';
    if (p.message) progressLabel.textContent = p.message;
    if (p.loaded != null && p.total != null && p.total > 0) {
      const ratio = Math.max(0, Math.min(1, p.loaded / p.total));
      const pct = Math.round(ratio * 100);
      progressFill.style.width = pct + '%';
      progressPct.textContent = pct + '%';
      progressDetail.textContent =
        p.total >= 1024 ? (formatBytes(p.loaded) + ' / ' + formatBytes(p.total)) : '';
    }
  }

  /* ── Load engine + model ─────────────────────────── */
  async function loadModel() {
    setStatus('loading', COPY.statusLoadingModel);
    progressWrap.style.display = '';
    try {
      engine = new MentriaEngine(MENTRIA_DIST_BASE + 'worker.mjs');
      engine.onProgress = onEngineProgress;
      // onDeviceLost is wired by the engine's S410 device-loss handler;
      // surface it to the user with a clear "reload to recover" message.
      engine.onDeviceLost = (info) => {
        setStatus('error', COPY.errDeviceLost);
        inputEl.disabled = true; sendBtn.disabled = true;
        console.error('WebGPU device lost:', info);
      };
      await engine.init();
      await engine.loadModel({
        modelUrl: MENTRIA_MODEL_BASE,
        shards: ['qwen3.5-0.8b-q4.safetensors'],
        tokenizerUrl: MENTRIA_TOKEN_BASE,
        visionModelUrl: MENTRIA_MODEL_BASE,
        visionShards: ['qwen3.5-0.8b-vl-q4.safetensors'],
        visionConfig: MENTRIA_VL_CONFIG,
      });
      progressWrap.style.display = 'none';
      setStatus('ready', COPY.statusReady);
      deleteBtn.style.display = '';
      inputEl.disabled = false;
      sendBtn.disabled = false;
      inputEl.focus();
    } catch (err) {
      progressWrap.style.display = 'none';
      console.error('Model load error:', err);
      setStatus('error', COPY.errLoadPrefix + (err.message || err));
    }
  }

  /* ── Generate ────────────────────────────────────── */
  async function generate() {
    if (generating || !engine) return;
    const text = inputEl.value.trim();
    if (!text && !attachedImage) return;

    generating = true;
    inputEl.value = '';
    autoResize();
    sendBtn.disabled = true;
    setStatus('generating', COPY.statusGenerating);

    // Build user content (mirrors HF chat-template content-array shape)
    const userContent = [];
    if (attachedImage) userContent.push({ type: 'image' });
    userContent.push({ type: 'text', text: text || 'Describe this image.' });

    addMessage('user', text, attachedDataUrl);
    messages.push({ role: 'user', content: userContent });

    const bodyEl = addMessage('assistant', '');
    let fullText = '';
    let pendingPaint = false;

    function paintToken() {
      const display = fullText.replace(/<think>[\s\S]*?<\/think>/g, '').trim();
      // window.renderMarkdown escapes html before applying markdown patterns,
      // so model-emitted <script> tags are inert. Falls back to textContent if
      // markdown.js failed to load.
      if (window.renderMarkdown) bodyEl.innerHTML = renderMarkdown(display) || '<p>…</p>';
      else bodyEl.textContent = display || '…';
      scrollToBottom();
      pendingPaint = false;
    }

    // If a NEW image was just attached, append it to the persistent conversation
    // history so it stays bound to its placeholder in the messages array on every
    // future turn. Then clear the staging state.
    if (attachedImage) {
      conversationImages.push({
        rgbHwc: attachedImage.rgbHwc,
        h: attachedImage.h,
        w: attachedImage.w,
      });
    }
    // Pass the FULL conversation image history to the engine on every call.
    // The engine matches placeholders to images by order across the whole
    // chat-template render, so dropping prior images crashes build3DPositions.
    const imagesForRequest = conversationImages.length ? conversationImages : undefined;
    attachedImage = null;
    attachedDataUrl = null;
    imgPreview.style.display = 'none';
    fileInput.value = '';

    try {
      const params = {
        messages: [...messages],
        maxTokens: MAX_TOKENS,
        // Greedy decoding (matches transformers.js do_sample:false)
        temperature: 0, topK: 1, topP: 1.0,
        repetitionPenalty: 1.15,   // bumped 1.10 → 1.15 to break list-cycle pattern (S+1 test)
        enableThinking: false,
      };
      if (imagesForRequest) params.images = imagesForRequest;

      await engine.generate(params, (event) => {
        if (typeof event.token === 'string' && event.token.length > 0) {
          // Skip Qwen special tokens (<|im_end|>, <|endoftext|>, etc) from the visible stream
          if (/^<\|[^|]*\|>$/.test(event.token)) return;
          fullText += event.token;
          if (!pendingPaint) {
            pendingPaint = true;
            requestAnimationFrame(paintToken);
          }
        }
      });

      const display = fullText
        .replace(/<think>[\s\S]*?<\/think>/g, '')
        .replace(/<\|[^|]*\|>/g, '')   // belt-and-suspenders strip if a multi-piece special leaks through
        .trim();
      const escEmpty = COPY.emptyResponse.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      if (window.renderMarkdown) bodyEl.innerHTML = renderMarkdown(display) || `<p>${escEmpty}</p>`;
      else bodyEl.textContent = display || COPY.emptyResponse;
      messages.push({ role: 'assistant', content: display });
    } catch (err) {
      bodyEl.textContent = COPY.errPrefix + err.message;
      console.error('Generation error:', err);
    }

    generating = false;
    sendBtn.disabled = false;
    setStatus('ready', COPY.statusReady);
    inputEl.focus();
  }

  /* ── Delete cached model ─────────────────────────── */
  async function deleteModel() {
    if (!confirm(COPY.confirmDelete)) return;
    try {
      const keys = await caches.keys();
      for (const key of keys) {
        if (key.includes('mentria') || key.includes('huggingface') || key.includes('transformers')) {
          await caches.delete(key);
        }
      }
      const dbs = (typeof indexedDB.databases === 'function') ? await indexedDB.databases() : [];
      for (const db of dbs) {
        if (db.name && (db.name.includes('mentria') || db.name.includes('transformers') || db.name.includes('onnxruntime'))) {
          indexedDB.deleteDatabase(db.name);
        }
      }
      try { await engine?.unload(); } catch {}
      engine = null;
      messages = [];
      messagesEl.innerHTML = '';
      if (emptyEl) {
        messagesEl.appendChild(emptyEl);
        emptyEl.style.display = '';
      }
      deleteBtn.style.display = 'none';
      inputEl.disabled = true;
      sendBtn.disabled = true;
      setStatus('idle', COPY.statusModelDeleted);
    } catch (err) {
      console.error('Delete error:', err);
      alert(COPY.errDeletePrefix + err.message);
    }
  }

  /* ── Image handling ──────────────────────────────── */
  async function attachFile(file) {
    if (!file || !file.type.startsWith('image/')) return;
    try {
      const url = URL.createObjectURL(file);
      imgThumb.src = url;
      imgPreview.style.display = '';
      attachedDataUrl = url;
      attachedImage = await fileToEngineImage(file);
    } catch (err) {
      console.error('Image attach error:', err);
      attachedImage = null;
      attachedDataUrl = null;
      imgPreview.style.display = 'none';
    }
  }

  function removeImage() {
    attachedImage = null;
    attachedDataUrl = null;
    imgPreview.style.display = 'none';
    imgThumb.src = '';
    fileInput.value = '';
  }

  /* ── Events ──────────────────────────────────────── */
  sendBtn.addEventListener('click', generate);

  inputEl.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      generate();
    }
  });

  inputEl.addEventListener('input', autoResize);

  fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) attachFile(fileInput.files[0]);
  });

  imgRemoveBtn.addEventListener('click', removeImage);
  deleteBtn.addEventListener('click', deleteModel);

  // Paste image from clipboard
  document.addEventListener('paste', e => {
    const items = e.clipboardData?.items;
    if (!items) return;
    for (const item of items) {
      if (item.type.startsWith('image/')) {
        e.preventDefault();
        attachFile(item.getAsFile());
        break;
      }
    }
  });

  /* ── Init ────────────────────────────────────────── */
  loadModel();
}
</script>

<style>
/* ── AI Chat — Terminal HUD ─────────────────────── */
.ac {
  display: flex;
  flex-direction: column;
  font-family: var(--font-mono);
  height: min(600px, 70vh);
}

/* ── Status bar ─────────────────────────────────── */
.ac__status {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.75rem;
  border-bottom: 1px solid var(--term-border);
  font-size: 0.75rem;
  color: var(--term-muted);
  flex-shrink: 0;
}

.ac__status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--term-muted);
  flex-shrink: 0;
}
.ac__status-dot--idle     { background: var(--term-muted); }
.ac__status-dot--loading  { background: var(--syn-amber); box-shadow: 0 0 6px var(--syn-amber); animation: ac-pulse 1.5s ease-in-out infinite; }
.ac__status-dot--ready    { background: var(--syn-green); box-shadow: 0 0 6px var(--syn-green); }
.ac__status-dot--generating { background: var(--syn-cyan); box-shadow: 0 0 6px var(--syn-cyan); animation: ac-pulse 1s ease-in-out infinite; }
.ac__status-dot--error    { background: var(--syn-pink); box-shadow: 0 0 6px var(--syn-pink); }

@keyframes ac-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.ac__delete-btn {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  background: none;
  border: 1px solid rgba(244, 114, 182, 0.2);
  color: var(--syn-pink);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.2s ease;
}
.ac__delete-btn:hover {
  background: rgba(244, 114, 182, 0.1);
  border-color: rgba(244, 114, 182, 0.4);
}

